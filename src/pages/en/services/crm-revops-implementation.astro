import EnServicePage from '../../../components/EnServicePage.astro';
---

<EnServicePage
  title="CRM / RevOps Implementation"
  description="Turn revenue architecture into CRM configuration, workflows, automation, and reporting that teams can actually use."
  heroTagline="Turn revenue architecture into systems, workflows, and reporting that teams can actually use."
  heroBrief="We help global B2B teams translate revenue flow, lifecycle logic, handoff rules, and KPI requirements into CRM configuration, automation, dashboards, and operating processes."
  secondaryCta="View HubSpot Support"
  secondaryCtaHref="/en/services/hubspot-implementation-operations-support/"
  coversHeading="What this service covers"
  covers={[
    { body: "CRM structure and object design — contact, company, deal, and custom object setup based on your revenue model" },
    { body: "Lifecycle stage and status configuration — stage definitions, transition criteria, and ownership rules built into the CRM" },
    { body: "Lead routing and handoff workflows — automated assignment, notification, and task creation based on handoff rules" },
    { body: "Automation and notification logic — triggers, sequences, and alerts connected to process milestones" },
    { body: "Reporting and dashboard setup — custom views for marketing, sales, and leadership with the right metrics and filters" },
    { body: "Data fields, required properties, and update rules — field logic that enforces data quality during normal use" },
    { body: "Integration planning with related tools — connections to marketing, sales, CS, and billing systems where applicable" },
  ]}
  goodFitHeading="This is a good fit if:"
  goodFitItems={[
    "Your CRM exists but does not reflect how revenue actually moves — stages are vague, data is inconsistent, or pipeline is unreliable",
    "Marketing and sales use different definitions for lead status, qualification, or pipeline stage",
    "Handoff between teams depends on manual communication rather than system-driven workflows",
    "Reports exist but are not trusted or used for decisions",
    "HubSpot or another CRM is underused and not connected to your actual revenue process",
    "You have completed strategy or architecture work and need implementation support to build it into the system",
  ]}
  deliverables={[
    "CRM pipeline and object configuration — stages, properties, and validation rules built to match your architecture",
    "Lead and contact lifecycle setup — status definitions, scoring rules, and list segmentation",
    "Automation workflows — lead routing, task creation, handoff triggers, and notification rules",
    "Integration connections — CRM connected to relevant tools where applicable",
    "Reporting and dashboards — metrics configured for each team's visibility needs",
    "Process documentation — written record of how the system is configured and why",
    "End-to-end testing before handoff — verified lead flow, automation triggers, and reporting accuracy",
  ]}
  japanGTM="Japan-facing CRM implementation requires decisions that differ from standard setups. Lead scoring logic needs to reflect Japan-specific qualification signals. Pipeline stages need to account for the extended trust-building phase before formal sales engagement. Handoff timing rules need to fit Japan's relationship-driven sales motion. Reporting needs to surface the metrics that matter for Japan's longer decision cycles. We build the CRM around these realities, not around a generic template that assumes Western buying behavior."
