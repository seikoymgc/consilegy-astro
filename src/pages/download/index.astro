---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqItems = [
	{
		q: '資料は無料ですか？',
		a: 'はい、無料でダウンロードいただけます。会員登録や費用は一切不要です。フォームにお名前・会社名・メールアドレスをご入力いただくだけでお受け取りいただけます。',
	},
	{
		q: '営業連絡は来ますか？',
		a: 'ダウンロード後に自動的に営業連絡をお送りすることはありません。内容にご興味をお持ちいただいた場合のみ、お問い合わせフォームやCRM / RevOps診断ページよりお気軽にご相談ください。',
	},
	{
		q: '小規模企業でも参考になりますか？',
		a: 'はい。Revenue ArchitectureやRevOpsの考え方は、企業規模に関わらず適用できます。特に「CRMを導入したが定着しない」「営業とマーケの連携が取れない」「KPIが部門ごとに異なる」といった課題は、20名〜300名規模の企業でも頻繁に発生します。',
	},
	{
		q: 'Salesforce以外にも対応していますか？',
		a: 'はい。本資料はSalesforceに限らず、HubSpot・Kintone・Marketo・Account Engagementなど主要CRM / SFA / MA全般を対象としています。Consilegyはベンダーフリーの立場で支援しており、特定ツールに依存しないRevOps設計の考え方を解説しています。',
	},
	{
		q: 'HubSpot利用企業向けですか？',
		a: 'HubSpot利用企業だけでなく、Salesforce・Kintone・複数ツール混在環境の企業も対象です。「どのツールを使うか」ではなく「どう設計・運用するか」に焦点を当てた内容になっています。',
	},
	{
		q: 'Revenue Architectureとは何ですか？',
		a: 'Revenue Architectureは、営業・マーケティング・カスタマーサクセスなど収益に関わる全部門のプロセス・データ・KPI・ツール・会議体を統合的に設計する考え方です。CRMやSFAの導入・設定にとどまらず、収益構造全体を俯瞰して設計します。本資料では、Revenue Architectureの基本的な考え方と設計アプローチを解説しています。',
	},
	{
		q: 'RevOpsとの違いは何ですか？',
		a: 'RevOps（Revenue Operations）は、Revenue Architectureを継続的に運用・改善する機能・組織です。Revenue Architectureが「設計図」とすれば、RevOpsは「設計図を現場で動かし続ける仕組み」です。本資料では両者の関係性と、RevOps導入の具体的なアプローチについても解説しています。',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map(({ q, a }) => ({
		'@type': 'Question',
		name: q,
		acceptedAnswer: { '@type': 'Answer', text: a },
	})),
};
---

<BaseLayout
	title="CRM / RevOps再設計ガイド｜資料ダウンロード | Consilegy"
	description="収益構造（レベニューアーキテクチャ）を整え、営業・マーケ・CSをつなぐRevenue Operationsの設計方法。CRM / RevOps / Revenue Architecture設計ガイド資料。無料ダウンロード。"
	lang="ja"
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	</Fragment>

<!-- ===== HERO ===== -->
<section class="hero">
	<div class="container">
		<div class="hero-inner">
			<div class="hero-text">
				<p class="eyebrow">Document Download</p>
				<h1>CRM / RevOps<br />再設計ガイド</h1>
				<p class="hero-sub">
					収益構造（レベニューアーキテクチャ）を整え、営業・マーケ・CSをつなぐRevenue Operationsの設計方法
				</p>
				<div class="hero-tags">
					<span class="hero-tag">Revenue Architecture</span>
					<span class="hero-tag">RevOps</span>
					<span class="hero-tag">CRM再設計</span>
					<span class="hero-tag">営業マーケ連携</span>
					<span class="hero-tag">KPI設計</span>
				</div>
				<a href="#download-form" class="btn btn--primary btn--lg">資料をダウンロードする →</a>
			</div>
			<div class="hero-mock">
				<div class="pdf-mock">
					<div class="pdf-mock__cover">
						<div class="pdf-mock__logo">CONSILEGY</div>
						<div class="pdf-mock__rule"></div>
						<div class="pdf-mock__title">CRM / RevOps<br />再設計ガイド</div>
						<div class="pdf-mock__subtitle">収益構造（レベニューアーキテクチャ）を整え、<br />営業・マーケ・CSをつなぐ設計方法</div>
						<div class="pdf-mock__rule pdf-mock__rule--bottom"></div>
						<div class="pdf-mock__meta">2025 Edition</div>
					</div>
					<div class="pdf-mock__spine"></div>
					<div class="pdf-mock__shadow"></div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ===== 資料内容 ===== -->
<section class="contents">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow">Contents</p>
			<h2>資料内容</h2>
		</div>
		<div class="contents-grid">
			<div class="content-card">
				<div class="content-card__num">01</div>
				<h3>Revenue Architectureとは</h3>
				<p>Revenue Operationsを支える収益構造設計の考え方。なぜCRM単体では不十分なのか。</p>
			</div>
			<div class="content-card">
				<div class="content-card__num">02</div>
				<h3>RevOps再設計</h3>
				<p>営業・マーケ・CS連携をどう整理するか。部門横断の運用構造の設計アプローチ。</p>
			</div>
			<div class="content-card">
				<div class="content-card__num">03</div>
				<h3>CRM再設計</h3>
				<p>Salesforce / HubSpot / Kintoneなどをどう設計するか。導入後に定着させる設計の考え方。</p>
			</div>
			<div class="content-card">
				<div class="content-card__num">04</div>
				<h3>KPI設計</h3>
				<p>部門を横断したKPI管理の考え方。経営・営業・マーケ・CSが共通で動くKPI体系の作り方。</p>
			</div>
			<div class="content-card">
				<div class="content-card__num">05</div>
				<h3>マルチCRM運用</h3>
				<p>Salesforce + HubSpotなど複数ツールをどう統合するか。ベンダーフリーの設計思想。</p>
			</div>
			<div class="content-card">
				<div class="content-card__num">06</div>
				<h3>よくある失敗</h3>
				<p>CRM導入後に運用が崩れる企業の特徴。定着しない本当の原因と対策。</p>
			</div>
		</div>
	</div>
</section>

<!-- ===== おすすめ企業 ===== -->
<section class="fit">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow">Good Fit</p>
			<h2>こんな企業向けの資料です</h2>
		</div>
		<div class="fit-grid">
			<div class="fit-item"><span class="fit-check">✓</span>CRMを導入したが定着しない</div>
			<div class="fit-item"><span class="fit-check">✓</span>営業とマーケが分断している</div>
			<div class="fit-item"><span class="fit-check">✓</span>KPIが部門ごとに異なる</div>
			<div class="fit-item"><span class="fit-check">✓</span>SalesforceとHubSpotが分断している</div>
			<div class="fit-item"><span class="fit-check">✓</span>Revenue Operationsを整備したい</div>
			<div class="fit-item"><span class="fit-check">✓</span>RevOps組織を作りたい</div>
			<div class="fit-item"><span class="fit-check">✓</span>Revenue Architectureを理解したい</div>
			<div class="fit-item"><span class="fit-check">✓</span>CRM再設計を検討している</div>
		</div>
	</div>
</section>

<!-- ===== 資料イメージ ===== -->
<section class="preview">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow">Preview</p>
			<h2>資料イメージ</h2>
			<p class="section-desc">会社紹介ではなく、実際の設計資料の考え方を共有しています。</p>
		</div>
		<div class="preview-grid">
			<!-- Revenue Architecture図 -->
			<div class="preview-card">
				<div class="preview-card__mock">
					<div class="ra-diagram">
						<div class="ra-top-row">
							<div class="ra-node ra-node--strategy">Revenue<br />Architecture</div>
						</div>
						<div class="ra-mid-row">
							<div class="ra-node ra-node--sales">Sales Ops</div>
							<div class="ra-node ra-node--mktg">マーケティング<br />Ops</div>
							<div class="ra-node ra-node--cs">CS Ops</div>
						</div>
						<div class="ra-bottom-row">
							<div class="ra-tool">CRM</div>
							<div class="ra-tool">MA</div>
							<div class="ra-tool">BI</div>
						</div>
					</div>
				</div>
				<p class="preview-card__label">Revenue Architecture 構造図</p>
			</div>

			<!-- KPIツリー -->
			<div class="preview-card">
				<div class="preview-card__mock">
					<div class="kpi-tree">
						<div class="kpi-root">Revenue KPI</div>
						<div class="kpi-branches">
							<div class="kpi-branch">
								<div class="kpi-parent">Pipeline</div>
								<div class="kpi-children">
									<div class="kpi-leaf">MQL</div>
									<div class="kpi-leaf">SQL</div>
								</div>
							</div>
							<div class="kpi-branch">
								<div class="kpi-parent">Win Rate</div>
								<div class="kpi-children">
									<div class="kpi-leaf">Deal Cycle</div>
									<div class="kpi-leaf">CAC</div>
								</div>
							</div>
							<div class="kpi-branch">
								<div class="kpi-parent">ARR</div>
								<div class="kpi-children">
									<div class="kpi-leaf">NRR</div>
									<div class="kpi-leaf">LTV</div>
								</div>
							</div>
						</div>
					</div>
				</div>
				<p class="preview-card__label">KPI体系 設計図</p>
			</div>

			<!-- RevOpsフロー -->
			<div class="preview-card">
				<div class="preview-card__mock">
					<div class="flow-diagram">
						<div class="flow-step flow-step--mktg">
							<div class="flow-label">マーケティング</div>
							<div class="flow-items">
								<div class="flow-item">Lead Gen</div>
								<div class="flow-item flow-item--hi">MQL定義</div>
							</div>
						</div>
						<div class="flow-arrow">→</div>
						<div class="flow-step flow-step--sales">
							<div class="flow-label">営業</div>
							<div class="flow-items">
								<div class="flow-item flow-item--hi">SQL定義</div>
								<div class="flow-item">商談化</div>
							</div>
						</div>
						<div class="flow-arrow">→</div>
						<div class="flow-step flow-step--cs">
							<div class="flow-label">CS</div>
							<div class="flow-items">
								<div class="flow-item">オンボード</div>
								<div class="flow-item flow-item--hi">NRR</div>
							</div>
						</div>
					</div>
				</div>
				<p class="preview-card__label">営業・マーケ・CS 連携フロー</p>
			</div>

			<!-- ダッシュボードUI -->
			<div class="preview-card">
				<div class="preview-card__mock">
					<div class="dash-preview">
						<div class="dash-preview__header">RevOps Dashboard</div>
						<div class="dash-preview__kpis">
							<div class="dash-kpi">
								<div class="dash-kpi__v">¥142M</div>
								<div class="dash-kpi__l">Pipeline</div>
							</div>
							<div class="dash-kpi">
								<div class="dash-kpi__v">28%</div>
								<div class="dash-kpi__l">Win Rate</div>
							</div>
							<div class="dash-kpi">
								<div class="dash-kpi__v">42%</div>
								<div class="dash-kpi__l">MQL→SQL</div>
							</div>
						</div>
						<div class="dash-preview__bars">
							<div class="dash-bar" style="height:50%"></div>
							<div class="dash-bar" style="height:65%"></div>
							<div class="dash-bar" style="height:42%"></div>
							<div class="dash-bar dash-bar--hi" style="height:85%"></div>
							<div class="dash-bar" style="height:70%"></div>
							<div class="dash-bar dash-bar--hi" style="height:90%"></div>
						</div>
					</div>
				</div>
				<p class="preview-card__label">KPI ダッシュボード設計</p>
			</div>

			<!-- CRM構造図 -->
			<div class="preview-card">
				<div class="preview-card__mock">
					<div class="crm-diagram">
						<div class="crm-header">CRM Data Architecture</div>
						<div class="crm-objects">
							<div class="crm-obj crm-obj--contact">Contact</div>
							<div class="crm-obj crm-obj--company">Company</div>
							<div class="crm-obj crm-obj--deal">Deal</div>
						</div>
						<div class="crm-props">
							<div class="crm-prop">ライフサイクル</div>
							<div class="crm-prop">MQL/SQL定義</div>
							<div class="crm-prop">パイプライン</div>
							<div class="crm-prop">KPI紐付け</div>
						</div>
					</div>
				</div>
				<p class="preview-card__label">CRM データ設計</p>
			</div>

			<!-- 失敗パターン -->
			<div class="preview-card">
				<div class="preview-card__mock">
					<div class="failure-list">
						<div class="failure-header">CRM崩壊のパターン</div>
						<div class="failure-item">
							<span class="failure-x">✕</span>
							<span>KPIが現場業務につながらない</span>
						</div>
						<div class="failure-item">
							<span class="failure-x">✕</span>
							<span>会議が改善につながらない</span>
						</div>
						<div class="failure-item">
							<span class="failure-x">✕</span>
							<span>入力ルールが曖昧なまま</span>
						</div>
						<div class="failure-item">
							<span class="failure-x">✕</span>
							<span>営業マーケが再び分断</span>
						</div>
					</div>
				</div>
				<p class="preview-card__label">よくある失敗パターン</p>
			</div>
		</div>
	</div>
</section>

<!-- ===== FORM ===== -->
<section class="form-section" id="download-form">
	<div class="container">
		<div class="form-layout">
			<div class="form-text">
				<p class="eyebrow">Download</p>
				<h2>資料をダウンロードする</h2>
				<p class="form-lead">
					以下のフォームにご入力いただくと、資料をお送りします。ダウンロード後に営業連絡が届くことはありません。
				</p>
				<ul class="form-note-list">
					<li>無料でダウンロードいただけます</li>
					<li>自動的な営業連絡はありません</li>
					<li>PDF形式でお受け取りいただけます</li>
				</ul>
			</div>
			<div class="form-embed">
				<iframe
					src="https://share-na2.hsforms.com/1TnQ9hL_NRM-zY2A83OVo1gromnr"
					width="100%"
					style="min-height: 520px; border: none;"
					title="資料ダウンロードフォーム"
					loading="lazy"
				></iframe>
			</div>
		</div>
	</div>
</section>

<!-- ===== 診断導線 ===== -->
<section class="next-section">
	<div class="container">
		<div class="next-box">
			<div class="next-text">
				<p class="eyebrow">Next Step</p>
				<h2>具体的な課題整理をご希望の場合</h2>
				<p>
					CRM / RevOps / 営業マーケ連携 / KPI設計に課題がある場合は、専用の診断ページから現状整理をご相談いただけます。
				</p>
			</div>
			<a href="/free-consultation/" class="btn btn--primary">30分無料相談を予約 →</a>
		</div>
	</div>
</section>

<!-- ===== FAQ ===== -->
<section class="faq-section">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow">FAQ</p>
			<h2>よくある質問</h2>
		</div>
		<div class="faq-list">
			{faqItems.map(({ q, a }) => (
				<details class="faq-item">
					<summary class="faq-q">{q}</summary>
					<div class="faq-a"><p>{a}</p></div>
				</details>
			))}
		</div>
	</div>
</section>

<!-- ===== FINAL CTA ===== -->
<section class="cta-final">
	<div class="container">
		<p class="cta-final__eyebrow">Document Download</p>
		<h2>
			CRM / RevOpsの設計方法を、<br />
			まず資料で確認しませんか。
		</h2>
		<p class="cta-final__body">
			CRM、営業・マーケ・CS連携、KPI、Revenue Architectureについて、<br />
			Consilegyの支援思想を資料にまとめています。
		</p>
		<div class="cta-final__btns">
			<a href="#download-form" class="btn btn--white btn--lg">資料をダウンロードする →</a>
			<a href="/free-consultation/" class="btn btn--outline-white btn--lg">30分無料相談を予約</a>
		</div>
	</div>
</section>

</BaseLayout>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
	--color-primary: #1e40af;
	--color-primary-dark: #1d4ed8;
	--color-navy: #0f172a;
	--color-slate: #1e293b;
	--color-charcoal: #334155;
	--color-muted: #64748b;
	--color-border: #e2e8f0;
	--color-border-mid: #cbd5e1;
	--color-bg-soft: #f8fafc;
	--font-serif: 'Noto Serif JP', Georgia, serif;
	--font-sans: 'Noto Sans JP', system-ui, sans-serif;
	--container: 1100px;
	--radius: 8px;
}

body { font-family: var(--font-sans); color: var(--color-navy); line-height: 1.7; }
.container { max-width: var(--container); margin: 0 auto; padding: 0 2rem; }

.eyebrow { display: block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-primary); margin-bottom: 0.625rem; }
.section-header { text-align: center; margin-bottom: 3rem; }
.section-header h2 { font-family: var(--font-serif); font-size: clamp(1.5rem, 3vw, 2rem); color: var(--color-navy); }
.section-desc { margin-top: 0.75rem; color: var(--color-muted); font-size: 0.9375rem; }

.btn { display: inline-flex; align-items: center; justify-content: center; font-weight: 600; border-radius: 5px; text-decoration: none; transition: all 0.18s; font-size: 0.9375rem; padding: 0.75rem 1.5rem; }
.btn--lg { padding: 0.9rem 2rem; font-size: 1rem; }
.btn--primary { background: var(--color-primary); color: #fff; border: 2px solid transparent; }
.btn--primary:hover { background: var(--color-primary-dark); }
.btn--white { background: #fff; color: var(--color-primary); border: 2px solid transparent; }
.btn--white:hover { background: #f1f5f9; }
.btn--outline-white { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,0.55); }
.btn--outline-white:hover { background: rgba(255,255,255,0.12); }

/* ===== HERO ===== */
.hero {
	padding: 5rem 0 4.5rem;
	background: #fff;
	border-bottom: 1px solid var(--color-border);
}
.hero-inner {
	display: grid;
	grid-template-columns: 1fr auto;
	gap: 4rem;
	align-items: center;
}
.hero h1 {
	font-family: var(--font-serif);
	font-size: clamp(2rem, 4vw, 2.875rem);
	color: var(--color-navy);
	line-height: 1.3;
	margin-bottom: 1.25rem;
}
.hero-sub {
	font-size: 1rem;
	color: var(--color-charcoal);
	line-height: 1.9;
	margin-bottom: 1.5rem;
	max-width: 48ch;
}
.hero-tags {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5rem;
	margin-bottom: 2rem;
}
.hero-tag {
	font-size: 0.8125rem;
	font-weight: 600;
	background: var(--color-bg-soft);
	color: var(--color-charcoal);
	border: 1px solid var(--color-border-mid);
	border-radius: 4px;
	padding: 0.25rem 0.75rem;
}

/* PDF Mock */
.hero-mock { flex-shrink: 0; }
.pdf-mock {
	position: relative;
	width: 220px;
}
.pdf-mock__cover {
	width: 200px;
	height: 280px;
	background: var(--color-navy);
	border-radius: 3px 6px 6px 3px;
	padding: 2rem 1.5rem;
	display: flex;
	flex-direction: column;
	justify-content: space-between;
	box-shadow: 4px 4px 24px rgba(0,0,0,0.25), 0 0 0 1px rgba(0,0,0,0.1);
	position: relative;
