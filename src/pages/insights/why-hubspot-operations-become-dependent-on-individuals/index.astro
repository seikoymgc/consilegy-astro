.hsc-flow--1 { border-left: 3px solid #fbbf24; }
.hsc-flow--2 { border-left: 3px solid #f59e0b; }
.hsc-flow--3 { border-left: 3px solid #d97706; }
.hsc-flow--4 { border-left: 3px solid #92400e; }
.hsc-flow--5 { border-left: 3px solid #94a3b8; }
.hsc-flow--6 { border-left: 3px solid #dc2626; color: #dc2626; font-weight: 600; }
.hsc-bubbles { display: flex; justify-content: center; gap: 8px; flex-wrap: wrap; }
.hsc-bubble { background: #fff; border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; padding: 5px 12px; font-size: 0.75rem; color: var(--color-charcoal, #334155); }
.hsc-bubble--warn { background: #fee2e2; border-color: #fca5a5; color: #991b1b; font-weight: 600; }
.hsc-footer { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
.hsc-tag { font-size: 0.75rem; font-weight: 600; }
.bad  { color: #dc2626; }
.good { color: #16a34a; }

/* --- DIAGRAM 2: HubSpot Architecture --- */
.diag--hs-arch { display: flex; flex-direction: column; gap: 12px; }
.hsa-header { text-align: center; font-size: 0.9rem; font-weight: 700; color: var(--color-navy, #0f172a); letter-spacing: 0.03em; }
