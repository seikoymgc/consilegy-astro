	'@type': 'Article',
	headline: 'CRM統合プロジェクトが失敗する理由｜RevOpsとRevenue Architecture',
	description: 'Salesforce・HubSpot・KintoneなどのCRM統合プロジェクトが失敗する原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
	datePublished: pubDate,
	dateModified: pubDate,
	author: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	publisher: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	url: 'https://consilegy.com/insights/why-crm-integration-projects-fail/',
	inLanguage: 'ja',
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
