.diag-lg-lead--warn { background: #fef9c3; color: #92400e; }
.diag-lg-flow__label { font-size: .65rem; font-weight: 700; color: #b91c1c; background: #fef2f2; border-radius: 3px; padding: 2px 8px; }

.diag-lg-vs { font-size: 1.4rem; font-weight: 700; color: #b91c1c; padding: 0 4px; }

.diag-lg-footer { display: flex; justify-content: center; flex-wrap: wrap; gap: 8px; margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--color-border, #e2e8f0); }
