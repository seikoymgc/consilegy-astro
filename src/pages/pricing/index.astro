---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="パッケージ料金 | Consilegy"
	description="診断パッケージ（10〜50万円）、マルチCRM再設計プロジェクト（300〜800万円）、伴走・顧問支援（月額30〜100万円）。目的に応じて選べる3つのプランをご用意しています。"
	lang="ja"
>
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{"@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://consilegy.com/"},
		{"@type": "ListItem", "position": 2, "name": "パッケージ料金", "item": "https://consilegy.com/pricing/"}
	]
})} />
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
	"@context": "https://schema.org",
	"@type": "WebPage",
	"@id": "https://consilegy.com/pricing/#webpage",
	"url": "https://consilegy.com/pricing/",
	"name": "パッケージ料金 | Consilegy",
	"description": "診断パッケージ（10〜50万円）、マルチCRM再設計プロジェクト（300〜800万円）、伴走・顧問支援（月額30〜100万円）",
	"publisher": { "@id": "https://consilegy.com/#organization" },
	"mainEntity": {
		"@type": "ItemList",
		"name": "Consilegy サービスプラン一覧",
		"itemListElement": [
			{
				"@type": "ListItem",
				"position": 1,
				"item": {
					"@type": "Service",
					"name": "簡易診断",
					"description": "現状のヒアリングと課題仮説の提示。オンラインMTG数回とレポート作成に絞った入口商品。",
					"provider": { "@id": "https://consilegy.com/#organization" },
					"offers": { "@type": "Offer", "priceCurrency": "JPY", "priceRange": "¥100,000〜¥150,000" }
				}
			},
			{
				"@type": "ListItem",
				"position": 2,
				"item": {
					"@type": "Service",
					"name": "詳細診断",
					"description": "CRM / SFA / MA運用とデータ構造のフルレビュー。ボトルネックの根拠と再設計ロードマップを提示。",
					"provider": { "@id": "https://consilegy.com/#organization" },
					"offers": { "@type": "Offer", "priceCurrency": "JPY", "priceRange": "¥300,000〜¥500,000" }
				}
			},
			{
				"@type": "ListItem",
				"position": 3,
				"item": {
					"@type": "Service",
					"name": "マルチCRM再設計プロジェクト",
					"description": "Salesforce / HubSpot / Kintone / Marketoなど複数ツールが混在する収益オペレーションを再設計。営業プロセス・データモデル・KPI基盤を一体で再構築。",
					"provider": { "@id": "https://consilegy.com/#organization" },
					"offers": { "@type": "Offer", "priceCurrency": "JPY", "priceRange": "¥3,000,000〜¥8,000,000" }
				}
			},
			{
				"@type": "ListItem",
				"position": 4,
				"item": {
					"@type": "Service",
					"name": "ライト伴走支援",
					"description": "月1〜2回の定例会とダッシュボード改善アドバイスを中心とした月額伴走支援。",
					"provider": { "@id": "https://consilegy.com/#organization" },
					"offers": { "@type": "Offer", "priceCurrency": "JPY", "priceRange": "¥300,000〜¥400,000/月" }
				}
			},
			{
				"@type": "ListItem",
				"position": 5,
				"item": {
					"@type": "Service",
					"name": "スタンダード伴走支援",
					"description": "営業・マーケ・CS各部門への定例伴走。KPIレビューからレポート改善・施策優先順位づけまで対応。",
					"provider": { "@id": "https://consilegy.com/#organization" },
					"offers": { "@type": "Offer", "priceCurrency": "JPY", "priceRange": "¥500,000〜¥800,000/月" }
				}
			},
			{
				"@type": "ListItem",
				"position": 6,
				"item": {
					"@type": "Service",
					"name": "フル伴走支援",
					"description": "施策の設計・実行まで入り込む最も深い関与。部門間調整や改善プロジェクトのリードまで担当。",
					"provider": { "@id": "https://consilegy.com/#organization" },
					"offers": { "@type": "Offer", "priceCurrency": "JPY", "priceRange": "¥800,000〜/月" }
				}
			}
		]
	}
})} />

<!-- ===================== HERO ===================== -->
<section class="hero">
	<div class="container">
		<span class="eyebrow"><span class="eyebrow__dot"></span>Pricing</span>
		<h1>パッケージ料金</h1>
		<p class="hero-lead">
			目的に応じて選べる3つのプラン。まず現状を把握したい企業から、
			CRM基盤を根本から作り直したい企業まで、フェーズに合わせてご選択ください。
		</p>
		<div class="hero-actions">
			<a href="/free-consultation/" class="btn btn--hero-primary btn--lg">30分無料相談を予約 →</a>
			<a href="/download/" class="btn btn--hero-outline btn--lg">サービス資料をダウンロード</a>
		</div>
	</div>
</section>

<!-- ===================== PRICING NOTE ===================== -->
<section class="pricing-note">
	<div class="container">
		<h2 class="pn-title">料金体系について</h2>
		<p class="pn-lead">Consilegyでは、目的に応じて以下の2つの料金体系をご用意しています。</p>
		<div class="pn-grid">
			<div class="pn-item">
				<span class="pn-type">プロジェクト型</span>
				<p>診断や再設計プロジェクトなど、期間と成果物が定められた単発支援。</p>
			</div>
			<div class="pn-item">
				<span class="pn-type">月額型</span>
				<p>伴走・顧問支援など、継続的な改善と定着支援を行う月額プラン。</p>
			</div>
		</div>
		<p class="pn-custom-note">表示価格はパッケージ料金の目安です。プロジェクトの規模・期間・要件に応じてカスタマイズが可能ですので、お気軽にご相談ください。</p>
	</div>
</section>

<!-- ===================== STEP 01: DIAGNOSIS ===================== -->
<section class="plan-section" id="diagnosis">
	<div class="container">
		<div class="plan-group-head">
			<span class="step-badge">Step 01</span>
			<h2>診断パッケージ</h2>
			<p class="plan-group-sub">まず現状を把握する。予算・意思決定前の入口として。</p>
		</div>

		<div class="plan-grid plan-grid--2">

			<article class="plan-card">
				<p class="plan-tag">簡易診断</p>
				<p class="plan-sub">現状のヒアリングと課題仮説の提示。オンラインMTG数回とレポート作成に絞った入口商品。</p>
				<div class="plan-price">
					<div class="plan-price__amount">¥100,000〜150,000</div>
					<span class="plan-price__unit">オンラインMTG 2〜3回 + レポート提出</span>
				</div>
				<ul class="plan-features">
					<li><span class="check" aria-hidden="true">✓</span>現状ツール・業務フローのヒアリング</li>
					<li><span class="check" aria-hidden="true">✓</span>課題仮説と優先度の整理</li>
					<li><span class="check" aria-hidden="true">✓</span>改善の方向性レポート（10〜15ページ）</li>
				</ul>
				<a href="/contact/" class="btn btn--primary plan-cta">まず相談してみる →</a>
			</article>

			<article class="plan-card">
				<p class="plan-tag">詳細診断</p>
				<p class="plan-sub">CRM / SFA / MA運用とデータ構造のフルレビュー。ボトルネックの根拠と再設計ロードマップを提示します。</p>
				<div class="plan-price">
					<div class="plan-price__amount">¥300,000〜500,000</div>
					<span class="plan-price__unit">期間目安：4〜6週間 / 一括</span>
				</div>
				<ul class="plan-features">
					<li><span class="check" aria-hidden="true">✓</span>CRM / MA運用・データ構造の詳細レビュー</li>
					<li><span class="check" aria-hidden="true">✓</span>業務インタビュー（5〜10名）</li>
					<li><span class="check" aria-hidden="true">✓</span>ボトルネック分析と改善ロードマップ</li>
					<li><span class="check" aria-hidden="true">✓</span>経営報告会（1回）</li>
				</ul>
				<a href="/contact/" class="btn btn--primary plan-cta">詳細診断を相談する →</a>
			</article>

		</div>
	</div>
</section>

<!-- ===================== STEP 02: PROJECT ===================== -->
<section class="plan-section plan-section--alt" id="project">
	<div class="container">
		<div class="plan-group-head">
			<span class="step-badge">Step 02</span>
			<h2>マルチCRM再設計プロジェクト</h2>
			<p class="plan-group-sub">収益構造を根本から直す。最も相談の多い中核プロジェクト。</p>
		</div>

		<article class="plan-card plan-card--recommended" id="project-card">
			<span class="plan-sub-badge">おすすめ</span>
			<p class="plan-tag">マルチCRM再設計プロジェクト</p>
			<p class="plan-sub">Salesforce / HubSpot / Kintone / Marketoなど複数ツールが混在する収益オペレーションを、ベンダー中立の立場で設計し直す中核プロジェクト。営業プロセス・データモデル・KPI基盤を一体で再構築します。</p>
			<div class="plan-price">
				<div class="plan-price__amount">¥3,000,000〜8,000,000</div>
				<span class="plan-price__unit">期間目安：3〜6ヶ月 / 一括または分割</span>
			</div>
			<ul class="plan-features plan-features--cols">
				<li><span class="check" aria-hidden="true">✓</span>To-Beデータモデル / オブジェクト設計</li>
				<li><span class="check" aria-hidden="true">✓</span>マルチCRM間の統合・移行設計</li>
				<li><span class="check" aria-hidden="true">✓</span>営業 / マーケ / CSプロセス再設計</li>
				<li><span class="check" aria-hidden="true">✓</span>KPI / レポーティング基盤の再構築</li>
				<li><span class="check" aria-hidden="true">✓</span>実装ベンダー選定支援（中立）</li>
				<li><span class="check" aria-hidden="true">✓</span>PMO / ステアリング運営</li>
			</ul>
			<a href="/contact/" class="btn btn--primary plan-cta">プロジェクトを相談する →</a>
		</article>
	</div>
</section>

<!-- ===================== STEP 03: RETAINER ===================== -->
<section class="plan-section" id="support">
	<div class="container">
		<div class="plan-group-head">
			<span class="step-badge">Step 03</span>
			<h2>伴走・顧問支援</h2>
			<p class="plan-group-sub">定着・内製化まで支える月次支援。関与度に応じて3プランから選択。</p>
		</div>

		<div class="plan-grid plan-grid--3">

			<article class="plan-card">
				<p class="plan-tag">ライト伴走</p>
				<p class="plan-sub">まず伴走から始めたい企業向け。月1〜2回の定例会とダッシュボード改善アドバイスを中心に支援。</p>
				<div class="plan-price">
					<div class="plan-price__amount">¥300,000〜400,000</div>
					<span class="plan-price__unit">月額 / 最低3ヶ月〜</span>
				</div>
				<ul class="plan-features">
					<li><span class="check" aria-hidden="true">✓</span>月次定例会（1〜2回）</li>
					<li><span class="check" aria-hidden="true">✓</span>KPIダッシュボードレビュー</li>
					<li><span class="check" aria-hidden="true">✓</span>課題整理・優先順位づけ</li>
				</ul>
				<a href="/contact/" class="btn btn--primary plan-cta">相談する →</a>
			</article>

			<article class="plan-card">
				<p class="plan-tag">スタンダード伴走</p>
				<p class="plan-sub">営業・マーケ・CS各部門への定例伴走。KPIレビューからレポート改善・施策優先順位づけまで対応。</p>
				<div class="plan-price">
					<div class="plan-price__amount">¥500,000〜800,000</div>
					<span class="plan-price__unit">月額 / 最低3ヶ月〜</span>
				</div>
				<ul class="plan-features">
					<li><span class="check" aria-hidden="true">✓</span>月次定例会（各部門 月1回）</li>
					<li><span class="check" aria-hidden="true">✓</span>KPIレビュー・レポート改善</li>
					<li><span class="check" aria-hidden="true">✓</span>施策の優先順位付け</li>
					<li><span class="check" aria-hidden="true">✓</span>Slack等での非同期相談対応</li>
				</ul>
				<a href="/contact/" class="btn btn--primary plan-cta">相談する →</a>
			</article>

			<article class="plan-card">
				<p class="plan-tag">フル伴走</p>
				<p class="plan-sub">施策の設計・実行まで入り込む、最も深い関与。部門間調整や改善プロジェクトのリードまで担当。</p>
				<div class="plan-price">
					<div class="plan-price__amount">¥800,000〜</div>
					<span class="plan-price__unit">月額 / 最低6ヶ月〜</span>
				</div>
				<ul class="plan-features">
					<li><span class="check" aria-hidden="true">✓</span>施策設計・実行まで伴走</li>
					<li><span class="check" aria-hidden="true">✓</span>部門間調整・ステークホルダー管理</li>
					<li><span class="check" aria-hidden="true">✓</span>改善プロジェクトのリード</li>
					<li><span class="check" aria-hidden="true">✓</span>RevOpsチーム内製化支援</li>
				</ul>
				<a href="/contact/" class="btn btn--primary plan-cta">相談する →</a>
			</article>

		</div>
	</div>
</section>

<!-- ===================== SERVICES BRIDGE ===================== -->
<section class="services-bridge">
	<div class="container bridge-inner">
		<div>
			<p class="section-eyebrow">Services</p>
			<h2>各サービスの詳細はこちら</h2>
			<p class="section-lead">
				レベニューアーキテクチャ設計・マーケティング戦略設計・CRM実装支援など、
				5つの支援領域の詳細をサービス一覧でご確認いただけます。
			</p>
		</div>
		<a href="/services/" class="btn btn--primary btn--lg">サービス一覧を見る →</a>
	</div>
</section>

<!-- ===================== FINAL CTA ===================== -->
<section class="final-cta">
	<div class="container cta-inner">
		<div>
			<p class="cta-eyebrow">Get Started</p>
			<h2>まずは現状の<br />CRM / RevOps構成を、<br />中立の視点で診断しませんか。</h2>
			<p class="cta-lead">
				初回ご相談は無料です。
				現状のツール構成・組織・データフローを伺い、
				再設計の優先順位とプロジェクト規模感をお伝えします。
				90分のディスカッション形式で実施します。
			</p>
			<div class="cta-actions">
				<a href="/free-consultation/" class="btn btn--cta-primary btn--lg">30分無料相談を予約 →</a>
				<a href="/download/" class="btn btn--cta-outline btn--lg">サービス資料をダウンロード</a>
			</div>
		</div>
		<div class="cta-card">
			<h4>ご相談時にお伺いする内容</h4>
			<ul class="cta-list">
				<li>現在ご利用中のCRM / SFA / MAツール構成</li>
				<li>事業部・組織体制（規模・部門数）</li>
				<li>現状の課題・優先度の高いテーマ</li>
				<li>想定スケジュールと社内ステークホルダー</li>
				<li>過去の導入・移行プロジェクトの経緯</li>
			</ul>
		</div>
	</div>
</section>

</BaseLayout>

<style>
/* ── Shared ──────────────────────────────────────────── */
.section-eyebrow {
	font-size: 0.8125rem; font-weight: 600; color: var(--color-primary);
	letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 0.75rem;
}
.section-lead { font-size: 1.0625rem; color: var(--color-text-muted); line-height: 1.75; margin: 0; }
.btn--lg { padding: 1.0625rem 1.875rem; font-size: 1rem; }

/* ── Pricing Note ──────────────────────────────────── */
.pricing-note {
	background: #f0f5ff;
	border-top: 1px solid rgba(30,64,175,0.15);
	border-bottom: 1px solid rgba(30,64,175,0.15);
	padding-block: var(--space-lg);
}
.pn-title {
	font-size: 1rem; font-weight: 700; color: var(--color-text);
	margin: 0 0 0.5rem;
}
.pn-lead {
	font-size: 0.9375rem; color: var(--color-text-muted); margin: 0 0 1.25rem;
}
.pn-grid {
	display: flex; gap: 1rem; flex-wrap: wrap;
}
.pn-item {
	flex: 1; min-width: 220px;
	background: #fff; border: 1px solid rgba(30,64,175,0.15);
	border-radius: 8px; padding: 1rem 1.25rem;
	display: flex; flex-direction: column; gap: 0.375rem;
}
.pn-type {
	font-size: 0.8125rem; font-weight: 700; color: var(--color-primary);
	letter-spacing: 0.04em;
}
.pn-item p { margin: 0; font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.65; }
.pn-custom-note {
	margin: 1rem 0 0; padding: 0.875rem 1.125rem;
	background: #fff; border: 1px solid rgba(30,64,175,0.2);
	border-left: 3px solid var(--color-primary); border-radius: 0 6px 6px 0;
	font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.7;
}

/* ── Hero ──────────────────────────────────────────── */
.hero {
	background: linear-gradient(180deg, var(--color-bg-subtle) 0%, var(--color-bg) 100%);
	border-bottom: 1px solid var(--color-border);
	padding-block: var(--space-2xl) var(--space-xl);
}
.eyebrow {
	display: inline-flex; align-items: center; gap: 0.5rem;
	font-size: 0.8125rem; font-weight: 600; color: var(--color-primary);
	background: rgba(30,64,175,0.08); padding: 0.375rem 0.875rem; border-radius: 4px;
	letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 1.25rem;
}
.eyebrow__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-primary); display: inline-block; }
.hero h1 {
	font-size: clamp(2.25rem, 4vw, 3.25rem); font-weight: 600;
	letter-spacing: 0.01em; margin: 0 0 1rem; color: var(--color-text); line-height: 1.2;
}
.hero-lead { font-size: 1.125rem; line-height: 1.75; color: var(--color-text-muted); max-width: 680px; margin: 0 0 2rem; }
.hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

.btn--hero-primary {
	display: inline-flex; align-items: center;
	background: var(--color-primary); color: #fff;
	padding: 1.0625rem 1.875rem; border-radius: var(--radius);
	font-weight: 700; font-size: 1rem; text-decoration: none; border: none;
	transition: background 0.15s ease;
}
.btn--hero-primary:hover { background: var(--color-primary-dark); color: #fff; }

.btn--hero-outline {
	display: inline-flex; align-items: center;
	background: transparent; color: var(--color-primary);
	padding: 1.0625rem 1.875rem; border-radius: var(--radius);
	font-weight: 600; font-size: 1rem; text-decoration: none;
	border: 1.5px solid var(--color-primary);
	transition: all 0.15s ease;
}
.btn--hero-outline:hover { background: rgba(30,64,175,0.06); }

/* ── Plan Sections ─────────────────────────────────── */
.plan-section { padding-block: var(--space-2xl); background: var(--color-bg); }
.plan-section--alt { background: var(--color-bg-subtle); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }

.plan-group-head { margin-bottom: 2rem; }
.step-badge {
	display: inline-block; font-size: 0.75rem; font-weight: 700;
	color: var(--color-primary); background: rgba(30,64,175,0.08);
	padding: 0.25rem 0.75rem; border-radius: 4px;
	letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 0.75rem;
}
.plan-group-head h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 700; color: var(--color-text); margin: 0 0 0.5rem; }
.plan-group-sub { font-size: 1.0625rem; color: var(--color-text-muted); margin: 0; }

.plan-grid { display: grid; gap: 1.25rem; }
.plan-grid--2 { grid-template-columns: 1fr 1fr; }
.plan-grid--3 { grid-template-columns: 1fr 1fr 1fr; }

/* ── Plan Cards ────────────────────────────────────── */
.plan-card {
