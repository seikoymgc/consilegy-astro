.hsa-layer-items { display: flex; gap: 8px; flex-wrap: wrap; }
.hsa-item { font-size: 0.7rem; border-radius: 4px; padding: 3px 8px; }
.layer-top .hsa-item { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: #e2e8f0; }
.layer-bot .hsa-item { background: #fff; border: 1px solid var(--color-border, #e2e8f0); color: var(--color-charcoal, #334155); }
.item-kpi { background: rgba(255,255,255,0.2) !important; }
.item-sf  { background: rgba(0,161,224,0.3) !important; }
.item-bi  { background: rgba(242,200,17,0.25) !important; color: #92400e !important; }
.hsa-lifecycle { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; justify-content: center; }
