		{ '@type': 'ListItem', position: 2, name: 'コラム', item: 'https://consilegy.com/insights/' },
		{ '@type': 'ListItem', position: 3, name: 'CRMがあっても営業とマーケティングが連携できない理由', item: 'https://consilegy.com/insights/why-crm-does-not-align-sales-and-marketing/' },
	],
