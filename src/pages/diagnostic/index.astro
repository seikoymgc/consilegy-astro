---
// 収益診断 LP — front door from LinkedIn / newsletter to the free self-check,
// which funnels into the paid CRM/RevOps assessment (/revops-assessment/).
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORIES } from '../../lib/diagnostic-data';

const pains = [
	{
		title: 'リードはあるのに、商談につながらない',
		desc: 'マーケは「渡している」、営業は「使えない」。境目でリードが静かに消えていく。',
	},
	{
		title: '営業が属人化して、売上が読めない',
		desc: 'トップ営業の頭の中にしかない基準。抜けたら数字が崩れる構造のまま。',
	},
	{
		title: 'マーケに投資しても、成果が見えない',
		desc: '施策は打っている。でも受注にどうつながったか、誰も説明できない。',
	},
];
---

<BaseLayout
	title="売上の取りこぼし診断（無料・1分）| あなたの会社は、どこで売上を取りこぼしているか？ | Consilegy"
	description="マーケ・営業・CSの「境目」を6つの観点で1分セルフ診断。取りこぼしマップで、売上をどこで取りこぼしているかを可視化します。無料。"
	lang="ja"
>

<!-- ===== HERO ===== -->
<section class="dx-hero">
	<div class="container">
		<p class="dx-eyebrow">Revenue Diagnostic — 無料セルフ診断</p>
		<h1>あなたの会社は、<br />どこで売上を取りこぼしているか？</h1>
		<p class="dx-sub">マーケ・営業・CSの「境目」を6つの観点で1分診断。無料。</p>
		<div class="dx-hero-actions">
			<a href="/diagnostic/start/" class="btn dx-btn-primary">無料で診断する（約1分）→</a>
		</div>
		<p class="dx-hero-note">メール登録は結果表示の直前。設問はすべて選択式です。</p>
	</div>
</section>

<!-- ===== PAINS ===== -->
<section class="dx-pains">
	<div class="container">
		<p class="section-eyebrow">Symptoms</p>
		<h2 class="dx-section-title">こんな状態に、心当たりはありませんか？</h2>
		<div class="dx-pain-grid">
			{pains.map((p) => (
				<div class="dx-pain-card">
					<h3>{p.title}</h3>
					<p>{p.desc}</p>
				</div>
			))}
		</div>
	</div>
</section>

<!-- ===== WHAT YOU GET ===== -->
<section class="dx-what">
	<div class="container">
		<p class="section-eyebrow">What You Get</p>
		<h2>6つの「境目」の信号が出る、<br class="sp-only" />取りこぼしマップ</h2>
		<p class="dx-what-lead">
			売上は「部門の中」ではなく「部門の境目」で取りこぼしています。
			この診断は、取りこぼしやすい6つの境目を信号（🔴🟡🟢）で可視化します。
		</p>
		<div class="dx-cat-grid">
			{CATEGORIES.map((c, i) => (
				<div class="dx-cat-card">
					<span class="dx-cat-num">{String(i + 1).padStart(2, '0')}</span>
					<span class="dx-cat-name">{c.name}</span>
				</div>
			))}
		</div>
	</div>
</section>

<!-- ===== TRUST ===== -->
<section class="dx-trust">
	<div class="container dx-trust-inner">
		<div>
			<p class="section-eyebrow">Behind It</p>
			<h2>Revenue Architectureの<br />実務フレームで設計</h2>
			<p>
				この診断は、代表が40社以上のB2B支援で繰り返し見てきた
				「売上を取りこぼす境目」のパターンをもとに設計しています。
				ツール起点ではなく、収益プロセス全体の構造から取りこぼしを特定します。
			</p>
			<a href="/revenue-architecture/" class="dx-trust-link">Revenue Architectureとは →</a>
		</div>
		<div class="dx-trust-stats">
			<div class="dx-stat">
				<span class="dx-stat-num">40<span class="dx-stat-unit">社+</span></span>
				<span class="dx-stat-label">代表が支援したB2B企業</span>
			</div>
			<div class="dx-stat">
				<span class="dx-stat-num">6<span class="dx-stat-unit">観点</span></span>
				<span class="dx-stat-label">収益プロセスの境目を診断</span>
			</div>
			<div class="dx-stat">
				<span class="dx-stat-num">1<span class="dx-stat-unit">分</span></span>
				<span class="dx-stat-label">全12問・選択式</span>
			</div>
		</div>
	</div>
</section>

<!-- ===== FINAL CTA ===== -->
<section class="dx-cta">
	<div class="container">
		<h2>まず、どこで取りこぼしているかを知る</h2>
		<p>診断は無料・約1分。結果はその場で表示されます。</p>
		<a href="/diagnostic/start/" class="btn dx-btn-primary dx-btn-lg">無料で診断する（約1分）→</a>
	</div>
</section>

</BaseLayout>

<style>
.container { max-width: 1120px; margin-inline: auto; padding-inline: 1.25rem; }
section { padding-block: var(--space-2xl); }
.section-eyebrow {
	display: block; font-size: 0.5625rem; font-weight: 500; color: var(--color-text-muted);
	letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 1.25rem;
	padding-top: 0.875rem; border-top: 1.5px solid var(--color-border);
}
.sp-only { display: none; }
@media (max-width: 640px) { .sp-only { display: inline; } }
.dx-section-title {
	font-size: clamp(1.375rem, 3.5vw, 2.25rem); font-weight: 500;
	line-height: 1.3; letter-spacing: -0.02em; color: var(--color-text);
	margin: 0 0 2rem;
}

/* Hero */
.dx-hero {
	background:
		radial-gradient(800px 460px at 90% 0%, rgba(59,130,246,0.10), transparent 60%),
		radial-gradient(640px 420px at 0% 100%, rgba(124,92,191,0.07), transparent 60%),
		linear-gradient(180deg, #F7F8FC 0%, #EFF2F9 100%);
	border-bottom: 1px solid var(--color-border);
	padding-block: 5rem 4rem;
}
.dx-eyebrow {
	font-size: 0.625rem; font-weight: 500; color: var(--color-primary);
	letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 1.25rem;
}
.dx-hero h1 {
	font-size: clamp(1.875rem, 5vw, 3.5rem); font-weight: 500;
	line-height: 1.2; letter-spacing: -0.02em; color: var(--color-text);
	margin: 0 0 1.25rem;
}
.dx-sub { font-size: clamp(1rem, 2.5vw, 1.1875rem); color: var(--color-text-muted); margin: 0 0 2rem; line-height: 1.7; }
.dx-hero-actions { margin-bottom: 1rem; }
.dx-hero-note { font-size: 0.8125rem; color: var(--color-text-muted); margin: 0; }

.dx-btn-primary {
	display: inline-flex; align-items: center; justify-content: center;
	background: var(--color-primary); color: #fff;
	padding: 1rem 1.75rem; min-height: 44px;
	font-weight: 600; font-size: 1rem; text-decoration: none;
	border: none; border-radius: var(--radius);
	transition: background 0.15s ease;
}
.dx-btn-primary:hover { background: var(--color-primary-dark); color: #fff; }
.dx-btn-lg { padding: 1.125rem 2.25rem; font-size: 1.0625rem; }

/* Pains */
.dx-pains { background: var(--color-bg); }
.dx-pain-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
.dx-pain-card {
	background: var(--glass-bg);
	backdrop-filter: var(--glass-blur);
	-webkit-backdrop-filter: var(--glass-blur);
	border: 1px solid var(--glass-border);
	border-radius: var(--radius-card);
	box-shadow: var(--glass-shadow);
	padding: 1.75rem;
}
.dx-pain-card h3 { font-size: 1rem; font-weight: 600; color: var(--color-text); margin: 0 0 0.625rem; line-height: 1.55; }
.dx-pain-card p { font-size: 0.875rem; color: var(--color-text-muted); margin: 0; line-height: 1.75; }

/* What */
.dx-what {
	background:
		radial-gradient(720px 420px at 100% 100%, rgba(59,130,246,0.07), transparent 60%),
		linear-gradient(180deg, #F3F5FB 0%, #EEF2F9 100%);
	border-top: 1px solid var(--color-border);
	border-bottom: 1px solid var(--color-border);
}
.dx-what h2 {
	font-size: clamp(1.5rem, 3.5vw, 2.5rem); font-weight: 500;
	line-height: 1.25; letter-spacing: -0.02em; margin: 0 0 1rem; color: var(--color-text);
}
.dx-what-lead { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.85; max-width: 560px; margin: 0 0 2.5rem; }
.dx-cat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
.dx-cat-card {
	display: flex; align-items: center; gap: 1rem;
	background: var(--glass-bg);
	backdrop-filter: var(--glass-blur);
	-webkit-backdrop-filter: var(--glass-blur);
	border: 1px solid var(--glass-border);
	border-radius: var(--radius);
	padding: 1.125rem 1.25rem;
}
.dx-cat-num { font-size: 1.375rem; font-weight: 500; color: var(--color-primary); opacity: 0.35; letter-spacing: -0.03em; }
.dx-cat-name { font-size: 0.875rem; font-weight: 600; color: var(--color-text); line-height: 1.5; }

/* Trust */
.dx-trust { background: var(--color-bg); }
.dx-trust-inner { display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: center; }
.dx-trust h2 {
	font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 500;
	line-height: 1.3; letter-spacing: -0.02em; margin: 0 0 1.25rem; color: var(--color-text);
}
.dx-trust p { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.85; margin: 0 0 1.5rem; }
.dx-trust-link { font-size: 0.875rem; font-weight: 600; color: var(--color-primary); text-decoration: none; }
.dx-trust-link:hover { text-decoration: underline; }
.dx-trust-stats { display: flex; flex-direction: column; gap: 0.75rem; }
.dx-stat {
	background: var(--glass-bg);
	border: 1px solid var(--glass-border);
	border-radius: var(--radius);
	padding: 1.25rem 1.5rem;
	display: flex; align-items: baseline; gap: 1rem;
}
.dx-stat-num { font-size: 1.875rem; font-weight: 500; color: var(--color-primary); letter-spacing: -0.02em; }
.dx-stat-unit { font-size: 0.9375rem; margin-left: 0.125rem; }
.dx-stat-label { font-size: 0.8125rem; color: var(--color-text-muted); }

/* CTA */
.dx-cta {
	background:
		radial-gradient(700px 380px at 85% 0%, rgba(167,139,250,0.28), transparent 60%),
		linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%);
	text-align: center;
}
.dx-cta h2 {
	color: #fff; font-size: clamp(1.5rem, 3.5vw, 2.5rem); font-weight: 500;
	letter-spacing: -0.02em; margin: 0 0 0.875rem;
}
.dx-cta p { color: rgba(255,255,255,0.7); font-size: 0.9375rem; margin: 0 0 2rem; }
.dx-cta .dx-btn-primary { background: #fff; color: var(--color-primary); }
.dx-cta .dx-btn-primary:hover { background: #F5F5F4; }

/* Responsive */
@media (max-width: 900px) {
	.dx-pain-grid, .dx-cat-grid { grid-template-columns: 1fr; }
	.dx-trust-inner { grid-template-columns: 1fr; gap: 2.5rem; }
}
</style>
