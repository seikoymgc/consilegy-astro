						<div class="rdff-sot">Kintone</div>
					</div>
					<div class="rdff-arrow">→</div>
					<div class="rdff-stage">
						<div class="rdff-box box-invoice">請求<br /><small>Invoice</small></div>
						<div class="rdff-sot">会計</div>
					</div>
					<div class="rdff-arrow">→</div>
					<div class="rdff-stage">
						<div class="rdff-box box-renewal">更新<br /><small>Renewal</small></div>
						<div class="rdff-sot">Salesforce</div>
