---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const cases = (await getCollection('caseStudies'))
	.filter((c) => c.data.lang === 'ja' && !c.data.draft)
	.slice(0, 3);

const insightsPosts = [
	{
		slug: 'why-good-marketing-does-not-create-repeatable-growth',
		title: 'なぜ「良い施策」を打っているのに、組織が再現性を持てないのか',
		description: '優秀な施策や営業人材がいるのに成長が再現しない原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
		category: 'レベニューアーキテクチャ',
	},
	{
		slug: 'why-dashboards-do-not-improve-executive-decisions',
		title: 'ダッシュボードを作っても意思決定が速くならない理由',
		description: 'BIやダッシュボードを整備しても経営判断が速くならない原因を、KPI設計・Revenue Architecture・RevOpsの観点から解説します。',
		category: 'KPI・BI',
	},
	{
		slug: 'why-marketing-automation-does-not-improve-pipeline',
		title: 'MAを導入しても商談化率が改善しない理由',
		description: 'HubSpotやMarketoなどのMAを導入しても商談化率が改善しない原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
		category: 'CRM',
	},
];
---

<BaseLayout
	title="Consilegy | CRM・SFA・MAを売上が見える経営基盤へ"
	description="Salesforce・HubSpot・Kintone・Marketoが混在する収益オペレーションをベンダーフリーの立場から再設計。RevOps・Revenue Architecture設計からCRM実装・定着支援まで、売上が見える仕組みをつくります。"
	lang="ja"
>
	<link
		rel="preload"
		as="image"
		href="/images/common/hero-visual.webp"
		type="image/webp"
		fetchpriority="high"
		slot="head"
	/>
	<script slot="head">
		if (window.location.pathname === '/' || window.location.pathname === '') {
			const pref = localStorage.getItem('languagePreference');
			if (!pref) {
				const lang = navigator.language || 'ja';
				if (!lang.toLowerCase().startsWith('ja')) {
					window.location.replace('/en/');
				}
			}
		}
	</script>

<!-- ===================== HERO ===================== -->
<section class="hero">
	<div class="hero-bg" aria-hidden="true">
		<div class="hero-orb hero-orb--1"></div>
		<div class="hero-orb hero-orb--2"></div>
		<div class="hero-grid"></div>
	</div>
	<div class="container hero-inner">
		<div class="hero-copy">
			<h1>
				CRM・SFA・MAを、<br />
				<span class="hero-accent">売上が見える収益基盤へ。</span>
			</h1>
			<p class="hero-sub">
				Revenue Architectureで、<br />
				営業・マーケ・CSを一つの収益プロセスへ設計。
			</p>
			<p class="hero-lead">
				Salesforce、HubSpot、kintone、Marketoなど既存ツールを前提に、
				売上につながる仕組みへ再構築します。
			</p>
			<div class="hero-actions">
				<a href="/contact/" class="btn btn--hero-primary btn--lg">
					お問い合わせ →
				</a>
				<a href="/download/" class="btn btn--hero-outline btn--lg">
					資料ダウンロード
				</a>
			</div>
		</div>

	</div>
	<div class="hero-tools">
		<div class="container">
			<p class="tools-label">対応ツール（一部）</p>
			<div class="tools-row">
				<span>Salesforce</span><span class="tools-sep">|</span>
				<span>HubSpot</span><span class="tools-sep">|</span>
				<span>Kintone</span><span class="tools-sep">|</span>
				<span>Marketo</span><span class="tools-sep">|</span>
				<span>ServiceNow</span><span class="tools-sep">|</span>
				<span>Zoho CRM</span><span class="tools-sep">|</span>
				<span>Tableau / Looker</span>
			</div>
		</div>
	</div>
</section>

<!-- ===================== WHY ===================== -->
<section class="why">
	<div class="container">
		<div class="why-grid">
			<div class="why-head">
				<p class="section-eyebrow">Why It Fails</p>
				<h2>CRMが機能しない理由は<br />ツールではなく、<span class="text-primary">設計にあります</span></h2>
				<p class="section-lead">
					多くの企業がCRM / SFA / MAを導入しても成果に繋がらない原因は、
					ツールの問題ではありません。営業プロセス・データ構造・組織設計が
					ツール導入の前後で整理されていないことにあります。
				</p>
				<p class="section-lead" style="margin-top: 1rem;">
					Consilegyは部分最適ではなく、収益プロセス全体を設計し直すアプローチで支援します。
				</p>
			</div>
			<div class="why-problems">
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>リードはあるが、商談化しない</h4>
						<p>マーケと営業の定義・ハンドオフ・KPIが揃っていないため、リードが積み上がるだけで商談に繋がらない。</p>
					</div>
				</div>
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>営業とマーケティングの定義が揃っていない</h4>
						<p>「有望なリード」の基準が部門ごとに異なり、データの意味が統一されていない状態が続く。</p>
					</div>
				</div>
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>SFAに入力されない、データが信頼できない</h4>
						<p>設計が現場に合っておらず、正しく入力されないまま運用が続き、レポートが形骸化する。</p>
					</div>
				</div>
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>レポートが経営判断に使えない</h4>
						<p>ツールからデータは出るが、数字の定義・粒度・タイミングがバラバラで意思決定に活用できない。</p>
					</div>
				</div>
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>部門ごとに顧客データが分断されている</h4>
						<p>営業・マーケ・CS・基幹システムで顧客情報が別々に管理され、全体像が見えない。</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ===================== HOW ===================== -->
<section class="how">
	<div class="container">
		<div class="how-grid">
			<div class="how-visual">
				<div class="flow-diagram">
					<div class="flow-step flow-step--top">
						<span class="flow-label">マーケティング</span>
						<div class="flow-tools">MA / CDP</div>
					</div>
					<div class="flow-arrow">↓</div>
					<div class="flow-center">
						<span class="flow-center-label">収益プロセス設計</span>
						<span class="flow-center-sub">Revenue Architecture</span>
					</div>
					<div class="flow-arrow">↓</div>
					<div class="flow-step flow-step--mid">
						<span class="flow-label">営業・インサイドセールス</span>
						<div class="flow-tools">CRM / SFA</div>
					</div>
					<div class="flow-arrow">↓</div>
					<div class="flow-step flow-step--bot">
						<span class="flow-label">カスタマーサクセス</span>
						<div class="flow-tools">CS / BI / データ基盤</div>
					</div>
					<div class="flow-kpi">
						<span>KPI・ダッシュボード</span>
						<span class="flow-kpi-arrow">←</span>
						<span>経営判断に使えるデータへ</span>
					</div>
				</div>
			</div>
			<div class="how-copy">
				<p class="section-eyebrow">Our Approach</p>
				<h2>RevOps再設計 ＆<br /><span class="text-primary">レベニューアーキテクチャ</span></h2>
				<p class="section-lead">
					Consilegyの支援の中心は「ツール導入」ではなく、
					収益プロセス全体の再設計です。
					CRM / SFA / MAを点として改善するのではなく、
					営業・マーケ・CSがひとつのプロセスとして機能するよう、
					データモデル・組織設計・KPIを一体で整えます。
				</p>
				<ul class="how-points">
					<li>
						<span class="how-num">01</span>
						<div>
							<strong>ベンダーフリー</strong>
							<p>特定ツールの代理店ではないため、事業構造に合った中立的な設計を提案します。</p>
						</div>
					</li>
					<li>
						<span class="how-num">02</span>
						<div>
							<strong>プロセス設計から実装・定着まで</strong>
							<p>To-Be設計だけでなく、現場に落とし込む運用ルールと伴走支援まで一貫して対応します。</p>
						</div>
					</li>
					<li>
						<span class="how-num">03</span>
						<div>
							<strong>複数ツール横断の統合設計</strong>
							<p>Salesforce・HubSpot・Kintone・Marketoなどが混在する環境でもマルチCRM統合を設計します。</p>
						</div>
					</li>
				</ul>
				<a href="/revenue-architecture/" class="btn btn--outline-primary">
					レベニューアーキテクチャとは →
				</a>
			</div>
		</div>
	</div>
</section>

<!-- ===================== SERVICES ===================== -->
<section class="services-overview">
	<div class="container">
		<header class="section-head">
			<p class="section-eyebrow">Service Packages</p>
			<h2>提供サービス</h2>
			<p class="section-lead">
				現状把握から再設計、定着まで。課題のフェーズに合わせて選べる3つのステップを用意しています。
			</p>
		</header>

		<div class="svc-grid">

			<!-- Step 01: 診断 -->
			<article class="svc-card">
				<div class="svc-card__head">
					<span class="svc-step">Step 01</span>
					<h3>CRM / RevOps 診断</h3>
					<p class="svc-price-range">¥100,000〜500,000</p>
				</div>
				<p class="svc-desc">
					現状のCRM / SFA / MA運用・データ構造を診断し、
					ボトルネックの根拠と改善ロードマップを提示します。
					まず状況を把握したい企業向けの入口商品です。
				</p>
				<ul class="svc-items">
					<li>現状ヒアリングと課題仮説の整理</li>
					<li>CRM / MA運用・データ構造のフルレビュー</li>
					<li>ボトルネック分析と改善ロードマップ</li>
				</ul>
				<div class="svc-plans">
					<div class="svc-plan">
						<span class="svc-plan__name">簡易診断</span>
						<span class="svc-plan__price">¥100,000〜150,000</span>
					</div>
					<div class="svc-plan">
						<span class="svc-plan__name">詳細診断</span>
						<span class="svc-plan__price">¥300,000〜500,000</span>
					</div>
				</div>
				<a href="/pricing/#diagnosis" class="btn btn--primary svc-cta">詳しく見る →</a>
			</article>

			<!-- Step 02: 再設計 -->
			<article class="svc-card">
				<div class="svc-card__head">
					<span class="svc-step">Step 02</span>
					<h3>マルチCRM再設計プロジェクト</h3>
					<p class="svc-price-range">¥3,000,000〜8,000,000</p>
				</div>
				<p class="svc-desc">
					Salesforce / HubSpot / Kintone / Marketoなど複数ツールが混在する
					収益オペレーションを、ベンダー中立の立場で設計し直す中核プロジェクト。
				</p>
				<ul class="svc-items">
					<li>営業プロセス / データモデル再設計</li>
					<li>CRM / SFA / MA統合・移行設計</li>
					<li>KPI / ダッシュボード基盤の再構築</li>
					<li>実装ベンダー選定支援（中立）</li>
				</ul>
				<a href="/pricing/#project" class="btn btn--primary svc-cta">プロジェクトを相談する →</a>
			</article>

			<!-- Step 03: 伴走 -->
			<article class="svc-card">
				<div class="svc-card__head">
					<span class="svc-step">Step 03</span>
					<h3>伴走・顧問支援</h3>
					<p class="svc-price-range">月額 ¥300,000〜1,000,000</p>
				</div>
				<p class="svc-desc">
					再設計後の定着から内製化まで、月次で並走します。
					関与度に応じてライト・スタンダード・フルの3プランから選択可能。
				</p>
				<ul class="svc-items">
					<li>月次定例会・KPIレビュー</li>
					<li>施策の優先順位付けと改善支援</li>
					<li>部門間調整・RevOps内製化支援</li>
				</ul>
				<div class="svc-plans">
					<div class="svc-plan">
						<span class="svc-plan__name">ライト</span>
						<span class="svc-plan__price">月 ¥300,000〜400,000</span>
					</div>
					<div class="svc-plan">
						<span class="svc-plan__name">スタンダード</span>
						<span class="svc-plan__price">月 ¥500,000〜800,000</span>
					</div>
					<div class="svc-plan">
						<span class="svc-plan__name">フル</span>
						<span class="svc-plan__price">月 ¥800,000〜1,000,000</span>
					</div>
				</div>
				<a href="/pricing/#support" class="btn btn--primary svc-cta">詳しく見る →</a>
			</article>

		</div>

		<div class="svc-footer">
			<a class="btn btn--secondary" href="/services/">サービス一覧を見る</a>
			<a class="btn btn--secondary" href="/pricing/">パッケージ料金を見る</a>
		</div>
	</div>
</section>

<!-- ===================== CASE STUDIES ===================== -->
{cases.length > 0 && (
<section class="cases">
	<div class="container">
		<header class="section-head">
			<p class="section-eyebrow">Case Studies</p>
			<h2>導入事例</h2>
			<p class="section-lead">
				製造・SaaS・サービス業など、複数のB2B事業会社にて
				収益プロセスの再設計と定着を支援してきました。
			</p>
		</header>
		<div class="cases-grid">
			{cases.map((c) => (
				<article class="case-card">
					{c.data.featuredImage && (
						<div class="case-img">
							<img src={c.data.featuredImage} alt={c.data.featuredImageAlt || c.data.title} loading="lazy" />
						</div>
					)}
					<div class="case-body">
						{c.data.industry && <p class="case-tag">{c.data.industry}</p>}
						<h3 class="case-title">{c.data.title}</h3>
						{c.data.description && <p class="case-desc">{c.data.description.slice(0, 90)}...</p>}
						<a href={`/case-studies/${c.data.slug}/`} class="case-link">詳しく見る →</a>
					</div>
				</article>
			))}
		</div>
		<p style="margin-top: var(--space-lg); text-align: center;">
			<a class="btn btn--secondary" href="/case-studies/">事例一覧へ</a>
		</p>
	</div>
</section>
)}

<!-- ===================== BLOG ===================== -->
<section class="blog-section">
	<div class="container">
		<header class="section-head">
			<p class="section-eyebrow">Insights</p>
			<h2>最新コラム</h2>
			<p class="section-lead">RevOps・CRM運用・データ活用に関するナレッジを公開しています。</p>
		</header>
		<div class="blog-grid">
			{insightsPosts.map((post) => (
				<article class="blog-card">
					<a href={`/insights/${post.slug}/`} class="blog-card__link">
						<div class="blog-img">
							<img
								src={`/images/insights/${post.slug}.svg`}
								alt={post.category}
								loading="lazy"
								width="1200"
								height="630"
								class="blog-img__asset"
							/>
							<span class="blog-cat-overlay">{post.category}</span>
							<span class="blog-new">新着</span>
						</div>
						<div class="blog-body">
							<h3 class="blog-title">{post.title}</h3>
							<p class="blog-desc">{post.description}</p>
							<div class="blog-foot">
								<span class="blog-arrow" aria-hidden="true">→</span>
							</div>
						</div>
					</a>
				</article>
			))}
		</div>
		<p style="margin-top: var(--space-lg); text-align: center;">
			<a class="btn btn--secondary" href="/insights/">コラム一覧へ</a>
		</p>
	</div>
</section>

<!-- ===================== NEWSLETTER CTA ===================== -->
<section class="nl-cta-strip">
	<div class="container nl-cta-strip__inner">
		<div class="nl-cta-strip__copy">
			<p class="nl-cta-strip__eyebrow">Newsletter</p>
			<h2>次世代B2Bレベニュー戦略バイブル</h2>
			<p>Revenue Architecture・RevOps・CRM実装の実践知を毎月配信。約2,000人が購読中。</p>
		</div>
		<a href="/newsletter/#signup" class="btn nl-cta-strip__btn">
			無料で登録する →
		</a>
	</div>
</section>

<!-- ===================== FINAL CTA ===================== -->
<section class="final-cta">
	<div class="container cta-inner">
		<div class="cta-copy">
			<p class="cta-eyebrow">Get Started</p>
			<h2>まずは30分無料相談から<br />はじめましょう</h2>
			<p class="cta-lead">
				初回ご相談は無料。現状のシステム構成・営業プロセス・組織体制を
				ヒアリングし、改善余地と優先順位を明確にします。
			</p>
			<div class="cta-actions">
				<a href="/free-consultation/" class="btn btn--cta-primary btn--lg">
					30分無料相談を申し込む →
				</a>
				<a href="/download/" class="btn btn--cta-outline btn--lg">
					サービス資料をダウンロード
				</a>
			</div>
		</div>
		<div class="cta-checklist">
			<h4>ご相談時にお伺いする内容</h4>
			<ul>
				<li>現在ご利用中のCRM / SFA / MAツール構成</li>
				<li>事業部・組織体制（規模・部門数）</li>
				<li>現状の課題・優先度の高いテーマ</li>
				<li>想定スケジュールと社内ステークホルダー</li>
				<li>過去の導入・移行プロジェクトの経緯</li>
			</ul>
		</div>
	</div>
</section>

</BaseLayout>

<style>
/* ── Shared ──────────────────────────────────────────── */
.container { max-width: 1160px; margin-inline: auto; padding-inline: 2rem; }
section { padding-block: var(--space-2xl); }
.section-head { max-width: 640px; margin-bottom: var(--space-xl); }
.section-eyebrow {
	display: block; font-size: 0.5625rem; font-weight: 500; color: var(--color-text-muted);
	letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 1.25rem;
	padding-top: 0.875rem; border-top: 1.5px solid var(--color-border);
}
/* Editorial: section headings at display scale */
.section-head h2 {
	font-size: clamp(2rem, 3.5vw, 3.25rem); font-weight: 500;
	line-height: 1.1; letter-spacing: -0.02em; color: var(--color-text);
	margin: 0 0 1.25rem;
}
.section-lead { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.8; margin: 0; }
.text-primary { color: var(--color-primary); }
.btn--lg { padding: 0.875rem 1.75rem; font-size: 0.9375rem; }

/* ── Hero ──────────────────────────────────────────── */
.hero {
	position: relative; overflow: hidden;
	background-image: url('/images/common/hero-visual-720.webp');
	background-size: cover;
	background-position: center;
	background-repeat: no-repeat;
	border-bottom: 1px solid var(--color-border);
	padding-block: 0;
}
@media (min-width: 769px) {
	.hero { background-image: url('/images/common/hero-visual.webp'); }
}
/* Glass: gradient orbs floating over the hero visual */
.hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
.hero-orb { position: absolute; border-radius: 50%; filter: blur(90px); }
.hero-orb--1 {
	width: 560px; height: 560px; top: -180px; right: -120px;
	background: radial-gradient(circle, rgba(96,165,250,0.4) 0%, transparent 70%);
}
.hero-orb--2 {
	width: 440px; height: 440px; bottom: -140px; left: -100px;
	background: radial-gradient(circle, rgba(167,139,250,0.32) 0%, transparent 70%);
}
.hero-grid { display: none; }

.hero-inner {
	position: relative; z-index: 1;
	padding-block: 6rem 4rem;
}
.hero-copy { max-width: 600px; }

.hero-eyebrow {
	display: inline-flex; align-items: center; gap: 0.5rem;
	font-size: 0.625rem; font-weight: 500; color: #fff;
	background: rgba(255,255,255,0.12); padding: 0.375rem 0.875rem;
	letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1.5rem;
}
.eyebrow-dot { width: 4px; height: 4px; background: #fff; display: inline-block; }

.hero-copy h1 {
	font-size: clamp(2.5rem, 5vw, 4.75rem); font-weight: 500;
	line-height: 1.05; letter-spacing: -0.03em; color: #fff;
	margin: 0 0 1.75rem;
}
.hero-accent { color: #fff; display: block; }

.hero-sub {
	font-size: 1.0625rem; font-weight: 400; line-height: 1.7; color: rgba(255,255,255,0.88);
	margin: 0 0 0.875rem;
}

.hero-lead {
	font-size: 0.9375rem; line-height: 1.85; color: rgba(255,255,255,0.6);
	max-width: 560px; margin: 0 0 2.5rem;
}

.hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

.btn--hero-primary {
	display: inline-flex; align-items: center;
	background: #fff; color: #1C1917;
	padding: 0.875rem 1.5rem;
	font-weight: 500; font-size: 0.9375rem; text-decoration: none; border: none;
	transition: background 0.15s ease; white-space: nowrap;
}
.btn--hero-primary:hover { background: #F5F5F4; color: #1C1917; }

.btn--hero-outline {
	display: inline-flex; align-items: center;
	background: transparent; color: #fff;
	padding: 0.875rem 1.5rem;
	font-weight: 400; font-size: 0.9375rem; text-decoration: none;
	border: 1px solid rgba(255,255,255,0.5);
	transition: all 0.15s ease; white-space: nowrap;
}
.btn--hero-outline:hover { background: rgba(255,255,255,0.07); border-color: rgba(255,255,255,0.8); }

/* Stats */
.hero-stats { display: flex; flex-direction: column; gap: 1rem; }
.stat-card {
	background: var(--color-bg); border: 1px solid var(--color-border);
	padding: 1.5rem 1.75rem;
}
.stat-card--accent { border-color: var(--color-primary); }
.stat-num {
	font-size: 2rem; font-weight: 500; color: var(--color-primary);
	letter-spacing: -0.03em; line-height: 1; margin-bottom: 0.5rem;
}
.stat-unit { font-size: 1rem; font-weight: 400; margin-left: 0.25rem; }
.stat-label { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.5; }

/* Tools ribbon */
.hero-tools {
	position: relative; z-index: 1;
	border-top: 1px solid rgba(255,255,255,0.18);
	padding: 1rem 0; background: rgba(28,25,23,0.3);
	backdrop-filter: blur(14px) saturate(1.3);
	-webkit-backdrop-filter: blur(14px) saturate(1.3);
}
.tools-label {
	font-size: 0.5625rem; font-weight: 500; color: rgba(255,255,255,0.45);
	text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 0.5rem;
}
.tools-row {
	display: flex; flex-wrap: wrap; align-items: center; gap: 0.25rem 0.625rem;
	font-size: 0.75rem; color: rgba(255,255,255,0.55); font-weight: 400;
}
.tools-sep { color: rgba(255,255,255,0.2); }

/* ── Why ──────────────────────────────────────────── */
.why {
	background:
		radial-gradient(900px 480px at 88% 0%, rgba(124,92,191,0.08), transparent 60%),
		radial-gradient(720px 420px at 0% 100%, rgba(59,130,246,0.09), transparent 60%),
		linear-gradient(180deg, #F7F8FC 0%, #EFF2F9 100%);
	border-top: 1px solid var(--color-border);
	border-bottom: 1px solid var(--color-border);
}
.why-grid {
	display: grid; grid-template-columns: 1fr 1.1fr; gap: 5rem; align-items: start;
}
.why-head h2 {
	font-size: clamp(2rem, 3.5vw, 3.5rem); font-weight: 500;
	line-height: 1.1; letter-spacing: -0.02em; color: var(--color-text);
	margin: 0 0 1.75rem;
}

.why-problems { display: flex; flex-direction: column; gap: 0.625rem; }
.problem-item {
	display: flex; gap: 1.25rem; align-items: flex-start;
	background: var(--glass-bg);
	backdrop-filter: var(--glass-blur);
	-webkit-backdrop-filter: var(--glass-blur);
	border: 1px solid var(--glass-border);
	border-radius: var(--radius-card);
	box-shadow: var(--glass-shadow);
	padding: 1.25rem 1.5rem;
	transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}
.problem-item:hover {
	transform: translateY(-2px);
	background: var(--glass-bg-strong);
	box-shadow: var(--glass-shadow-hover);
}
.problem-icon {
	flex-shrink: 0; width: 28px; height: 28px;
	background: rgba(30,64,175,0.08); color: var(--color-primary);
	display: inline-flex; align-items: center; justify-content: center;
	font-weight: 400; font-size: 0.875rem; margin-top: 2px;
}
.problem-item h4 { margin: 0 0 0.25rem; font-size: 0.9375rem; font-weight: 500; color: var(--color-text); }
.problem-item p { margin: 0; font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.7; }

/* ── How ──────────────────────────────────────────── */
.how {
	background:
		radial-gradient(800px 460px at 0% 10%, rgba(59,130,246,0.06), transparent 60%),
		linear-gradient(180deg, var(--color-bg) 0%, #F4F6FB 100%);
	border-top: 1px solid var(--color-border);
}
.how-grid {
	display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center;
}
.how-copy h2 {
	font-size: clamp(2rem, 3.5vw, 3.5rem); font-weight: 500;
	line-height: 1.1; letter-spacing: -0.02em; color: var(--color-text);
	margin: 0 0 1.75rem;
}

/* Flow diagram */
.flow-diagram {
	background: var(--glass-bg);
	backdrop-filter: var(--glass-blur);
	-webkit-backdrop-filter: var(--glass-blur);
	border: 1px solid var(--glass-border);
	border-radius: var(--radius-card);
	box-shadow: var(--glass-shadow);
	padding: 2rem;
	display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
}
.flow-step {
	width: 100%;
	background: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.7);
	border-radius: var(--radius);
	padding: 0.875rem 1.25rem;
	display: flex; flex-direction: column; align-items: flex-start; gap: 0.25rem;
}
.flow-step--top { background: rgba(59,130,246,0.09); border-color: rgba(96,165,250,0.3); }
.flow-step--mid { background: rgba(59,130,246,0.06); border-color: rgba(96,165,250,0.22); }
.flow-step--bot { background: rgba(124,92,191,0.07); border-color: rgba(167,139,250,0.25); }
.flow-label { font-size: 0.625rem; font-weight: 500; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.08em; }
.flow-tools { font-size: 0.8125rem; font-weight: 500; color: var(--color-text); }
.flow-arrow { font-size: 1rem; color: var(--color-primary); opacity: 0.35; line-height: 1; }
.flow-center {
	width: 100%;
	background: linear-gradient(135deg, rgba(30,64,175,0.92), rgba(29,78,216,0.88));
	backdrop-filter: blur(8px);
	-webkit-backdrop-filter: blur(8px);
	border-radius: var(--radius);
	box-shadow: 0 8px 24px rgba(30,64,175,0.25);
	padding: 1rem 1.25rem; text-align: center;
	display: flex; flex-direction: column; gap: 0.25rem;
}
.flow-center-label { font-size: 0.8125rem; font-weight: 500; color: #fff; }
.flow-center-sub { font-size: 0.6875rem; color: rgba(255,255,255,0.6); }
.flow-kpi {
	margin-top: 0.25rem; width: 100%;
	display: flex; align-items: center; gap: 0.5rem;
	font-size: 0.6875rem; color: var(--color-text-muted);
	background: rgba(255,255,255,0.45); padding: 0.625rem 1rem;
	border: 1px solid rgba(255,255,255,0.65);
	border-radius: var(--radius);
}
.flow-kpi-arrow { color: var(--color-primary); font-weight: 500; }

.how-points { list-style: none; padding: 0; margin: 1.75rem 0 2rem; display: flex; flex-direction: column; gap: 2rem; }
.how-points li { display: flex; gap: 1.5rem; align-items: flex-start; }
/* Editorial: ghosted large number as visual anchor */
.how-num {
	flex-shrink: 0; min-width: 3rem;
	color: var(--color-primary); opacity: 0.18;
	display: inline-flex; align-items: flex-start; justify-content: flex-end;
	font-size: 3rem; font-weight: 500; letter-spacing: -0.05em;
	line-height: 0.85; margin-top: 0.125rem; border: none;
}
.how-points strong { display: block; font-size: 0.9375rem; font-weight: 500; color: var(--color-text); margin-bottom: 0.25rem; }
.how-points p { margin: 0; font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.75; }

.btn--outline-primary {
	display: inline-flex; align-items: center;
	background: transparent; color: var(--color-primary);
	padding: 0.75rem 1.25rem;
	font-weight: 500; font-size: 0.875rem; text-decoration: none;
	border: 1px solid var(--color-primary);
	transition: all 0.15s ease;
}
.btn--outline-primary:hover { background: rgba(30,64,175,0.05); }

/* ── Services Overview ─────────────────────────────── */
.services-overview {
	background:
		radial-gradient(880px 500px at 100% 100%, rgba(124,92,191,0.07), transparent 60%),
		radial-gradient(700px 420px at 0% 0%, rgba(59,130,246,0.08), transparent 55%),
		linear-gradient(180deg, #F2F5FB 0%, #EDF1F9 100%);
	border-top: 1px solid var(--color-border);
}
.svc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

.svc-card {
	background: var(--glass-bg);
	backdrop-filter: var(--glass-blur);
	-webkit-backdrop-filter: var(--glass-blur);
	border: 1px solid var(--glass-border);
	border-radius: var(--radius-card);
	box-shadow: var(--glass-shadow);
	padding: 2.5rem;
	display: flex; flex-direction: column; position: relative;
	transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}
.svc-card:hover {
	transform: translateY(-3px);
	background: var(--glass-bg-strong);
	box-shadow: var(--glass-shadow-hover);
}
.svc-card--featured {
	background: linear-gradient(145deg, #1e40af 0%, #1d4ed8 55%, #7c5cbf 100%);
	border-color: transparent;
	box-shadow: 0 8px 32px rgba(30,64,175,0.2);
}

.svc-badge {
	position: absolute; top: -13px; left: 1.5rem;
	background: rgba(255,255,255,0.85); color: var(--color-primary);
	backdrop-filter: blur(8px);
	-webkit-backdrop-filter: blur(8px);
	border: 1px solid var(--color-primary);
	border-radius: 100px;
	font-size: 0.625rem; font-weight: 500;
	padding: 0.3rem 0.8rem;
}
.svc-card--featured .svc-badge {
	background: var(--color-primary); color: #fff; border-color: transparent;
}

.svc-card__head { margin-bottom: 1.25rem; }
/* Editorial: step label with top rule, like a magazine section header */
.svc-step {
	display: block; font-size: 0.5625rem; font-weight: 500;
	color: var(--color-text-muted); background: none; padding: 0;
	border-top: 1.5px solid var(--color-border); padding-top: 0.75rem;
	letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 1rem;
}
.svc-step--light { color: rgba(255,255,255,0.45); border-color: rgba(255,255,255,0.18); }
.svc-card h3 { margin: 0 0 0.5rem; font-size: 1.0625rem; font-weight: 400; color: var(--color-text); }
.svc-card--featured h3 { color: #fff; }
.svc-price-range { margin: 0; font-size: 1rem; font-weight: 500; color: var(--color-primary); }
.svc-price-range--light { color: rgba(255,255,255,0.88); }

.svc-desc { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.8; margin: 0 0 1.5rem; flex: 1; }
.svc-desc--light { color: rgba(255,255,255,0.75); }

.svc-items { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
.svc-items li {
	font-size: 0.8125rem; color: var(--color-text); padding-left: 1.25rem; position: relative; line-height: 1.55;
}
.svc-items li::before { content: "—"; position: absolute; left: 0; color: var(--color-primary); font-weight: 400; }
.svc-items--light li { color: rgba(255,255,255,0.82); }
.svc-items--light li::before { color: rgba(255,255,255,0.35); }

.svc-plans {
	display: flex; flex-direction: column; gap: 0.375rem; margin-bottom: 1.5rem;
	padding: 0.875rem; background: rgba(255,255,255,0.45);
	border: 1px solid rgba(255,255,255,0.7);
	border-radius: var(--radius);
}
.svc-plan { display: flex; justify-content: space-between; align-items: center; }
.svc-plan__name { font-size: 0.75rem; color: var(--color-text-muted); font-weight: 400; }
.svc-plan__price { font-size: 0.75rem; color: var(--color-text); font-weight: 500; }

.svc-cta {
	display: inline-flex; align-items: center; justify-content: center;
	padding: 0.75rem 1.25rem;
	font-weight: 500; font-size: 0.875rem; text-decoration: none;
	transition: all 0.15s ease; width: 100%;
}

.btn--primary.svc-cta {
	background: var(--color-primary); color: #fff; border: none;
}
.btn--primary.svc-cta:hover { background: var(--color-primary-dark); }

.btn--white {
	background: #fff; color: var(--color-primary); border: none;
}
.btn--white:hover { background: var(--color-bg-subtle); color: var(--color-primary); }

.svc-footer { margin-top: var(--space-lg); display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap; }

/* ── Case Studies ──────────────────────────────────── */
.cases {
	background:
		radial-gradient(760px 440px at 90% 0%, rgba(59,130,246,0.06), transparent 60%),
		linear-gradient(180deg, var(--color-bg) 0%, #F5F7FC 100%);
	border-top: 1px solid var(--color-border);
}
.cases-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

.case-card {
	background: var(--glass-bg);
	backdrop-filter: var(--glass-blur);
	-webkit-backdrop-filter: var(--glass-blur);
	border: 1px solid var(--glass-border);
	border-radius: var(--radius-card);
	box-shadow: var(--glass-shadow);
	overflow: hidden;
	display: flex; flex-direction: column;
	transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}
.case-card:hover {
	transform: translateY(-3px);
	background: var(--glass-bg-strong);
	box-shadow: var(--glass-shadow-hover);
}
.case-img { aspect-ratio: 16/9; overflow: hidden; background: var(--color-bg-subtle); }
.case-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
.case-body { padding: 1.5rem; display: flex; flex-direction: column; flex: 1; }
.case-tag {
	font-size: 0.5625rem; font-weight: 500; color: var(--color-primary);
	text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 0.5rem;
}
.case-title { font-size: 0.9375rem; font-weight: 400; color: var(--color-text); line-height: 1.5; margin: 0 0 0.75rem; }
.case-desc { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.7; margin: 0 0 1rem; flex: 1; }
.case-link {
	font-size: 0.8125rem; font-weight: 500; color: var(--color-primary);
	text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem;
}
.case-link:hover { text-decoration: underline; }

/* ── Blog ──────────────────────────────────────────── */
.blog-section {
	background:
		radial-gradient(820px 480px at 5% 100%, rgba(124,92,191,0.07), transparent 60%),
		radial-gradient(700px 400px at 100% 0%, rgba(59,130,246,0.07), transparent 55%),
		linear-gradient(180deg, #F3F5FB 0%, #EEF2F9 100%);
	border-top: 1px solid var(--color-border);
	border-bottom: 1px solid var(--color-border);
}
.blog-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
/* Editorial: first card is a featured wide card */
@media (min-width: 769px) {
	.blog-card:first-child { grid-column: span 2; }
	.blog-card:first-child .blog-card__link { flex-direction: row; }
	.blog-card:first-child .blog-img { flex: 0 0 54%; aspect-ratio: unset; min-height: 220px; }
	.blog-card:first-child .blog-body { padding: 2rem; justify-content: center; }
	.blog-card:first-child .blog-title { font-size: 1.25rem; line-height: 1.4; }
	.blog-card:first-child .blog-desc { -webkit-line-clamp: 3; }
}
.blog-card {
	background: var(--glass-bg);
	backdrop-filter: var(--glass-blur);
	-webkit-backdrop-filter: var(--glass-blur);
	border: 1px solid var(--glass-border);
	border-radius: var(--radius-card);
	box-shadow: var(--glass-shadow);
	overflow: hidden;
	display: flex; flex-direction: column;
	transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}
.blog-card:hover {
	transform: translateY(-3px);
	background: var(--glass-bg-strong);
	box-shadow: var(--glass-shadow-hover);
}
.blog-card__link {
	display: flex; flex-direction: column;
	height: 100%; text-decoration: none; color: inherit;
}
.blog-img {
	position: relative;
	aspect-ratio: 1200 / 630;
	overflow: hidden;
	background: #1C1917;
	flex-shrink: 0;
}
.blog-img__asset {
	width: 100%; height: 100%;
	object-fit: cover; display: block;
	transition: transform .3s ease;
}
.blog-card:hover .blog-img__asset { transform: scale(1.02); }
.blog-new {
	position: absolute; top: 10px; right: 10px;
	font-size: .5625rem; font-weight: 500; letter-spacing: .08em;
	background: var(--color-primary); color: #fff; padding: 3px 8px;
}
.blog-cat-overlay {
	position: absolute; top: 10px; left: 10px;
	font-size: .6875rem; font-weight: 400; letter-spacing: .04em;
	background: rgba(28,25,23,0.6); color: #fff;
	padding: 3px 10px;
}
.blog-body {
	display: flex; flex-direction: column; gap: 0;
	padding: 1.25rem 1.5rem; flex-grow: 1;
}
.blog-title {
	margin: 0 0 0.5rem; font-size: .9375rem; font-weight: 400;
	line-height: 1.55; color: var(--color-text); flex-grow: 1;
}
.blog-card:hover .blog-title { color: var(--color-primary); }
.blog-desc {
	margin: 0 0 0.875rem; font-size: .8125rem; color: var(--color-text-muted); line-height: 1.75;
	display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
	overflow: hidden;
}
.blog-foot {
	display: flex; align-items: center; gap: 10px;
	padding-top: 0.75rem; border-top: 1px solid var(--color-border);
	margin-top: auto;
}
.blog-arrow {
	margin-left: auto; font-size: .8125rem; color: var(--color-primary);
	transition: transform .18s ease;
}
.blog-card:hover .blog-arrow { transform: translateX(4px); }

/* ── Newsletter CTA strip ──────────────────────────── */
.nl-cta-strip {
	background:
		radial-gradient(600px 300px at 80% 50%, rgba(96,165,250,0.12), transparent 65%),
		linear-gradient(135deg, #F5F7FD 0%, #EDF2FB 100%);
	border-top: 3px solid var(--color-primary);
	border-bottom: 1px solid var(--color-border);
	padding-block: 3rem;
}
.nl-cta-strip__inner {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 2rem;
	flex-wrap: wrap;
}
.nl-cta-strip__eyebrow {
	display: block; font-size: 0.5625rem; font-weight: 500; letter-spacing: 0.14em;
	text-transform: uppercase; color: var(--color-text-muted);
	margin: 0 0 0.875rem;
	border-top: 1.5px solid var(--color-border); padding-top: 0.75rem;
}
.nl-cta-strip__copy h2 {
	font-size: clamp(1.5rem, 2.5vw, 2.5rem); font-weight: 500;
	color: var(--color-text); margin: 0 0 0.5rem; line-height: 1.2; letter-spacing: -0.02em;
}
.nl-cta-strip__copy p {
	font-size: 0.875rem; color: var(--color-text-muted);
	margin: 0; line-height: 1.7;
}
.nl-cta-strip__btn {
	display: inline-flex; align-items: center; white-space: nowrap; flex-shrink: 0;
	background: var(--color-primary); color: #fff;
	padding: 0.75rem 1.5rem;
	font-weight: 500; font-size: 0.875rem; text-decoration: none;
	border: none; transition: background 0.15s;
}
.nl-cta-strip__btn:hover { background: var(--color-primary-dark); }
@media (max-width: 640px) {
	.nl-cta-strip__inner { flex-direction: column; align-items: flex-start; }
}

/* ── Final CTA ─────────────────────────────────────── */
.final-cta {
	background:
		radial-gradient(800px 400px at 85% -5%, rgba(167,139,250,0.35), transparent 60%),
		radial-gradient(600px 360px at 0% 100%, rgba(96,165,250,0.25), transparent 55%),
		linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%);
	color: #fff;
}
.cta-inner {
	display: grid; grid-template-columns: 1.2fr 1fr;
	gap: 4rem; align-items: center;
}
.cta-eyebrow {
	display: block; font-size: 0.5625rem; font-weight: 500; color: rgba(255,255,255,0.4);
	letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 1.25rem;
	border-top: 1px solid rgba(255,255,255,0.15); padding-top: 0.875rem;
}
.cta-copy h2 {
	color: #fff; font-size: clamp(2.5rem, 4.5vw, 5rem);
