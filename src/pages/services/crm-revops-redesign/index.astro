.hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.hero-tools { display: flex; flex-direction: column; gap: 0.625rem; }
.tools-label { font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-subtle); font-family: var(--font-sans); }
.tools-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.tool-pill {
	font-size: 0.75rem; font-weight: 600; font-family: var(--font-sans);
	color: var(--color-text-muted); background: var(--color-bg-subtle);
	border: 1px solid var(--color-border); padding: 0.25rem 0.75rem;
	border-radius: 4px;
}
.hero-keywords { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.kw-pill {
	font-size: 0.75rem; font-weight: 600; font-family: var(--font-sans);
	color: var(--color-text-muted); background: var(--color-bg-subtle);
	border: 1px solid var(--color-border); padding: 0.25rem 0.75rem;
	border-radius: 4px;
}

/* ── Symptoms ──────────────────────────────────────────── */
.symptoms { background: var(--color-bg-subtle); padding: 5rem 0; }
.symptoms-grid {
	display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.875rem; margin-bottom: 2rem;
}
.symptom-card {
	background: #fff; border: 1px solid var(--color-border); border-radius: 8px;
	padding: 1rem 1.125rem; font-size: 0.875rem; color: var(--color-text-muted);
	font-family: var(--font-sans); line-height: 1.55;
}
.symptom-card strong { color: var(--color-text); font-weight: 700; display: block; }
.symptoms-note {
	text-align: center; font-size: 0.9375rem; color: var(--color-text-muted);
	line-height: 1.85; font-family: var(--font-sans); margin: 0;
}

/* ── Root Cause ──────────────────────────────────────────── */
.root-cause { background: #fff; padding: 5rem 0; }
.root-cause-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
.root-cause-body { display: flex; flex-direction: column; gap: 1rem; padding-top: 0.25rem; }
.root-cause-body p { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.85; margin: 0; }
.root-cause-list {
	list-style: none; border-left: 3px solid var(--color-border);
	padding-left: 1.25rem; display: flex; flex-direction: column; gap: 0.625rem;
}
.root-cause-list li {
	font-size: 0.9375rem; color: var(--color-text); font-family: var(--font-sans);
	line-height: 1.6;
}
.root-cause-closing {
	font-family: var(--font-serif) !important; font-size: 1.0625rem !important;
	color: var(--color-text) !important; border-left: 3px solid var(--color-primary);
	padding-left: 1.25rem; margin-top: 0.5rem !important;
}

/* ── Definition ──────────────────────────────────────────── */
.definition { background: var(--color-bg-subtle); padding: 5rem 0; }
.definition-inner { max-width: 720px; }
.definition-inner h2 { font-size: 1.75rem; color: var(--color-text); margin-bottom: 1.5rem; }
.definition-body { font-size: 1.0625rem; color: var(--color-text-muted); line-height: 1.9; margin-bottom: 2rem; }
.definition-oneliner {
	font-family: var(--font-serif); font-size: 1.25rem; color: var(--color-text);
	line-height: 1.7; border-left: 3px solid var(--color-primary); padding-left: 1.25rem;
}

/* ── Problems ──────────────────────────────────────────── */
.problems { background: #fff; padding: 5rem 0; }
.problems-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; }
.problem-card {
	background: var(--color-bg-subtle); border: 1px solid var(--color-border);
	border-radius: 8px; padding: 1.5rem 1.25rem;
}
.problem-card__en {
	font-size: 0.625rem; font-weight: 700; letter-spacing: 0.1em;
	color: var(--color-primary); font-family: var(--font-sans);
	text-transform: uppercase; margin-bottom: 0.5rem;
}
.problem-card h3 { font-size: 1rem; color: var(--color-text); margin-bottom: 0.5rem; font-family: var(--font-serif); }
.problem-card p { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.7; margin: 0; }

/* ── Scope ──────────────────────────────────────────── */
.scope { background: var(--color-bg-subtle); padding: 5rem 0; }
.scope-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
.scope-card {
	background: #fff; border: 1px solid var(--color-border);
	border-radius: 8px; padding: 1.5rem 1.25rem;
}
.scope-card__label {
	font-size: 0.6875rem; font-weight: 700; color: var(--color-primary);
	font-family: var(--font-sans); margin-bottom: 0.25rem; letter-spacing: 0.02em;
}
.scope-card__ja {
	font-size: 0.9375rem; font-weight: 700; color: var(--color-text);
	font-family: var(--font-serif); margin-bottom: 0.5rem;
}
.scope-card p { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.7; margin: 0; }

/* ── Process ──────────────────────────────────────────── */
.process { background: #fff; padding: 5rem 0; }
.process-flow { display: flex; flex-wrap: wrap; align-items: flex-start; gap: 0; }
.pstep {
	flex: 1; min-width: 100px; background: var(--color-bg-subtle);
	border: 1px solid var(--color-border); border-radius: 8px;
	padding: 1.25rem 1rem; display: flex; flex-direction: column; gap: 0.5rem;
}
.pstep--last { border-color: var(--color-primary); }
.pstep__num { font-size: 1.25rem; font-weight: 700; color: var(--color-primary); font-family: var(--font-sans); line-height: 1; }
.pstep__body strong { font-size: 0.875rem; color: var(--color-text); display: block; margin-bottom: 0.25rem; font-family: var(--font-sans); }
.pstep__body p { font-size: 0.75rem; color: var(--color-text-muted); line-height: 1.65; margin: 0; }
.pstep-arrow { display: flex; align-items: center; padding: 0 0.25rem; color: var(--color-text-subtle); font-size: 1.125rem; flex-shrink: 0; margin-top: 1.25rem; }

/* ── Before / After ──────────────────────────────────────────── */
.ba-section { background: var(--color-bg-subtle); padding: 5rem 0; }
.ba-diagram {
	display: grid; grid-template-columns: 1fr auto 1fr;
	gap: 1.5rem; align-items: center;
	background: #fff; border: 1px solid var(--color-border);
	border-radius: 8px; padding: 2rem; margin-bottom: 1.5rem;
}
.ba-panel { display: flex; flex-direction: column; gap: 1rem; }
.ba-panel__label {
	font-size: 0.6875rem; font-weight: 700; letter-spacing: 0.12em;
	text-transform: uppercase; color: var(--color-text-subtle); font-family: var(--font-sans);
}
.ba-tools { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.ba-tool {
	font-size: 0.75rem; font-weight: 600; font-family: var(--font-sans);
	padding: 0.3rem 0.75rem; border-radius: 4px;
	background: var(--color-bg-subtle); border: 1px solid var(--color-border-strong);
	color: var(--color-text-muted);
}
.ba-tool--legacy { opacity: 0.6; border-style: dashed; }
.ba-problems { display: flex; flex-wrap: wrap; gap: 0.375rem; }
.ba-prob {
	font-size: 0.7rem; font-family: var(--font-sans);
	background: #fef2f2; border: 1px solid #fecaca;
	color: #dc2626; padding: 0.2rem 0.6rem; border-radius: 4px; font-weight: 600;
}
.ba-ra-node {
	font-size: 0.9375rem; font-weight: 700; color: #fff;
	background: var(--color-primary); border-radius: 8px;
	padding: 0.5rem 1rem; text-align: center; font-family: var(--font-sans);
	margin-bottom: 0.75rem;
}
.ba-results { display: flex; flex-wrap: wrap; gap: 0.375rem; }
.ba-result {
	font-size: 0.75rem; font-weight: 600; font-family: var(--font-sans);
	background: rgba(30,64,175,.08); border: 1px solid rgba(30,64,175,.25);
	color: var(--color-primary); padding: 0.25rem 0.75rem; border-radius: 4px;
}
.ba-status {
	font-size: 0.75rem; font-weight: 600; font-family: var(--font-sans);
	padding: 0.35rem 0.875rem; border-radius: 4px; align-self: flex-start;
}
.ba-status--bad { background: #fee2e2; color: #dc2626; }
.ba-status--good { background: #dcfce7; color: #16a34a; }
.ba-arrow {
	display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
}
.ba-arrow__line {
	width: 2px; height: 60px; background: var(--color-border-strong);
	position: relative;
}
.ba-arrow__line::after {
	content: '▼'; position: absolute; bottom: -14px; left: 50%;
	transform: translateX(-50%); color: var(--color-text-subtle); font-size: 0.875rem;
}
.ba-arrow__label {
	font-size: 0.625rem; font-weight: 700; letter-spacing: 0.08em;
	text-transform: uppercase; color: var(--color-primary); font-family: var(--font-sans);
	writing-mode: vertical-rl; text-orientation: mixed; white-space: nowrap; text-align: center;
}
.ba-notes { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
.ba-note {
	font-size: 0.875rem; font-weight: 700; color: var(--color-primary);
	font-family: var(--font-sans);
}

/* ── Deliverables ──────────────────────────────────────────── */
.deliverables { background: #fff; padding: 5rem 0; }
.deliverables-layout { display: grid; grid-template-columns: 1fr 320px; gap: 3rem; align-items: start; }
.deliverables-list { list-style: none; }
.deliverables-list li {
	display: flex; gap: 1.25rem; padding: 1rem 0;
	border-bottom: 1px solid var(--color-border);
}
.deliverables-list li:last-child { border-bottom: none; }
.deliv-num {
	font-size: 0.6875rem; font-weight: 700; color: var(--color-primary);
	letter-spacing: 0.04em; flex-shrink: 0; width: 2rem;
	text-align: right; margin-top: 0.2rem; font-family: var(--font-sans);
}
.deliverables-list strong { font-size: 0.9375rem; color: var(--color-text); display: block; margin-bottom: 0.2rem; font-family: var(--font-sans); }
.deliverables-list p { font-size: 0.8125rem; color: var(--color-text-muted); margin: 0; line-height: 1.65; }

/* Document Mockup */
.deliverables-mockup { display: flex; flex-direction: column; gap: 1rem; position: sticky; top: 2rem; }
.doc-mock {
	background: #fff; border: 1px solid var(--color-border);
	border-radius: 8px; overflow: hidden; box-shadow: var(--shadow-sm);
}
.doc-mock__header {
	background: var(--color-bg-subtle); border-bottom: 1px solid var(--color-border);
	padding: 0.75rem 1rem; display: flex; flex-direction: column; gap: 0.25rem;
}
.doc-mock__logo-bar {
	width: 3rem; height: 4px; background: var(--color-primary);
	border-radius: 2px; margin-bottom: 0.375rem;
}
.doc-mock__label {
	font-size: 0.6875rem; font-weight: 700; color: var(--color-primary);
	font-family: var(--font-sans); letter-spacing: 0.06em; text-transform: uppercase;
}
.doc-mock__subtitle { font-size: 0.625rem; color: var(--color-text-subtle); font-family: var(--font-sans); }
.doc-mock__body { padding: 1rem; }
.doc-mock__table { display: flex; flex-direction: column; gap: 1px; }
.doc-mock__row {
	display: grid; grid-template-columns: 1.5fr 2fr 1fr; gap: 1px;
}
.doc-mock__row--head .doc-mock__cell { background: var(--color-border); }
.doc-mock__cell {
	height: 16px; background: var(--color-bg-subtle); border-radius: 2px;
}
.doc-mock__lines { display: flex; flex-direction: column; gap: 5px; }
.doc-mock__line { height: 5px; background: var(--color-border); border-radius: 3px; opacity: 0.7; }
.doc-mock__line--lg { width: 90%; opacity: 0.9; }
.doc-mock__line--sm { width: 55%; opacity: 0.5; }

/* Pipeline mockup */
.pipeline-mock {
	display: flex; align-items: center; gap: 4px; flex-wrap: nowrap; overflow: hidden;
}
.pipeline-stage {
	flex: 1; text-align: center; font-size: 0.5rem; font-family: var(--font-sans);
	color: var(--color-text-muted); background: var(--color-bg-subtle);
	border: 1px solid var(--color-border); border-radius: 3px;
	padding: 5px 2px; white-space: nowrap;
}
.pipeline-stage--accent { background: rgba(30,64,175,.1); border-color: rgba(30,64,175,.3); color: var(--color-primary); font-weight: 700; }
.pipeline-arrow { font-size: 0.5rem; color: var(--color-text-subtle); flex-shrink: 0; }

/* ── Metrics ──────────────────────────────────────────── */
.metrics { background: var(--color-bg-subtle); padding: 5rem 0; }
.metrics-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; }
.metric-card {
	background: #fff; border: 1px solid var(--color-border); border-radius: 8px; padding: 1.5rem 1.25rem;
}
.metric-card__en {
	font-size: 0.625rem; font-weight: 700; letter-spacing: 0.1em;
	color: var(--color-primary); font-family: var(--font-sans);
	text-transform: uppercase; margin-bottom: 0.5rem;
}
.metric-card h3 { font-size: 0.9375rem; color: var(--color-text); margin-bottom: 0.5rem; font-family: var(--font-serif); }
.metric-card p { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.7; margin: 0; }

/* ── Why Us ──────────────────────────────────────────── */
.why-us { background: #fff; padding: 5rem 0; }
.why-us-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
.why-card { border-top: 2px solid var(--color-border); padding-top: 1.5rem; }
.why-card h3 { font-size: 1.0625rem; color: var(--color-text); margin-bottom: 0.75rem; font-family: var(--font-serif); }
.why-card p { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.8; margin-bottom: 1rem; }
.why-card__notes { display: flex; flex-direction: column; gap: 0.25rem; }
.why-card__notes span {
	font-size: 0.75rem; font-weight: 600; color: var(--color-primary);
	font-family: var(--font-sans);
}
.why-card__notes span::before { content: '✓ '; }

/* ── Cases ──────────────────────────────────────────── */
.cases { background: var(--color-bg-subtle); padding: 5rem 0; }
.cases-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-bottom: 2.5rem; }
.case-card {
	background: #fff; border: 1px solid var(--color-border); border-radius: 8px;
	padding: 1.75rem; display: flex; flex-direction: column; gap: 1rem;
	transition: box-shadow 0.2s;
}
.case-card:hover { box-shadow: var(--shadow-sm); border-color: var(--color-primary); }
.case-card__meta { display: flex; align-items: center; gap: 0.625rem; flex-wrap: wrap; }
.case-tag {
	font-size: 0.75rem; font-weight: 600; color: var(--color-primary);
	background: rgba(30,64,175,.07); padding: 0.2rem 0.6rem;
	border-radius: 4px; font-family: var(--font-sans);
}
.case-size { font-size: 0.75rem; color: var(--color-text-muted); font-family: var(--font-sans); }
.case-card__title { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); line-height: 1.55; margin: 0; font-family: var(--font-serif); }
.case-card__body { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.75; margin: 0; flex: 1; }
.case-card__footer { display: flex; flex-direction: column; gap: 0.75rem; margin-top: auto; }
.case-tools { display: flex; flex-wrap: wrap; gap: 0.375rem; }
.case-tools span {
	font-size: 0.7rem; color: var(--color-text-muted); background: var(--color-bg-subtle);
	border: 1px solid var(--color-border); padding: 0.15rem 0.5rem;
	border-radius: 4px; font-family: var(--font-sans);
}
.case-link { font-size: 0.8125rem; font-weight: 600; color: var(--color-primary); text-decoration: none; font-family: var(--font-sans); }
.case-link:hover { text-decoration: underline; }
.cases-cta { text-align: center; }

/* ── Fit ──────────────────────────────────────────── */
.fit { background: #fff; padding: 5rem 0; }
.fit-inner { max-width: 680px; }
.fit-list { list-style: none; }
.fit-list li {
	font-size: 0.9375rem; color: var(--color-text-muted); padding: 0.875rem 0;
	border-bottom: 1px solid var(--color-border); display: flex; gap: 0.875rem;
	font-family: var(--font-sans); line-height: 1.6;
}
.fit-list li:last-child { border-bottom: none; }
.fit-list li::before {
	content: ''; display: block; width: 6px; height: 6px;
	background: var(--color-primary); border-radius: 50%;
	flex-shrink: 0; margin-top: 0.45rem;
}

/* ── Approach ──────────────────────────────────────────── */
.approach { background: var(--color-bg-subtle); padding: 5rem 0; }
.approach-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
.approach-copy h2 { font-size: 1.625rem; color: var(--color-text); margin-bottom: 1.25rem; }
.approach-copy p { font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.85; margin-bottom: 1rem; }
.approach-copy .btn { margin-top: 1rem; }
.checklist-label { font-size: 0.8125rem; font-weight: 700; color: var(--color-text); margin-bottom: 1rem; font-family: var(--font-sans); }
.approach-checklist ul { list-style: none; }
.approach-checklist li {
	font-size: 0.9375rem; color: var(--color-text-muted); padding: 0.75rem 0;
	border-bottom: 1px solid var(--color-border); display: flex; gap: 0.875rem;
	font-family: var(--font-sans); line-height: 1.6;
}
.approach-checklist li:last-child { border-bottom: none; }
.approach-checklist li::before { content: '✓'; color: var(--color-primary); font-weight: 700; flex-shrink: 0; font-size: 0.875rem; }

/* ── Pricing ──────────────────────────────────────────── */
.pricing { background: #fff; padding: 5rem 0; }
.pricing-pretext {
	font-size: 0.9375rem; color: var(--color-text-muted); line-height: 1.9;
	margin-bottom: 2.5rem; font-family: var(--font-sans);
}
.pricing-card { border: 1px solid var(--color-border-strong); border-radius: 8px; overflow: hidden; }
.pricing-card__main { padding: 2.5rem; }
.pricing-service-name { font-size: 0.8125rem; font-weight: 700; color: var(--color-text-muted); font-family: var(--font-sans); margin-bottom: 0.5rem; letter-spacing: 0.04em; }
.pricing-amount { font-size: 2.5rem; font-weight: 900; color: var(--color-text); font-family: var(--font-serif); margin-bottom: 0.75rem; }
.pricing-note { font-size: 0.8125rem; color: var(--color-text-subtle); margin-bottom: 2rem; }
.pricing-card__types { display: grid; grid-template-columns: 1fr 1fr; }
.pricing-type { padding: 1.5rem 1.5rem 1.5rem 0; border-right: 1px solid var(--color-border); }
.pricing-type:last-child { border-right: none; padding-left: 1.5rem; padding-right: 0; }
.pricing-type__label { font-size: 0.875rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.5rem; font-family: var(--font-sans); }
.pricing-type p { font-size: 0.8125rem; color: var(--color-text-muted); margin: 0; line-height: 1.7; }
.pricing-card__cta {
	background: var(--color-bg-subtle); border-top: 1px solid var(--color-border);
	padding: 1.75rem 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap; align-items: center;
}

/* ── Related ──────────────────────────────────────────── */
.related { background: var(--color-bg-subtle); padding: 5rem 0; }
.related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
.related-card {
	background: #fff; border: 1px solid var(--color-border); border-radius: 8px;
	padding: 1.25rem; text-decoration: none; display: block; transition: all 0.2s;
}
.related-card:hover { box-shadow: var(--shadow-sm); border-color: var(--color-primary); }
.related-card__num { font-size: 0.6875rem; font-weight: 700; color: var(--color-primary); font-family: var(--font-sans); margin-bottom: 0.5rem; }
.related-card h3 { font-size: 0.9375rem; font-weight: 700; color: var(--color-text); margin: 0 0 0.375rem; line-height: 1.45; font-family: var(--font-serif); }
.related-card p { font-size: 0.8125rem; color: var(--color-text-muted); margin: 0; }

/* ── FAQ ──────────────────────────────────────────── */
.faq { background: #fff; padding: 5rem 0; }
.faq-list { max-width: 720px; }
.faq-item { border-bottom: 1px solid var(--color-border); }
.faq-item:first-of-type { border-top: 1px solid var(--color-border); }
.faq-q {
	font-size: 0.9375rem; font-weight: 700; color: var(--color-text);
	font-family: var(--font-sans); padding: 1.25rem 0; cursor: pointer;
	list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 1rem;
}
.faq-q::after { content: '+'; font-size: 1.25rem; color: var(--color-primary); flex-shrink: 0; }
details[open] .faq-q::after { content: '−'; }
.faq-a { padding: 0 0 1.25rem; }
.faq-a p { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.85; margin: 0; }

/* ── Final CTA ──────────────────────────────────────────── */
.cta-final {
	background:
		radial-gradient(800px 360px at 85% -5%, rgba(124,92,191,0.35), transparent 55%),
		linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%);
	padding: 5rem 0;
}
.cta-inner { display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center; }
.cta-copy h2 { font-size: 2rem; color: #fff; margin-bottom: 1rem; line-height: 1.4; }
.cta-copy p { font-size: 0.9375rem; color: rgba(255,255,255,.8); line-height: 1.85; margin: 0; }
.cta-actions { display: flex; flex-direction: column; gap: 0.875rem; }

/* ── Responsive ──────────────────────────────────────── */
@media (max-width: 1024px) {
	.symptoms-grid { grid-template-columns: repeat(3, 1fr); }
	.problems-grid { grid-template-columns: repeat(3, 1fr); }
	.metrics-grid { grid-template-columns: repeat(3, 1fr); }
	.scope-grid { grid-template-columns: repeat(2, 1fr); }
