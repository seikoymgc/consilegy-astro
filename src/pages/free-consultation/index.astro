---
import BaseLayout from '../../layouts/BaseLayout.astro';

const faqItems = [
	{
		q: '無料相談は本当に無料ですか？',
		a: 'はい、完全無料です。30分のオンライン相談で費用は一切かかりません。相談後に有償サービスをご提案することがありますが、強制ではありません。',
	},
	{
		q: '相談だけでも大丈夫ですか？',
		a: 'もちろんです。「まず状況を整理したい」「どのサービスが合うか知りたい」という段階でのご相談を歓迎しています。無理なご提案はしません。',
	},
	{
		q: '診断を申し込む前提ですか？',
		a: 'いいえ。無料相談は、課題の輪郭を整理し、次のステップを一緒に考えることが目的です。有償診断が必要かどうかも、相談の中で確認します。不要であればその旨をお伝えします。',
	},
	{
		q: 'オンライン対応ですか？',
		a: 'はい、Zoom / Google Meet等のオンラインで実施します。カレンダーから日時を選択いただければ、確認メールに接続URLを記載してお送りします。',
	},
	{
		q: '何を準備すればよいですか？',
		a: '特別な準備は不要です。現在利用中のCRM / SFA / MAのツール名、おおよその組織体制（営業・マーケ・CSの分業状況）をご存知であれば、そのままお話しください。「何が問題か分からない」状態でも問題ありません。',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map(({ q, a }) => ({
		'@type': 'Question',
		name: q,
		acceptedAnswer: { '@type': 'Answer', text: a },
	})),
};

const forItems = [
	'どのサービスを選べばよいか分からない',
	'収益構造の現状分析が必要か確認したい',
	'現状課題をまず話して整理したい',
	'プロジェクト規模感を知りたい',
	'Consilegyの支援範囲を確認したい',
];

const doItems = [
	'現状課題のヒアリング',
	'利用中のCRM / SFA / MAの確認',
	'営業・マーケ・CS連携の課題確認',
	'有償診断が必要かの確認',
	'次の進め方のご案内',
];

const dontItems = [
	'詳細なCRM環境調査',
	'データ分析',
	'診断レポート作成',
	'改善ロードマップ作成',
	'具体的な実装設計',
];
---

<BaseLayout
	title="30分無料相談 | Consilegy"
	description="CRM / RevOps、営業・マーケ連携、KPI設計、Revenue Architectureの課題を30分で伺い、次に整理すべき論点をご案内します。完全無料・オンライン対応。"
	lang="ja"
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	</Fragment>

<!-- ===== HERO ===== -->
<section class="hero">
	<div class="container">
		<p class="eyebrow">Free Consultation</p>
		<h1>30分無料相談</h1>
		<p class="hero-sub">
			CRM / RevOps、営業・マーケ連携、KPI設計、Revenue Architectureに関する課題を30分で簡単に伺い、次に整理すべき論点をご案内します。
		</p>
		<a href="#booking" class="btn btn--primary btn--lg">30分無料相談を予約する →</a>
		<div class="hero-meta">
			<span class="meta-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
				所要時間：30分
			</span>
			<span class="meta-item">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
				オンライン（Zoom等）
			</span>
			<span class="meta-item meta-item--free">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
				完全無料
			</span>
		</div>
	</div>
</section>

<!-- ===== FOR / DO / DONT ===== -->
<section class="info-section">
	<div class="container">
		<div class="info-grid">

			<!-- おすすめ -->
			<div class="info-card">
				<div class="info-card__header info-card__header--blue">
					<p class="info-card__eyebrow">For</p>
					<h2>このような方におすすめ</h2>
				</div>
				<ul class="info-list">
					{forItems.map((item) => (
						<li class="info-list__item info-list__item--check">
							<span class="info-icon info-icon--check" aria-hidden="true">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
							</span>
							{item}
						</li>
					))}
				</ul>
			</div>

			<!-- 行うこと -->
			<div class="info-card">
				<div class="info-card__header info-card__header--green">
					<p class="info-card__eyebrow">Do</p>
					<h2>無料相談で行うこと</h2>
				</div>
				<ul class="info-list">
					{doItems.map((item) => (
						<li class="info-list__item">
							<span class="info-icon info-icon--do" aria-hidden="true">○</span>
							{item}
						</li>
					))}
				</ul>
			</div>

			<!-- 行わないこと -->
			<div class="info-card">
				<div class="info-card__header info-card__header--muted">
					<p class="info-card__eyebrow">Don't</p>
					<h2>無料相談で行わないこと</h2>
				</div>
				<ul class="info-list">
					{dontItems.map((item) => (
						<li class="info-list__item">
							<span class="info-icon info-icon--dont" aria-hidden="true">—</span>
							{item}
						</li>
					))}
				</ul>
				<p class="info-card__note">これらは有償の<a href="/revops-assessment/">収益構造の現状分析</a>で対応します。</p>
			</div>

		</div>
	</div>
</section>

<!-- ===== FLOW ===== -->
<section class="flow-section">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow">After Consultation</p>
			<h2>相談後の流れ</h2>
		</div>
		<div class="flow">
			<div class="flow-step flow-step--active">
				<div class="flow-step__badge">無料</div>
				<div class="flow-step__card flow-step__card--active">
					<p class="flow-step__label">30分無料相談</p>
					<p class="flow-step__desc">課題の輪郭を整理し、次のステップを確認</p>
				</div>
			</div>
			<div class="flow-arrow" aria-hidden="true">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
				<span>必要に応じて</span>
			</div>
			<div class="flow-step">
				<div class="flow-step__badge flow-step__badge--muted">有償</div>
				<div class="flow-step__card">
					<a href="/revops-assessment/" class="flow-step__link">収益構造の現状分析</a>
					<p class="flow-step__desc">ボトルネックの可視化と改善優先順位の整理</p>
				</div>
			</div>
			<div class="flow-arrow" aria-hidden="true">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
			</div>
			<div class="flow-step">
				<div class="flow-step__badge flow-step__badge--muted">有償</div>
				<div class="flow-step__card">
					<a href="/services/" class="flow-step__link">設計・実装・伴走支援</a>
					<p class="flow-step__desc">Revenue Architecture設計、CRM再設計、定着支援</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ===== BOOKING ===== -->
<section class="booking-section" id="booking">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow">Schedule</p>
			<h2>日程を選択してください</h2>
			<p class="section-sub">カレンダーから空き時間を選んでそのまま予約できます。確認メールが自動送信されます。</p>
		</div>
		<div class="booking-wrapper">
			<div class="meetings-iframe-container" data-src="https://lp.consilegy.com/meetings/seiko/free-consultation?embed=true"></div>
			<script type="text/javascript" src="https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js" is:inline></script>
		</div>
	</div>
</section>

<!-- ===== FAQ ===== -->
<section class="faq-section">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow">FAQ</p>
			<h2>よくある質問</h2>
		</div>
		<div class="faq-list">
			{faqItems.map(({ q, a }) => (
				<details class="faq-item">
					<summary class="faq-q">{q}</summary>
					<div class="faq-a"><p>{a}</p></div>
				</details>
			))}
		</div>
	</div>
</section>

<!-- ===== FINAL CTA ===== -->
<section class="final-cta">
	<div class="container">
		<div class="final-cta__inner">
			<h2>まず30分、話してみませんか。</h2>
			<p>課題が整理できていなくても問題ありません。一緒に整理します。</p>
			<a href="#booking" class="btn btn--cta">日程を選んで予約する →</a>
		</div>
	</div>
</section>

</BaseLayout>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
	--color-primary: #1e40af;
	--color-primary-dark: #1d4ed8;
	--color-navy: #0f172a;
	--color-charcoal: #334155;
	--color-muted: #64748b;
	--color-border: #e2e8f0;
	--color-border-mid: #cbd5e1;
	--color-bg-soft: #f8fafc;
	--color-green: #059669;
	--font-serif: var(--font-sans);
	--font-sans: 'Inter', 'Noto Sans JP', system-ui, sans-serif;
	--container: 1100px;
}

body { font-family: var(--font-sans); color: var(--color-navy); line-height: 1.7; }
.container { max-width: var(--container); margin: 0 auto; padding: 0 2rem; }

.eyebrow {
	font-size: 0.72rem;
	font-weight: 700;
	letter-spacing: 0.16em;
	text-transform: uppercase;
	color: var(--color-primary);
	display: block;
	margin-bottom: 0.625rem;
}
.section-header {
	text-align: center;
	margin-bottom: 2.5rem;
}
.section-header h2 {
	font-family: var(--font-serif);
	font-size: clamp(1.375rem, 2.5vw, 1.875rem);
	color: var(--color-navy);
	line-height: 1.4;
}
.section-sub {
	margin-top: 0.75rem;
	font-size: 0.9375rem;
	color: var(--color-muted);
	line-height: 1.7;
}

.btn {
	display: inline-flex;
	align-items: center;
	font-weight: 600;
	border-radius: 5px;
	text-decoration: none;
	transition: all 0.18s;
	font-size: 0.9375rem;
	padding: 0.75rem 1.5rem;
}
.btn--primary { background: var(--color-primary); color: #fff; border: 2px solid transparent; }
.btn--primary:hover { background: var(--color-primary-dark); }
.btn--lg { padding: 0.875rem 1.875rem; font-size: 1rem; }
.btn--cta { background: #fff; color: var(--color-primary); border: 2px solid transparent; padding: 0.875rem 2rem; font-size: 1rem; }
.btn--cta:hover { background: #f0f4ff; }

/* ===== HERO ===== */
.hero {
	padding: 4.5rem 0 4rem;
	background: linear-gradient(160deg, #f0f4ff 0%, #ffffff 70%);
	border-bottom: 1px solid var(--color-border);
}
.hero h1 {
	font-family: var(--font-serif);
	font-size: clamp(2.25rem, 5vw, 3.25rem);
	color: var(--color-navy);
	margin-bottom: 1.25rem;
	line-height: 1.2;
}
.hero-sub {
	font-size: 1rem;
	color: var(--color-charcoal);
	line-height: 1.85;
	max-width: 54ch;
	margin-bottom: 2rem;
}
.hero-meta {
	display: flex;
	flex-wrap: wrap;
	gap: 1.25rem;
	margin-top: 1.75rem;
	align-items: center;
}
.meta-item {
	display: flex;
	align-items: center;
	gap: 0.375rem;
	font-size: 0.875rem;
	color: var(--color-muted);
}
.meta-item svg { flex-shrink: 0; opacity: 0.7; }
.meta-item--free {
	color: var(--color-green);
	font-weight: 700;
}
.meta-item--free svg { opacity: 1; stroke: var(--color-green); }

/* ===== INFO SECTION ===== */
.info-section {
	padding: 4rem 0;
	background: var(--color-bg-soft);
	border-top: 1px solid var(--color-border);
}
.info-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 1.25rem;
}
.info-card {
	background: #fff;
	border: 1px solid var(--color-border);
	border-radius: 8px;
	overflow: hidden;
	display: flex;
	flex-direction: column;
}
.info-card__header {
	padding: 1.25rem 1.5rem;
	border-bottom: 1px solid var(--color-border);
}
.info-card__header--blue { background: #eff6ff; }
.info-card__header--green { background: #f0fdf4; }
.info-card__header--muted { background: var(--color-bg-soft); }
.info-card__eyebrow {
	font-size: 0.65rem;
	font-weight: 700;
	letter-spacing: 0.16em;
	text-transform: uppercase;
	color: var(--color-primary);
	margin-bottom: 0.375rem;
	display: block;
}
.info-card__header--green .info-card__eyebrow { color: var(--color-green); }
.info-card__header--muted .info-card__eyebrow { color: var(--color-muted); }
.info-card__header h2 {
	font-family: var(--font-serif);
	font-size: 0.9375rem;
	color: var(--color-navy);
	line-height: 1.4;
}
.info-list {
	list-style: none;
	padding: 1.25rem 1.5rem;
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
	flex: 1;
}
.info-list__item {
	display: flex;
	align-items: flex-start;
	gap: 0.625rem;
	font-size: 0.875rem;
	color: var(--color-charcoal);
	line-height: 1.6;
}
.info-icon {
	flex-shrink: 0;
	display: flex;
	align-items: center;
	justify-content: center;
	width: 20px;
	height: 20px;
	border-radius: 50%;
	font-size: 0.75rem;
	font-weight: 700;
	margin-top: 1px;
}
.info-icon--check {
	background: var(--color-primary);
	color: #fff;
}
.info-icon--do {
	background: #dcfce7;
	color: var(--color-green);
	font-size: 0.875rem;
}
.info-icon--dont {
	background: var(--color-bg-soft);
	color: var(--color-border-mid);
	font-size: 1rem;
	font-weight: 400;
}
.info-card__note {
	padding: 0 1.5rem 1.25rem;
	font-size: 0.8125rem;
	color: var(--color-muted);
	line-height: 1.7;
}
.info-card__note a {
	color: var(--color-primary);
	text-decoration: underline;
}

/* ===== FLOW ===== */
.flow-section {
	padding: 4rem 0;
	background: #fff;
	border-top: 1px solid var(--color-border);
}
.flow {
	max-width: 500px;
	margin: 0 auto;
	display: flex;
	flex-direction: column;
	align-items: stretch;
	gap: 0;
}
.flow-step {
	display: flex;
	align-items: flex-start;
	gap: 1rem;
}
.flow-step__badge {
	font-size: 0.65rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	color: var(--color-primary);
	background: #eff6ff;
	border: 1px solid #bfdbfe;
	padding: 0.2rem 0.625rem;
	border-radius: 4px;
	white-space: nowrap;
	margin-top: 1.125rem;
	flex-shrink: 0;
}
.flow-step__badge--muted {
	color: var(--color-muted);
	background: var(--color-bg-soft);
	border-color: var(--color-border);
}
.flow-step__card {
	flex: 1;
	background: var(--color-bg-soft);
	border: 1px solid var(--color-border);
	border-radius: 8px;
	padding: 1rem 1.25rem;
}
.flow-step__card--active {
	background: #eff6ff;
	border-color: #bfdbfe;
}
.flow-step__label {
	font-size: 0.9375rem;
	font-weight: 700;
	color: var(--color-navy);
	margin-bottom: 0.25rem;
}
.flow-step__link {
	font-size: 0.9375rem;
	font-weight: 700;
	color: var(--color-primary);
	text-decoration: none;
	display: block;
	margin-bottom: 0.25rem;
}
.flow-step__link:hover { text-decoration: underline; }
.flow-step__desc {
	font-size: 0.8125rem;
	color: var(--color-muted);
	line-height: 1.7;
}
.flow-arrow {
	display: flex;
	flex-direction: column;
	align-items: center;
	padding: 0.25rem 0 0.25rem 3.5rem;
	gap: 0.25rem;
	color: var(--color-border-mid);
}
.flow-arrow span {
	font-size: 0.72rem;
	color: var(--color-muted);
	letter-spacing: 0.05em;
}

/* ===== BOOKING ===== */
.booking-section {
	padding: 4rem 0;
	background: var(--color-bg-soft);
	border-top: 1px solid var(--color-border);
}
.booking-wrapper {
	max-width: 900px;
	margin: 0 auto;
	background: #fff;
	border: 1px solid var(--color-border);
	border-radius: 8px;
	overflow: hidden;
	min-height: 680px;
}
.meetings-iframe-container {
	width: 100%;
	min-height: 680px;
}

/* ===== FAQ ===== */
.faq-section {
	padding: 4rem 0;
	background: #fff;
	border-top: 1px solid var(--color-border);
}
.faq-list {
	max-width: 700px;
	margin: 0 auto;
}
.faq-item { border-bottom: 1px solid var(--color-border); }
.faq-item:first-child { border-top: 1px solid var(--color-border); }
.faq-q {
	font-size: 0.9375rem;
	font-weight: 600;
	color: var(--color-navy);
	padding: 1.125rem 2.5rem 1.125rem 0;
	cursor: pointer;
	list-style: none;
	position: relative;
	line-height: 1.6;
}
.faq-q::after {
	content: '+';
	position: absolute;
	right: 0;
	top: 50%;
	transform: translateY(-50%);
	font-size: 1.25rem;
	color: var(--color-primary);
	font-weight: 300;
	line-height: 1;
}
details[open] .faq-q::after { content: '−'; }
.faq-a { padding: 0 0 1.25rem; }
.faq-a p { font-size: 0.875rem; color: var(--color-muted); line-height: 1.9; }

/* ===== FINAL CTA ===== */
.final-cta {
	padding: 5rem 0;
	background:
		radial-gradient(800px 360px at 85% -5%, rgba(124,92,191,0.35), transparent 55%),
		linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%);
}
.final-cta__inner {
	text-align: center;
	max-width: 560px;
	margin: 0 auto;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 1.25rem;
}
.final-cta__inner h2 {
	font-family: var(--font-serif);
	font-size: clamp(1.5rem, 3vw, 2rem);
	color: #fff;
	line-height: 1.45;
}
.final-cta__inner p {
	font-size: 1rem;
	color: rgba(255,255,255,0.8);
	line-height: 1.8;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 860px) {
	.info-grid { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
	.hero-meta { gap: 0.875rem; }
	.booking-wrapper { border-radius: 0; border-left: none; border-right: none; }
}
</style>
