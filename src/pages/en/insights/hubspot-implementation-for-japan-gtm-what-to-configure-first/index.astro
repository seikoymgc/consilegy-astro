const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'HubSpot Implementation for Japan GTM: What to Configure First',
  description: 'HubSpot out of the box is not Japan-ready. Configuration order matters: lifecycle stages first, then Japan-specific properties, pipeline stages, handoff workflows, and Japan-focused reporting dashboards.',
  datePublished: pubDate,
  dateModified: pubDate,
  author: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
  publisher: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
  url: 'https://consilegy.com/en/insights/hubspot-implementation-for-japan-gtm-what-to-configure-first/',
  inLanguage: 'en',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://consilegy.com/en/' },
    { '@type': 'ListItem', position: 2, name: 'Insights', item: 'https://consilegy.com/en/insights/' },
    { '@type': 'ListItem', position: 3, name: 'HubSpot Implementation for Japan GTM: What to Configure First', item: 'https://consilegy.com/en/insights/hubspot-implementation-for-japan-gtm-what-to-configure-first/' },
  ],
