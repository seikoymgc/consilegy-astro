const readTime = '約10分';

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: 'Revenue Data Flowとは何か｜なぜ数字がつながらないのか',
	description: 'DXコンサルティング企業（150名）がHubSpot・Salesforce・Sansan・GA4を統合し、顧客行動の100%可視化・分析工数30%削減を実現。データが「つながっているつもり」になっている組織の構造的な問題を解説します。',
	datePublished: pubDate,
	dateModified: pubDate,
	author: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	publisher: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	url: 'https://consilegy.com/insights/what-is-revenue-data-flow/',
	inLanguage: 'ja',
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://consilegy.com/' },
		{ '@type': 'ListItem', position: 2, name: 'コラム', item: 'https://consilegy.com/insights/' },
		{ '@type': 'ListItem', position: 3, name: 'Revenue Data Flowとは何か——なぜ数字がつながらないのか', item: 'https://consilegy.com/insights/what-is-revenue-data-flow/' },
	],
