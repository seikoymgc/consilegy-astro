    date: '2026-05-07',
  },
];

// カテゴリ色マップ
const catColor: Record<string, string> = {
  'Revenue Architecture': 'cat--ra',
  'CRM / RevOps':         'cat--crm',
  'RevOps / KPI':         'cat--kpi',
  'RevOps / CS':          'cat--cs',
  'Marketing / RevOps':   'cat--mkt',
  'Marketing / Sales':    'cat--mkt',
  'BI / RevOps':          'cat--bi',
  'HubSpot / RevOps':     'cat--hs',
  'Salesforce / RevOps':  'cat--sf',
  'Sales / RevOps':       'cat--sales',
  'Sales / CRM':          'cat--sales',
  'RevOps':               'cat--revops',
};

function catClass(cat: string) {
  return catColor[cat] ?? 'cat--default';
}

function fmtDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y}年${parseInt(m)}月${parseInt(d)}日`;
}

// ユニークカテゴリ（出現順）
const allCats = articles.map(a => a.cat);
const uniqueCats = ['すべて', ...Array.from(new Set(allCats))];
---

<BaseLayout
  title="コラム | Consilegy"
  description="RevOps・Revenue Architecture・CRM・KPIに関する実践コラム。日本のBtoB企業の課題を構造から解説します。"
>
<div class="ins-page">

  <!-- ===== HEADER ===== -->
  <header class="ins-head">
    <div class="container"><div class="ins-head__inner">
      <p class="ins-head__eyebrow">コラム</p>
      <h1 class="ins-head__title">コラム</h1>
      <p class="ins-head__lede">RevOps・Revenue Architecture・CRM・KPI設計に関する実践コラム。<br class="br-pc" />日本のBtoB企業が直面する課題の構造を、実務の観点から解説します。</p>
    </div></div>
  </header>

  <!-- ===== FILTER ===== -->
  <div class="ins-filter-wrap container">
    <div class="ins-filter" role="group" aria-label="カテゴリで絞り込み">
      {uniqueCats.map((cat) => (
        <button
          class={`ins-filter__btn${cat === 'すべて' ? ' is-active' : ''}`}
          data-cat={cat}
          type="button"
        >{cat}</button>
      ))}
    </div>
  </div>

  <!-- ===== GRID ===== -->
  <section class="ins-grid-wrap container">
    <ul class="ins-grid" role="list" id="ins-grid">
      {articles.map((a, i) => (
        <li class="ins-card" data-cat={a.cat}>
          <a href={`/insights/${a.slug}/`} class="ins-card__link">
            <div class="ins-card__thumb">
              <img
                src={`/images/insights/${a.slug}.svg`}
                alt={a.cat}
                width="1200"
                height="630"
                loading="lazy"
                class="ins-card__img"
              />
              {i < 3 && <span class="ins-card__new">新着</span>}
            </div>
            <div class="ins-card__body">
              <h2 class="ins-card__title">{a.title}</h2>
              <p class="ins-card__desc">{a.desc}</p>
              <div class="ins-card__foot">
                <span class="ins-card__arrow" aria-hidden="true">→</span>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
    <p class="ins-no-result" id="ins-no-result" hidden>該当する記事がありません。</p>
  </section>

  <!-- ===== CTA ===== -->
  <div class="ins-cta container">
    <div class="ins-cta__inner">
      <p class="ins-cta__eyebrow">Revenue Architecture</p>
      <h2 class="ins-cta__title">記事の内容についてご相談ください</h2>
      <p class="ins-cta__body">RevOps・CRM・KPI設計の課題を30分でヒアリングし、構造的な論点を整理します。</p>
      <a href="/free-consultation/" class="ins-cta__btn">30分無料相談を予約</a>
    </div>
  </div>

</div>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.ins-filter__btn');
  const cards = document.querySelectorAll<HTMLElement>('.ins-card');
  const noResult = document.getElementById('ins-no-result') as HTMLElement;

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat ?? 'すべて';
      btns.forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');

      let visible = 0;
      cards.forEach(card => {
        const show = cat === 'すべて' || card.dataset.cat === cat;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      noResult.hidden = visible > 0;
    });
  });
</script>
</BaseLayout>

<style>
.ins-page { background: #fff; }
.container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

/* ===== HEADER ===== */
.ins-head {
  background: linear-gradient(160deg, #f8fafc 0%, #eff6ff 100%);
  border-bottom: 1px solid #e2e8f0;
  padding: 64px 0 48px;
}
.ins-head__inner { max-width: 780px; }
.ins-head__eyebrow {
  font-size: .72rem; font-weight: 800; letter-spacing: .18em;
  text-transform: uppercase; color: #1e40af; margin: 0 0 14px;
}
.ins-head__title {
  font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 600;
  color: #0f172a; letter-spacing: 0.01em; margin: 0 0 16px; line-height: 1.2;
}
.ins-head__lede {
  font-size: 1rem; color: #334155; line-height: 1.8; margin: 0;
}
.br-pc { display: block; }

/* ===== FILTER ===== */
.ins-filter-wrap {
  padding: 28px 24px 0;
}
.ins-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.ins-filter__btn {
  display: inline-flex;
  align-items: center;
  padding: 6px 16px;
  border-radius: 20px;
  border: 1.5px solid #e2e8f0;
  background: #fff;
  color: #475569;
  font-size: .8rem;
  font-weight: 600;
  cursor: pointer;
  transition: all .15s;
  white-space: nowrap;
}
.ins-filter__btn:hover {
  border-color: #93c5fd;
  color: #1e40af;
  background: #eff6ff;
}
.ins-filter__btn.is-active {
  background: #1e40af;
  border-color: #1e40af;
  color: #fff;
}

/* ===== GRID ===== */
.ins-grid-wrap { padding: 32px 24px 48px; }
.ins-grid {
  list-style: none; padding: 0; margin: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.ins-no-result {
  text-align: center;
  color: #64748b;
  font-size: .9rem;
  padding: 40px 0;
}

/* ===== CARD ===== */
.ins-card {
  border: 1px solid #e2e8f0; border-radius: 10px; background: #fff;
  overflow: hidden;
  transition: box-shadow .2s ease, transform .2s ease, border-color .2s ease;
}
.ins-card:hover {
  box-shadow: 0 8px 32px rgba(15,23,42,.10);
  transform: translateY(-3px);
  border-color: #bfdbfe;
}
.ins-card__link {
  display: flex; flex-direction: column;
  height: 100%; text-decoration: none; color: inherit;
}

/* Thumbnail */
.ins-card__thumb {
  position: relative;
  aspect-ratio: 1200 / 630;
  overflow: hidden;
  background: #0f172a;
  flex-shrink: 0;
}
.ins-card__img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform .3s ease;
}
.ins-card:hover .ins-card__img { transform: scale(1.03); }

.ins-card__new {
  position: absolute; top: 10px; right: 10px;
  font-size: .62rem; font-weight: 800; letter-spacing: .06em;
  background: #1e40af; color: #fff; border-radius: 4px; padding: 3px 8px;
}

/* Body */
.ins-card__body {
  display: flex; flex-direction: column; gap: 0;
  padding: 18px 20px 16px; flex-grow: 1;
}

.ins-card__cat {
  display: inline-block;
  font-size: .68rem; font-weight: 700; letter-spacing: .04em;
  border-radius: 4px; padding: 3px 10px; border: 1px solid;
  margin-bottom: 10px;
  align-self: flex-start;
}
/* category colors */
.cat--ra,
.cat--crm,
.cat--kpi,
.cat--sf,
.cat--revops  { background: #eff6ff; color: #1e40af; border-color: #bfdbfe; }
.cat--cs,
.cat--mkt,
.cat--bi,
.cat--hs,
.cat--sales,
.cat--default { background: #f8fafc; color: #475569; border-color: #e2e8f0; }

.ins-card__title {
  font-size: .95rem; font-weight: 600; color: #0f172a;
  line-height: 1.55; margin: 0 0 8px; flex-grow: 1;
}
.ins-card:hover .ins-card__title { color: #1e40af; }

.ins-card__desc {
  font-size: .8rem; color: #64748b; line-height: 1.7;
  margin: 0 0 14px;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  overflow: hidden;
}

.ins-card__foot {
  display: flex; align-items: center; gap: 10px;
  padding-top: 12px; border-top: 1px solid #f1f5f9;
  margin-top: auto;
}
.ins-card__date { font-size: .72rem; color: #94a3b8; }
.ins-card__read { font-size: .72rem; color: #94a3b8; }
.ins-card__arrow {
  margin-left: auto; font-size: .9rem; color: #bfdbfe;
  transition: transform .18s ease, color .18s ease;
}
.ins-card:hover .ins-card__arrow { transform: translateX(4px); color: #1e40af; }

/* ===== CTA ===== */
.ins-cta { padding: 0 24px 80px; }
.ins-cta__inner {
  background:
    radial-gradient(800px 360px at 85% -5%, rgba(124,92,191,0.35), transparent 55%),
    linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%);
  border-radius: 8px; padding: 52px 48px; color: #fff; text-align: center;
}
.ins-cta__eyebrow {
  font-size: .72rem; font-weight: 800; letter-spacing: .12em;
  text-transform: uppercase; opacity: .7; margin: 0 0 12px;
}
.ins-cta__title  { font-size: clamp(1.3rem, 2.5vw, 1.7rem); font-weight: 700; line-height: 1.45; margin: 0 0 14px; }
.ins-cta__body   { font-size: .95rem; opacity: .85; line-height: 1.7; margin: 0 0 28px; }
.ins-cta__btn {
  display: inline-block; background: #fff; color: #1e40af;
  font-weight: 700; font-size: .95rem; border-radius: 8px;
  padding: 13px 32px; text-decoration: none;
  transition: background .18s ease;
}
.ins-cta__btn:hover { background: #f0f9ff; }

/* ===== RESPONSIVE ===== */
@media (max-width: 960px) {
  .ins-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .br-pc { display: none; }
  .ins-head { padding: 40px 0 32px; }
  .ins-grid-wrap { padding: 24px 16px 32px; }
  .ins-grid { grid-template-columns: 1fr; gap: 16px; }
  .ins-card__body { padding: 16px 16px 14px; }
  .ins-cta__inner { padding: 36px 24px; }
  .ins-cta { padding: 0 16px 60px; }
  .ins-filter-wrap { padding: 20px 16px 0; }
}
</style>
