const pubDateDisplay = '2026年5月7日';
const readTime = '約10分';

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: 'SFAを導入しても売上予測が当たらない理由｜RevOpsとRevenue Architecture',
	description: 'SalesforceなどのSFAを導入しても売上予測が外れる原因を、商談定義・KPI・Revenue Architectureの観点から解説します。',
	datePublished: pubDate,
	dateModified: pubDate,
	author: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	publisher: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	url: 'https://consilegy.com/insights/why-sales-forecasting-fails-even-with-sfa/',
	inLanguage: 'ja',
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://consilegy.com/' },
		{ '@type': 'ListItem', position: 2, name: 'コラム', item: 'https://consilegy.com/insights/' },
		{ '@type': 'ListItem', position: 3, name: 'なぜSFAを導入しても売上予測が当たらないのか', item: 'https://consilegy.com/insights/why-sales-forecasting-fails-even-with-sfa/' },
	],
