---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const cases = (await getCollection('caseStudies'))
  .filter((c) => c.data.lang === 'en' && !c.data.draft)
  .slice(0, 3);
---

<BaseLayout
  title="Japan Revenue Operations for English-Speaking Leaders | Consilegy"
  description="We help English-speaking leaders in Japan and APAC build the CRM structure, revenue architecture, and GTM operations that make Japan execution visible and repeatable."
  lang="en"
  alternateUrl="/"
>
<link
  rel="preload"
  as="image"
  href="/images/common/hero-visual.webp"
  type="image/webp"
  fetchpriority="high"
  slot="head"
/>

<!-- ═══════════════════════════════════════════════════
     1. HERO
═══════════════════════════════════════════════════ -->
<section class="en-hero">
  <div class="en-container">
    <p class="en-eyebrow">For English-speaking leaders running Japan and APAC revenue</p>
    <h1 class="en-hero__h1">
      Make Japan revenue execution<br class="en-hero__br">
      visible, manageable, and repeatable.
    </h1>
    <p class="en-hero__lead">
      We help English-speaking leaders in Japan and APAC build the CRM structure,
      revenue architecture, and GTM operations that make Japan execution
      visible and repeatable — to you and to your HQ.
    </p>
    <div class="en-hero__actions">
      <a href="/en/contact/" class="en-btn en-btn--primary">Contact Us</a>
      <a href="/en/case-studies/" class="en-btn en-btn--ghost">View Case Studies →</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     1b. STATS BAR
═══════════════════════════════════════════════════ -->
<section class="en-stats-bar">
  <div class="en-container">
    <ul class="en-stats">
      <li class="en-stat">
        <span class="en-stat__num">40+</span>
        <span class="en-stat__label">CRM / MA / SFA implementations</span>
      </li>
      <li class="en-stat__div" aria-hidden="true"></li>
      <li class="en-stat">
        <span class="en-stat__num">10+</span>
        <span class="en-stat__label">years B2B marketing in Japan</span>
      </li>
      <li class="en-stat__div" aria-hidden="true"></li>
      <li class="en-stat">
        <span class="en-stat__num">HubSpot &amp; Salesforce</span>
        <span class="en-stat__label">primary platforms</span>
      </li>
      <li class="en-stat__div" aria-hidden="true"></li>
      <li class="en-stat en-stat--wide">
        <span class="en-stat__label en-stat__label--industries">AI · IT · SaaS · Healthcare · Subscription · E-commerce</span>
      </li>
    </ul>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     2. PROBLEM
═══════════════════════════════════════════════════ -->
<section class="en-section en-section--light">
  <div class="en-container en-container--narrow">
    <p class="en-label">The structural gap</p>
    <h2 class="en-section__h2">Japan operations have a blind spot built in.</h2>
    <div class="en-problem__body">
      <p>Your CRM was configured for a different market. Pipeline stages, qualification criteria, and handoff rules don't match how Japan buyers actually move.</p>
      <p>Your Japan team operates in Japanese. Every report that reaches you or HQ has already gone through an interpretation layer — and something gets lost.</p>
      <p>You can see the numbers. You can't always tell why Japan is underperforming or exactly where the system is breaking.</p>
      <p>We build the revenue operations layer that makes Japan execution legible from both sides.</p>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     3. POSITIONING (removed — merged into What we do)
═══════════════════════════════════════════════════ -->

<!-- ═══════════════════════════════════════════════════
     4. USE CASES
═══════════════════════════════════════════════════ -->
<section class="en-section en-section--white">
  <div class="en-container">
    <p class="en-label en-label--center">Who we work with</p>
    <h2 class="en-section__h2 en-section__h2--center">Three situations we know well</h2>
    <div class="en-use-cases">
      <div class="en-use-case">
        <div class="en-use-case__num">01</div>
        <h3 class="en-use-case__title">CRM built for a different market</h3>
        <p class="en-use-case__body">
          You have a CRM. It was configured globally, or for a Western sales motion.
          Lead stages don't match Japan's buying cycle. Forecast data is unreliable.
          Your Japan team uses the system — but not in a way that produces real visibility.
        </p>
      </div>
      <div class="en-use-case">
        <div class="en-use-case__num">02</div>
        <h3 class="en-use-case__title">Japan pipeline you can't see inside</h3>
        <p class="en-use-case__body">
          Revenue exists. Pipeline moves. But you can't tell where deals are stalling,
          what your Japan team is actually prioritizing, or which activities connect to outcomes.
          The gap between what you report and what's really happening is wider than you want it to be.
        </p>
      </div>
      <div class="en-use-case">
        <div class="en-use-case__num">03</div>
        <h3 class="en-use-case__title">Taking ownership of Japan or APAC revenue</h3>
        <p class="en-use-case__body">
          You're new to the Japan or APAC role. You've inherited a setup that wasn't designed
          for this market — or there's no setup at all. You need to understand what works,
          fix what doesn't, and build something that doesn't depend entirely on individual people.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     5. SERVICES — four layers
═══════════════════════════════════════════════════ -->
<section class="en-section en-section--subtle">
  <div class="en-container">
    <p class="en-label en-label--center">Services</p>
    <h2 class="en-section__h2 en-section__h2--center">
      We connect the layers of Japan revenue execution.
    </h2>
    <div class="en-layers">
      <a href="/en/services/revenue-architecture-design/" class="en-layer">
        <span class="en-layer__num">1</span>
        <div class="en-layer__content">
          <h3 class="en-layer__title">Revenue Architecture Design</h3>
          <p class="en-layer__body">
            Define the revenue flow behind lead generation, lifecycle stages, ownership, handoff, and visibility.
          </p>
        </div>
        <span class="en-layer__arrow">→</span>
      </a>
      <a href="/en/services/japan-market-gtm-messaging/" class="en-layer">
        <span class="en-layer__num">2</span>
        <div class="en-layer__content">
          <h3 class="en-layer__title">Japan GTM &amp; Messaging</h3>
          <p class="en-layer__body">
            Adapt positioning, messaging, offers, and conversion paths for Japan's buying context.
          </p>
        </div>
        <span class="en-layer__arrow">→</span>
      </a>
      <a href="/en/services/crm-revops-implementation/" class="en-layer">
        <span class="en-layer__num">3</span>
        <div class="en-layer__content">
          <h3 class="en-layer__title">CRM / RevOps Implementation</h3>
          <p class="en-layer__body">
            Translate the model into CRM configuration, workflows, automation, reporting, and system connections.
          </p>
        </div>
        <span class="en-layer__arrow">→</span>
      </a>
      <a href="/en/services/adoption-growth-support/" class="en-layer">
        <span class="en-layer__num">4</span>
        <div class="en-layer__content">
          <h3 class="en-layer__title">Adoption &amp; Optimization</h3>
          <p class="en-layer__body">
            Support launch, usage, reporting habits, and continuous improvement so the system becomes part of daily execution.
          </p>
        </div>
        <span class="en-layer__arrow">→</span>
      </a>
    </div>
    <p class="en-services__all-link">
      <a href="/en/services/">View all services →</a>
    </p>
    <div class="en-pricing-bar">
      <p class="en-pricing-bar__label">Investment range</p>
      <div class="en-pricing-bar__items">
        <div class="en-pricing-bar__item">
          <span class="en-pricing-bar__tier">Diagnosis</span>
          <span class="en-pricing-bar__range">¥100K – ¥500K</span>
        </div>
        <span class="en-pricing-bar__sep" aria-hidden="true">→</span>
        <div class="en-pricing-bar__item">
          <span class="en-pricing-bar__tier">Redesign Project</span>
          <span class="en-pricing-bar__range">¥3M – ¥8M</span>
        </div>
        <span class="en-pricing-bar__sep" aria-hidden="true">→</span>
        <div class="en-pricing-bar__item">
          <span class="en-pricing-bar__tier">Ongoing Retainer</span>
          <span class="en-pricing-bar__range">¥300K – ¥800K / mo</span>
        </div>
      </div>
      <a href="/pricing/" class="en-pricing-bar__link">Full pricing →</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     7. CASE STUDIES
═══════════════════════════════════════════════════ -->
<section class="en-section en-section--white">
  <div class="en-container">
    <p class="en-label en-label--center">Work</p>
    <h2 class="en-section__h2 en-section__h2--center">Selected case studies</h2>
    <div class="en-cases">
      <a href="/en/case-studies/hubspot-sales-handoff-lead-to-revenue-2/" class="en-case">
        <div class="en-case__img">
          <picture>
            <source srcset="/images/media/2026/02/dx.webp" type="image/webp" />
            <img src="/images/media/2026/02/dx.png" alt="Closing the Gap Between Lead Volume and Revenue" loading="lazy" width="700" height="394" />
          </picture>
        </div>
        <div class="en-case__meta">
          <span class="en-case__tag">HubSpot · Lead Operations</span>
        </div>
        <h3 class="en-case__title">
          Closing the Gap Between Lead Volume and Revenue
        </h3>
        <dl class="en-case__dl">
          <dt>Problem</dt>
          <dd>Lead volume was growing but revenue wasn't following. Handoff between marketing and sales was inconsistent, with no shared qualification criteria or pipeline creation process.</dd>
          <dt>Work</dt>
          <dd>Standardized lead scoring, defined handoff rules, and restructured pipeline stages with clear ownership in HubSpot.</dd>
          <dt>Result</dt>
          <dd>Consistent lead-to-opportunity conversion with visible pipeline by source and stage.</dd>
        </dl>
        <span class="en-case__link">Read case study →</span>
      </a>
      <a href="/en/case-studies/https-consilegy-com-case-studies-ai-gtm-automation-product-integration/" class="en-case">
        <div class="en-case__img">
          <picture>
            <source srcset="/images/media/2026/03/s-o-c-i-a-l-c-u-t-1RT4txDDAbM-unsplash.webp" type="image/webp" />
            <img src="/images/media/2026/03/s-o-c-i-a-l-c-u-t-1RT4txDDAbM-unsplash.jpg" alt="Building a Revenue Foundation for a New AI Business" loading="lazy" width="700" height="466" />
          </picture>
        </div>
        <div class="en-case__meta">
          <span class="en-case__tag">GTM · CRM Build</span>
        </div>
        <h3 class="en-case__title">
          Building a Revenue Foundation for a New AI Business
        </h3>
        <dl class="en-case__dl">
          <dt>Problem</dt>
          <dd>A new AI business needed a GTM foundation from scratch: no defined ICP, no CRM, no lead process, no messaging for the Japan market.</dd>
          <dt>Work</dt>
          <dd>Defined ICP and Japan-specific messaging, built CRM from scratch with appropriate automation and lead flow design.</dd>
          <dt>Result</dt>
          <dd>Operational revenue system in place to support initial sales motion and measure early pipeline.</dd>
        </dl>
        <span class="en-case__link">Read case study →</span>
      </a>
      <a href="/en/case-studies/marketing-data-integration-hubspot-migration-2/" class="en-case">
        <div class="en-case__img">
          <picture>
            <source srcset="/images/media/2026/02/apex-virtual-education-KNQUEQwTCY4-unsplash.webp" type="image/webp" />
            <img src="/images/media/2026/02/apex-virtual-education-KNQUEQwTCY4-unsplash-scaled.jpg" alt="Redesigning a Complex Marketing Stack" loading="lazy" width="700" height="394" />
          </picture>
        </div>
        <div class="en-case__meta">
          <span class="en-case__tag">HubSpot · Marketing Ops</span>
        </div>
        <h3 class="en-case__title">
          Redesigning a Complex Marketing Stack
        </h3>
        <dl class="en-case__dl">
          <dt>Problem</dt>
          <dd>Disconnected marketing tools made it impossible to track campaigns to revenue. Data was fragmented across systems with no unified view.</dd>
          <dt>Work</dt>
          <dd>HubSpot migration, data integration across systems, and attribution model redesign to connect campaign activity to pipeline outcomes.</dd>
          <dt>Result</dt>
          <dd>Unified marketing data with clear campaign-to-revenue visibility and a sustainable operational model.</dd>
        </dl>
        <span class="en-case__link">Read case study →</span>
      </a>
    </div>
    <p class="en-cases__all-link">
      <a href="/en/case-studies/">View all case studies →</a>
    </p>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     8. WHY CONSILEGY
═══════════════════════════════════════════════════ -->
<section class="en-section en-section--dark">
  <div class="en-container en-container--narrow">
    <p class="en-label en-label--light">Why Consilegy</p>
    <h2 class="en-section__h2 en-section__h2--light">
      How we work differently
    </h2>
    <ul class="en-why">
      <li class="en-why__item">
        <span class="en-why__icon">→</span>
        <div>
          <strong>We don't hand off.</strong> We stay engaged until execution works in practice,
          not just until delivery is complete.
        </div>
      </li>
      <li class="en-why__item">
        <span class="en-why__icon">→</span>
        <div>
          <strong>Strategy and implementation in the same engagement.</strong> No gap between
          the plan and the system that's supposed to run it.
        </div>
      </li>
      <li class="en-why__item">
        <span class="en-why__icon">→</span>
        <div>
          <strong>Japan-specific knowledge built in.</strong> Not added as a footnote.
          Japan's buying process, approval dynamics, and trust expectations are part of how
          we design GTM and revenue architecture from the start.
        </div>
      </li>
      <li class="en-why__item">
        <span class="en-why__icon">→</span>
        <div>
          <strong>CRM designed around how Japan actually works.</strong> Not generic best
          practices. Stage definitions, handoff rules, and reporting are built around Japan's
          actual sales motion.
        </div>
      </li>
      <li class="en-why__item">
        <span class="en-why__icon">→</span>
        <div>
          <strong>Bilingual without interpretation loss.</strong> We work directly with you
          in English and with your Japan team in Japanese — so nothing gets diluted
          between the two sides.
        </div>
      </li>
    </ul>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     9. FINAL CTA
═══════════════════════════════════════════════════ -->
<section class="en-section en-cta-final">
  <div class="en-container en-container--narrow en-cta-final__inner">
    <h2 class="en-cta-final__h2">
      Japan revenue operations<br>
      shouldn't be a black box.
    </h2>
    <p class="en-cta-final__body">
      Whether your CRM needs a rebuild, your pipeline lacks visibility,
      or you're taking ownership of Japan or APAC revenue for the first time —
      we can help you design and implement the system that makes Japan execution work.
    </p>
    <div class="en-cta-final__actions">
      <a href="/en/contact/" class="en-btn en-btn--primary en-btn--lg">Contact Us</a>
      <a href="/en/services/" class="en-btn en-btn--ghost-light">Explore Services →</a>
    </div>
  </div>
</section>

</BaseLayout>

<style>
/* ── Tokens ─────────────────────────────────── */
.en-container {
  width: 100%;
  max-width: 1120px;
  margin-inline: auto;
  padding-inline: 1.5rem;
}
.en-container--narrow {
  max-width: 760px;
}

/* ── Buttons ─────────────────────────────────── */
.en-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4em;
  padding: 0.75em 1.5em;
  font-size: 0.9375rem;
  font-weight: 700;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.15s, color 0.15s, border-color 0.15s, opacity 0.15s;
}
.en-btn--lg {
  padding: 0.9em 2em;
  font-size: 1rem;
}
.en-btn--primary {
  background: var(--color-primary);
  color: #fff;
  border: 2px solid var(--color-primary);
}
.en-btn--primary:hover {
  background: var(--color-primary-dark);
  border-color: var(--color-primary-dark);
  color: #fff;
}
.en-hero__actions .en-btn--primary {
  background: #fff;
  color: #0f172a;
  border-color: #fff;
}
.en-hero__actions .en-btn--primary:hover {
  background: #f1f5f9;
  border-color: #f1f5f9;
  color: #0f172a;
}
.en-btn--ghost {
  background: transparent;
  color: #fff;
  border: 2px solid rgba(255,255,255,0.4);
}
.en-btn--ghost:hover {
  border-color: #fff;
  color: #fff;
}
.en-btn--ghost-light {
  background: transparent;
  color: #fff;
  border: 2px solid rgba(255, 255, 255, 0.55);
}
.en-btn--ghost-light:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: #fff;
  color: #fff;
}

/* ── Labels ─────────────────────────────────── */
.en-label {
  display: block;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-primary);
  margin-bottom: 0.75rem;
}
.en-label--center { text-align: center; }
.en-label--light { color: rgba(255,255,255,0.6); }

/* ── Section headings ─────────────────────────── */
.en-section__h2 {
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  font-weight: 600;
  line-height: 1.25;
  color: var(--color-text);
  margin: 0 0 1.5rem;
}
.en-section__h2--center { text-align: center; }
.en-section__h2--light { color: #fff; }

.en-section__lead {
  font-size: 1.0625rem;
  line-height: 1.8;
  color: var(--color-text-muted);
}

/* ── Section backgrounds ─────────────────────── */
.en-section {
  padding: 80px 0;
}
.en-section--white  { background: #fff; }
.en-section--light  { background: #fff; }
.en-section--subtle { background: #f8f9fc; }
.en-section--dark   { background: #0f172a; }
.en-section--offer  { background: #eff6ff; }

/* ═══════════════════════════════════════════════
   1. HERO
═══════════════════════════════════════════════ */
.en-hero {
  background-image: url('/images/common/hero-visual-720.webp');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  padding: 96px 0 88px;
  color: #fff;
}
@media (min-width: 769px) {
  .en-hero {
    background-image: url('/images/common/hero-visual.webp');
  }
}
.en-eyebrow {
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin: 0 0 1.25rem;
}
.en-hero__h1 {
  font-size: clamp(2rem, 4.5vw, 3.25rem);
  font-weight: 600;
  line-height: 1.15;
  margin: 0 0 1.5rem;
  color: #fff;
}
.en-hero__lead {
  font-size: 1.125rem;
  line-height: 1.75;
  color: rgba(255,255,255,0.8);
  max-width: 640px;
  margin: 0 0 0.75rem;
}
.en-hero__sub {
  font-size: 0.9375rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.55);
  max-width: 580px;
  margin: 0 0 2rem;
}
.en-hero__actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

/* ═══════════════════════════════════════════════
   1b. STATS BAR
═══════════════════════════════════════════════ */
.en-stats-bar {
  background: #f1f5f9;
  border-bottom: 1px solid var(--color-border);
  padding: 1.25rem 0;
}
.en-stats {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0;
  flex-wrap: wrap;
}
.en-stat {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 0.5rem 2rem;
}
.en-stat--wide {
  flex: 1;
}
.en-stat__div {
  width: 1px;
  height: 2rem;
  background: var(--color-border);
  flex-shrink: 0;
}
.en-stat__num {
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.2;
}
.en-stat__label {
  font-size: 0.75rem;
  color: var(--color-text-muted);
  line-height: 1.3;
}
.en-stat__label--industries {
  font-size: 0.8125rem;
  font-weight: 500;
  color: var(--color-text-muted);
}
@media (max-width: 900px) {
  .en-stats { gap: 0; }
  .en-stat { padding: 0.4rem 1rem; }
  .en-stat__div { display: none; }
  .en-stat--wide { width: 100%; flex: none; padding-top: 0; }
}

/* ═══════════════════════════════════════════════
   2. PROBLEM
═══════════════════════════════════════════════ */
.en-problem__body {
  font-size: 1.0625rem;
  line-height: 1.8;
  color: var(--color-text-muted);
}
.en-problem__body p { margin: 0 0 1rem; }
.en-problem__body p:last-child { margin-bottom: 0; }

/* ═══════════════════════════════════════════════
   4. USE CASES
═══════════════════════════════════════════════ */
.en-use-cases {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 2.5rem;
}
.en-use-case {
  background: #f8f9fc;
  border: 1px solid var(--color-border);
  border-radius: 8px;
  padding: 2rem;
}
.en-use-case__num {
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  color: var(--color-primary);
  margin-bottom: 0.75rem;
}
.en-use-case__title {
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--color-text);
  margin: 0 0 0.75rem;
}
.en-use-case__body {
  font-size: 0.9375rem;
  line-height: 1.75;
  color: var(--color-text-muted);
  margin: 0;
}

/* ═══════════════════════════════════════════════
   5. CORE OFFER
═══════════════════════════════════════════════ */
.en-offer {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: start;
}
.en-offer__title {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 600;
  color: var(--color-text);
  margin: 0 0 0.5rem;
}
.en-offer__price {
  font-size: 1.125rem;
  font-weight: 700;
