---
// 売上の取りこぼし診断 — interactive flow: 12 questions → lead gate → result map.
// All quiz logic is client-side (static site). Lead capture posts the email
// directly to a dedicated, captcha-free HubSpot form via the Submissions API
// (no iframe, no reCAPTCHA), so submission is reliable and the result shows
// instantly. The diagnostic summary rides along in a hidden "message" field —
// it is never rendered to the user. Set HS_DIAGNOSTIC_FORM_ID below.
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
	title="売上の取りこぼし診断 | 全12問・約1分 | Consilegy"
	description="マーケ・営業・CSの「境目」を6つの観点で診断します。全12問・選択式・約1分。"
	lang="ja"
	noindex={true}
>

<section class="rd-stage">
	<div class="rd-container" id="rd-app">
		<noscript>
			<p style="padding: 2rem; text-align: center;">
				この診断はJavaScriptが必要です。ブラウザの設定をご確認ください。
			</p>
		</noscript>
	</div>
</section>

</BaseLayout>

<script>
	import { CATEGORIES, SIGNAL_META, signalOf, bandOf, patternOf } from '../../../lib/diagnostic-data';

	// ── Config ──────────────────────────────────────────────
	const HS_PORTAL_ID = '46498743';
	// Dedicated, captcha-free diagnostic form (Email + hidden "message"), submitted
	// via the Submissions API below. While empty, the diagnostic still works (the
	// result shows) but no lead is captured — fill in the GUID to turn capture on.
	const HS_DIAGNOSTIC_FORM_ID = 'df40a4b0-05e6-4fef-af58-633c398a619e';
	const BOOK_URL = '/free-consultation/';
	const CONTACT_URL = '/revops-assessment/';
	const STORAGE_KEY = 'rd-state-v1';

	// Flatten questions: [{catIndex, qIndex, text, options}]
	const FLAT = CATEGORIES.flatMap((c, ci) =>
		c.questions.map((q, qi) => ({ ci, qi, text: q.text, options: q.options, catName: c.name }))
	);
	const TOTAL_Q = FLAT.length;

	// ── State ───────────────────────────────────────────────
	interface State {
		step: 'quiz' | 'lead' | 'result';
		current: number;
		answers: (number | null)[]; // selected option index per flat question
		leadDone: boolean;
		email?: string;
	}

	function loadState(): State {
		try {
			const raw = sessionStorage.getItem(STORAGE_KEY);
			if (raw) {
				const s = JSON.parse(raw);
				if (Array.isArray(s.answers) && s.answers.length === TOTAL_Q) return s;
			}
		} catch { /* fresh start */ }
		return { step: 'quiz', current: 0, answers: Array(TOTAL_Q).fill(null), leadDone: false };
	}

	function saveState() {
		try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch { /* ignore */ }
	}

	let state = loadState();

	// ── GA4 (via GTM dataLayer) ─────────────────────────────
	function track(event: string, params: Record<string, unknown> = {}) {
		(window as any).dataLayer = (window as any).dataLayer || [];
		(window as any).dataLayer.push({ event, ...params });
	}

	function trackOnce(event: string, params: Record<string, unknown> = {}) {
		const key = `rd-evt-${event}`;
		try {
			if (sessionStorage.getItem(key)) return;
			sessionStorage.setItem(key, '1');
		} catch { /* still fire */ }
		track(event, params);
	}

	// ── Scoring ─────────────────────────────────────────────
	function categoryScores(): number[] {
		return CATEGORIES.map((c, ci) =>
			c.questions.reduce((sum, q, qi) => {
				const flatIdx = FLAT.findIndex((f) => f.ci === ci && f.qi === qi);
				const sel = state.answers[flatIdx];
				return sum + (sel !== null && sel !== undefined ? q.options[sel].score : 0);
			}, 0)
		);
	}

	function totalScore(): number {
		return categoryScores().reduce((a, b) => a + b, 0);
	}

	function summaryText(): string {
		const scores = categoryScores();
		const total = totalScore();
		const band = bandOf(total);
		const lines = CATEGORIES.map((c, i) => {
			const sig = SIGNAL_META[signalOf(scores[i])];
			return `${sig.emoji} ${c.name}: ${scores[i]}/4`;
		});
		return [
			'【売上の取りこぼし診断 結果】',
			`総合スコア: ${total}/24（${band.label}）`,
			...lines,
			'',
			'※このメッセージは診断結果から自動入力されています。',
		].join('\n');
	}

	// ── Rendering ───────────────────────────────────────────
	const app = document.getElementById('rd-app')!;

	function esc(s: string) {
		return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
	}

	function render() {
		saveState();
		if (state.step === 'quiz') renderQuiz();
		else if (state.step === 'lead') renderLead();
		else renderResult();
		window.scrollTo({ top: 0 });
	}

	function renderQuiz() {
		const q = FLAT[state.current];
		const n = state.current + 1;
		const progress = Math.round((state.current / TOTAL_Q) * 100);
		const selected = state.answers[state.current];

		app.innerHTML = `
			<div class="rd-progress">
				<div class="rd-progress-meta">
					<span class="rd-progress-label">${esc(q.catName)}</span>
					<span class="rd-progress-count">Q${n} / ${TOTAL_Q}</span>
				</div>
				<div class="rd-progress-bar"><div class="rd-progress-fill" style="width:${progress}%"></div></div>
			</div>
			<h1 class="rd-question">${esc(q.text)}</h1>
			<div class="rd-options">
				${q.options
					.map(
						(o, i) => `
					<button type="button" class="rd-option${selected === i ? ' is-selected' : ''}" data-opt="${i}">
						${esc(o.label)}
					</button>`
					)
					.join('')}
			</div>
			<div class="rd-nav">
				${state.current > 0 ? '<button type="button" class="rd-back" data-back>← 前の質問へ</button>' : '<span></span>'}
			</div>
		`;

		app.querySelectorAll<HTMLButtonElement>('.rd-option').forEach((btn) => {
			btn.addEventListener('click', () => {
				state.answers[state.current] = Number(btn.dataset.opt);
				if (state.current < TOTAL_Q - 1) {
					state.current += 1;
				} else {
					track('diagnostic_complete', { score_total: totalScore() });
					state.step = state.leadDone ? 'result' : 'lead';
				}
				render();
			});
		});

		app.querySelector('[data-back]')?.addEventListener('click', () => {
			state.current = Math.max(0, state.current - 1);
			render();
		});
	}

	function renderLead() {
		app.innerHTML = `
			<div class="rd-lead-head">
				<p class="rd-lead-eyebrow">診断完了</p>
				<h1 class="rd-lead-title">結果の表示まで、あと1ステップ</h1>
				<p class="rd-lead-desc">
					メールアドレスをご入力ください。送信後すぐに「取りこぼしマップ」が表示されます。
				</p>
			</div>
			<form class="rd-lead-form" id="rd-lead-form" novalidate>
				<label class="rd-field">
					<span class="rd-field-label">メールアドレス</span>
					<input type="email" name="email" inputmode="email" autocomplete="email"
						required placeholder="you@company.com" class="rd-input" />
				</label>
				<label class="rd-field">
					<span class="rd-field-label">従業員規模</span>
					<select name="employee_size" required class="rd-input rd-select">
						<option value="">選択してください</option>
						<option value="1-50">1〜50名</option>
						<option value="51-100">51〜100名</option>
						<option value="101-300">101〜300名</option>
						<option value="301-1000">301〜1000名</option>
						<option value="1001+">1001名以上</option>
					</select>
				</label>
				<label class="rd-field">
					<span class="rd-field-label">業種<span class="rd-field-opt">（任意）</span></span>
					<select name="industry" class="rd-input rd-select">
						<option value="">選択してください</option>
						<option value="saas">SaaS・IT</option>
						<option value="manufacturing">製造</option>
						<option value="wholesale">商社・卸</option>
						<option value="prof_services">専門サービス</option>
						<option value="retail_ec">小売・EC</option>
						<option value="other">その他</option>
					</select>
				</label>
				<fieldset class="rd-field rd-fieldset">
					<span class="rd-field-label">使っているツール<span class="rd-field-opt">（任意・複数可）</span></span>
					<div class="rd-check-grid">
						<label class="rd-check"><input type="checkbox" name="current_tools" value="hubspot" /> HubSpot</label>
						<label class="rd-check"><input type="checkbox" name="current_tools" value="salesforce" /> Salesforce</label>
						<label class="rd-check"><input type="checkbox" name="current_tools" value="kintone" /> kintone</label>
						<label class="rd-check"><input type="checkbox" name="current_tools" value="zoho" /> Zoho</label>
						<label class="rd-check"><input type="checkbox" name="current_tools" value="ma_other" /> MA各種</label>
						<label class="rd-check"><input type="checkbox" name="current_tools" value="bi" /> BIツール</label>
						<label class="rd-check"><input type="checkbox" name="current_tools" value="excel_only" /> Excel・スプレッドシートのみ</label>
						<label class="rd-check"><input type="checkbox" name="current_tools" value="none" /> 特に無い</label>
					</div>
				</fieldset>
				<p class="rd-lead-error" id="rd-lead-error" role="alert" hidden></p>
				<button type="submit" class="rd-lead-submit">結果を見る →</button>
			</form>
			<p class="rd-privacy">
				ご入力いただいた情報は、診断結果のご案内およびサービスのご案内に利用します。
				詳細は<a href="/privacy-policy/" target="_blank" rel="noopener">プライバシーポリシー</a>をご確認ください。
			</p>
		`;

		const form = document.getElementById('rd-lead-form') as HTMLFormElement;
		const errEl = document.getElementById('rd-lead-error')!;
		const input = form.querySelector<HTMLInputElement>('input[name="email"]')!;
		const btn = form.querySelector<HTMLButtonElement>('.rd-lead-submit')!;

		const showError = (msg: string) => { errEl.textContent = msg; errEl.hidden = false; };

		const sizeSel = form.querySelector<HTMLSelectElement>('select[name="employee_size"]')!;
		const indSel = form.querySelector<HTMLSelectElement>('select[name="industry"]')!;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const email = input.value.trim();
			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				showError('メールアドレスの形式をご確認ください。');
				input.focus();
				return;
			}
			if (!sizeSel.value) {
				showError('従業員規模をお選びください。');
				sizeSel.focus();
				return;
			}
			const tools = Array.from(form.querySelectorAll<HTMLInputElement>('input[name="current_tools"]:checked')).map((el) => el.value);
			const extra: Record<string, string> = {};
			if (sizeSel.value) extra.employee_size = sizeSel.value;
			if (indSel.value) extra.consilegy_industry = indSel.value;
			if (tools.length) extra.current_tools = tools.join(';');
			errEl.hidden = true;
			btn.disabled = true;
			btn.textContent = '送信中…';
			try {
				await submitLead(email, extra);
				track('lead_submit', { employee_size: extra.employee_size ?? '', industry: extra.consilegy_industry ?? '', tools_count: tools.length });
				state.leadDone = true;
				state.email = email;
				state.step = 'result';
				render();
			} catch (err) {
				console.error(err);
				btn.disabled = false;
				btn.textContent = '結果を見る →';
				showError('送信に失敗しました。通信環境をご確認のうえ、もう一度お試しください。');
			}
		});
	}

	function getCookie(name: string): string | undefined {
		return document.cookie.split('; ').find((c) => c.startsWith(name + '='))?.split('=')[1];
	}

	// Post the lead straight to a dedicated, captcha-free HubSpot form via the
	// Submissions API — no iframe, no reCAPTCHA. The diagnostic summary goes into
	// the hidden "message" field; it is never shown on screen.
	async function submitLead(email: string, extra: Record<string, string> = {}): Promise<void> {
		if (!HS_DIAGNOSTIC_FORM_ID) {
			// Form not configured yet — don't block the user from seeing their result.
			console.warn('HS_DIAGNOSTIC_FORM_ID is not set; skipping lead capture.');
			return;
		}
		const hutk = getCookie('hubspotutk');
		const fields = [
			{ name: 'email', value: email },
			{ name: 'message', value: summaryText() },
		];
		for (const [name, value] of Object.entries(extra)) {
			if (value) fields.push({ name, value });
		}
		const payload = {
			fields,
			context: {
				pageUri: location.href,
				pageName: '売上の取りこぼし診断',
				...(hutk ? { hutk } : {}),
			},
		};
		const res = await fetch(
			`https://api.hsforms.com/submissions/v3/integration/submit/${HS_PORTAL_ID}/${HS_DIAGNOSTIC_FORM_ID}`,
			{
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			}
		);
		if (!res.ok) {
			const text = await res.text().catch(() => '');
			throw new Error(`HubSpot submit failed: ${res.status} ${text}`);
		}
	}

	function renderResult() {
		const scores = categoryScores();
		const total = totalScore();
		const band = bandOf(total);

		// Leaking categories (yellow/red), worst first.
		const leaks = CATEGORIES.map((c, i) => ({ c, score: scores[i], signal: signalOf(scores[i]) }))
			.filter((x) => x.signal !== 'green')
			.sort((a, b) => b.score - a.score);
		const worst = leaks[0];

		// Leak pattern: which red categories overlap (red = score 4).
		const redIds = CATEGORIES.filter((c, i) => scores[i] >= 4).map((c) => c.id);
		const pattern = worst ? patternOf(redIds, worst.c.id) : null;

		app.innerHTML = `
			<div class="rd-result-head">
				<p class="rd-result-eyebrow">売上の取りこぼし診断 結果</p>
				<div class="rd-result-score">
					<span class="rd-score-num">${total}</span><span class="rd-score-den">/ 24</span>
					<span class="rd-score-band rd-band-${band.label === '健全' ? 'green' : band.label === '注意' ? 'yellow' : 'red'}">${esc(band.label)}</span>
				</div>
				<h1 class="rd-result-headline">${esc(band.headline)}</h1>
				<p class="rd-score-note">スコアは低いほど健全です（取りこぼしリスクの合計）。</p>
			</div>

			${pattern ? `
			<div class="rd-pattern">
				<p class="rd-pattern-label">あなたの取りこぼしの型</p>
				<h2 class="rd-pattern-headline">${esc(pattern.headline)}</h2>
				<p class="rd-pattern-body">${esc(pattern.body)}</p>
			</div>
			` : ''}

			<div class="rd-map">
				${CATEGORIES.map((c, i) => {
					const sig = SIGNAL_META[signalOf(scores[i])];
					return `
					<div class="rd-map-card rd-sig-${signalOf(scores[i])}">
						<span class="rd-map-emoji">${sig.emoji}</span>
						<div>
							<span class="rd-map-name">${esc(c.name)}</span>
							<span class="rd-map-state">${sig.label} — ${scores[i]}/4</span>
						</div>
					</div>`;
				}).join('')}
			</div>

			${leaks.length > 0 ? `
			<div class="rd-insights">
				<h2 class="rd-insights-title">取りこぼしている境目</h2>
				${leaks.map((x) => `
					<div class="rd-insight">
						<span class="rd-insight-emoji">${SIGNAL_META[x.signal].emoji}</span>
						<div>
							<span class="rd-insight-cat">${esc(x.c.name)}</span>
							<p class="rd-insight-text">${esc(x.c.insight)}</p>
							<p class="rd-insight-quant">${esc(x.c.quant)}</p>
						</div>
					</div>`).join('')}
			</div>

			<div class="rd-firststep">
				<p class="rd-firststep-label">最初の一手</p>
				<p class="rd-firststep-text">${esc(worst.c.firstStep)}</p>
			</div>
			` : `
			<div class="rd-firststep">
				<p class="rd-firststep-label">次の一手</p>
				<p class="rd-firststep-text">取りこぼしは小さい状態です。次は「拡大」設計 — 受注後のLTV最大化と再現性の強化に投資する段階です。</p>
			</div>
			`}

			<div class="rd-cta">
				<a href="${BOOK_URL}" class="rd-cta-primary" data-cta="book">この取りこぼしを「直す」なら｜30分無料相談を予約する →</a>
				<p class="rd-cta-note">診断結果をもとに、課題の輪郭と次の一手を30分で整理します。オンライン・完全無料。</p>
				<a href="${CONTACT_URL}" class="rd-cta-secondary" data-cta="contact">収益構造の現状分析（有償）の内容を見る</a>
			</div>

			<div class="rd-probe" id="rd-probe">
				<p class="rd-probe-q">あと1問だけ（任意）：この取りこぼしを<strong>毎月自動で可視化</strong>できるダッシュボードがあれば、使いたいですか？</p>
				<div class="rd-probe-opts">
					<label class="rd-check"><input type="radio" name="dashboard_demand" value="want" /> 使いたい</label>
					<label class="rd-check"><input type="radio" name="dashboard_demand" value="conditional" /> 条件次第</label>
					<label class="rd-check"><input type="radio" name="dashboard_demand" value="not_now" /> いまは不要</label>
				</div>
				<input type="text" id="rd-pain" class="rd-input" maxlength="120" placeholder="いま一番困っていることを一言で（任意）" />
				<button type="button" id="rd-probe-send" class="rd-probe-send">送信する</button>
				<p class="rd-probe-thanks" id="rd-probe-thanks" hidden>ありがとうございます。診断当日により具体的にお話しできます。</p>
			</div>

			<p class="rd-retry"><button type="button" data-retry>もう一度診断する</button></p>
		`;

		track('result_view', { score_total: total, band: band.label, pattern_id: pattern?.id ?? 'none' });

		app.querySelector('[data-cta="book"]')?.addEventListener('click', () => track('cta_book_click'));
		app.querySelector('[data-cta="contact"]')?.addEventListener('click', () => track('cta_contact_click'));

		app.querySelector('#rd-probe-send')?.addEventListener('click', async () => {
			const probe = app.querySelector<HTMLElement>('#rd-probe')!;
			const demand = probe.querySelector<HTMLInputElement>('input[name="dashboard_demand"]:checked')?.value ?? '';
			const pain = probe.querySelector<HTMLInputElement>('#rd-pain')!.value.trim();
			if (!demand && !pain) return;
			const extra: Record<string, string> = {};
			if (demand) extra.dashboard_demand = demand;
			if (pain) extra.pain_point = pain;
			const sendBtn = probe.querySelector<HTMLButtonElement>('#rd-probe-send')!;
			sendBtn.disabled = true;
			sendBtn.textContent = '送信中…';
			try {
				if (state.email) await submitLead(state.email, extra);
				track('probe_submit', { dashboard_demand: demand });
				probe.querySelector<HTMLElement>('#rd-probe-thanks')!.hidden = false;
				sendBtn.hidden = true;
			} catch (err) {
				console.error(err);
				sendBtn.disabled = false;
				sendBtn.textContent = '送信する';
			}
		});
		app.querySelector('[data-retry]')?.addEventListener('click', () => {
			state = { step: 'quiz', current: 0, answers: Array(TOTAL_Q).fill(null), leadDone: state.leadDone };
			render();
		});
	}

	// ── Boot ────────────────────────────────────────────────
	trackOnce('diagnostic_start');
	render();
</script>

<style>
.rd-stage {
	min-height: calc(100vh - 58px);
	background:
		radial-gradient(720px 420px at 90% 0%, rgba(59,130,246,0.08), transparent 60%),
		linear-gradient(180deg, #F7F8FC 0%, #EFF2F9 100%);
	padding-block: 2.5rem 4rem;
}
.rd-container { max-width: 640px; margin-inline: auto; padding-inline: 1.25rem; }

/* Progress */
:global(.rd-progress) { margin-bottom: 2rem; }
:global(.rd-progress-meta) { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.625rem; }
:global(.rd-progress-label) {
	font-size: 0.625rem; font-weight: 500; color: var(--color-primary);
	letter-spacing: 0.1em; text-transform: uppercase;
}
:global(.rd-progress-count) { font-size: 0.75rem; color: var(--color-text-muted); font-variant-numeric: tabular-nums; }
:global(.rd-progress-bar) { height: 4px; background: rgba(30,64,175,0.1); border-radius: 2px; overflow: hidden; }
:global(.rd-progress-fill) { height: 100%; background: var(--color-primary); border-radius: 2px; transition: width 0.25s ease; }

/* Question */
:global(.rd-question) {
	font-size: clamp(1.125rem, 4vw, 1.5rem); font-weight: 600;
	line-height: 1.55; letter-spacing: 0; color: var(--color-text);
	margin: 0 0 1.75rem;
}
:global(.rd-options) { display: flex; flex-direction: column; gap: 0.75rem; }
:global(.rd-option) {
	display: block; width: 100%; text-align: left;
	background: var(--glass-bg);
	backdrop-filter: var(--glass-blur);
	-webkit-backdrop-filter: var(--glass-blur);
	border: 1px solid var(--glass-border);
	border-radius: var(--radius);
	box-shadow: var(--glass-shadow);
	padding: 1.125rem 1.25rem; min-height: 56px;
	font-size: 0.9375rem; font-weight: 500; color: var(--color-text);
	font-family: inherit; line-height: 1.6; cursor: pointer;
	transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
}
