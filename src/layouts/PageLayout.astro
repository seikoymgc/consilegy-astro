---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description: string;
	canonical?: string;
	ogImage?: string;
	noindex?: boolean;
	lang?: 'ja' | 'en';
}

const seo = Astro.props;
const htmlLang = seo.lang ?? 'ja';
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<SEO {...seo} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="stylesheet" href="/css/theme-legacy.css" />
	</head>
	<body class="page">
		<Header />
		<main id="main-content">
			<article class="wp-block-post-content has-global-padding entry-content is-layout-constrained">
				<slot />
			</article>
		</main>
		<Footer />
	</body>
</html>
