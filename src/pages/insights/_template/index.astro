---
// ============================================================
// Insights記事テンプレート（LLMO対応版・2026-06-12作成）
//
// 使い方:
//   1. このフォルダごと src/pages/insights/<slug>/ にコピー
//      （_template はルーティング除外のため公開されない）
//   2. 「TODO」を全部埋める（grep TODO で漏れ確認）
//   3. アイキャッチ: scripts/generate-eyecatches.mjs で生成
//
// LLMO必須要素（削らないこと）:
//   - 定義ブロック: 冒頭H2直下に160〜200字の自己完結した定義段落。
//     AIが引用する最小単位。主語を省略しない・指示語を使わない
//   - 記事末FAQ: 3〜5問。faqItems に書けば本文とスキーマ両方に反映される
//   - author は Person（山口聖子）固定。Organizationに戻さない
// ============================================================
import NewsletterSidebar from '../../../components/NewsletterSidebar.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const slug = 'TODO-slug'; // 例: why-crm-adoption-fails（フォルダ名と一致させる）
const pubDate = 'TODO-2026-MM-DD';
const pubDateDisplay = 'TODO 2026年M月D日';

const title = 'TODO 記事タイトル（32字前後・「なぜ」「〜とは」型）';
const metaTitle = 'TODO 記事タイトル｜サブコピー | Consilegy';
const metaDescription = 'TODO メタディスクリプション（100〜120字。検索結果とAI要約の両方で使われる）';
const category = 'TODO カテゴリ'; // 例: CRM / RevOps / Revenue Architecture

// ── 記事末FAQ（3〜5問・LLMO必須）
// 質問は「〜とは？」「〜の違いは？」「いつ〜すべき？」など検索される形式で。
// 回答は2〜4文で自己完結させる（この回答だけ読んでも意味が通ること）。
const faqItems = [
	{ q: 'TODO 質問1', a: 'TODO 回答1' },
	{ q: 'TODO 質問2', a: 'TODO 回答2' },
	{ q: 'TODO 質問3', a: 'TODO 回答3' },
];

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: metaDescription,
	datePublished: pubDate,
	dateModified: pubDate,
	author: { '@type': 'Person', name: '山口聖子', alternateName: 'Seiko Yamaguchi', jobTitle: 'Revenue Architect', url: 'https://consilegy.com/company/', worksFor: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' } },
	publisher: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	url: `https://consilegy.com/insights/${slug}/`,
	inLanguage: 'ja',
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map(({ q, a }) => ({
		'@type': 'Question',
		name: q,
		acceptedAnswer: { '@type': 'Answer', text: a },
	})),
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://consilegy.com/' },
		{ '@type': 'ListItem', position: 2, name: 'コラム', item: 'https://consilegy.com/insights/' },
		{ '@type': 'ListItem', position: 3, name: title, item: `https://consilegy.com/insights/${slug}/` },
	],
};
---

<BaseLayout
	title={metaTitle}
	description={metaDescription}
	lang="ja"
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	</Fragment>

<div class="article-wrap">

	<!-- ===== ARTICLE HEADER ===== -->
	<header class="article-head container">
		<nav class="breadcrumb" aria-label="パンくずリスト">
			<a href="/">ホーム</a>
			<span aria-hidden="true">›</span>
			<a href="/insights/">コラム</a>
			<span aria-hidden="true">›</span>
			<span aria-current="page">{title}</span>
		</nav>
		<div class="article-meta">
			<span class="article-cat">{category}</span>
		</div>
		<h1>{title}</h1>
		<p class="article-desc">TODO リード文（具体的な数字・場面で始める。メタディスクリプションのコピペにしない）</p>
	</header>

	<!-- ===== ARTICLE BODY ===== -->
	<article class="article-body container" id="article">
		<div class="article-eyecatch">
			<img
				src={`/images/insights/${slug}.svg`}
				alt=""
				width="1200"
				height="630"
				class="article-eyecatch__img"
				loading="eager"
				aria-hidden="true"
			/>
		</div>

		<!-- ★ 定義ブロック（LLMO必須・削除禁止）────────────────
		     160〜200字・1段落で自己完結。この段落だけ切り取られても
		     意味が通ること。「TODOとは、〜です。」で始める。 -->
		<section class="article-section article-def" id="definition">
			<h2>TODO（記事の中心概念）とは</h2>
			<p class="article-def__text"><strong>TODO（中心概念）とは</strong>、TODO 160〜200字の定義文。主語を省略しない。指示語（これ・それ）を使わない。1段落で完結させる。</p>
		</section>

		<hr class="article-hr" />

		<!-- はじめに: 具体的なエピソード・数字で始める -->
		<section class="article-section">
			<h2>TODO 導入見出し（具体的な場面・数字）</h2>
			<p>TODO 本文</p>
			<div class="article-callout">
				<p>TODO この記事の核心を1〜2文で（コールアウトはAIに拾われやすい）</p>
			</div>
		</section>

		<hr class="article-hr" />

		<!-- 本文: 必要なだけ article-section を繰り返す -->
		<section class="article-section">
			<h2>TODO 見出し（「〜とは」「なぜ〜か」「〜との違い」型を優先）</h2>
			<p>TODO 本文</p>
			<div class="article-numbered">
				<div class="article-numbered__item">
					<p class="article-numbered__num">01</p>
					<h3>TODO 小見出し</h3>
					<p>TODO 本文</p>
				</div>
				<div class="article-numbered__item">
					<p class="article-numbered__num">02</p>
					<h3>TODO 小見出し</h3>
					<p>TODO 本文</p>
				</div>
			</div>
		</section>

		<hr class="article-hr" />

		<!-- まとめ -->
		<section class="article-section">
			<h2>まとめ：TODO（結論を見出しに書く）</h2>
			<p>TODO まとめ本文</p>
		</section>

		<hr class="article-hr" />

		<!-- ★ 記事末FAQ（LLMO必須・faqItems と自動同期） -->
		<section class="article-section article-faq" id="faq">
			<h2>よくある質問</h2>
			<div class="faq-list">
				{faqItems.map(({ q, a }) => (
					<details class="faq-item">
						<summary class="faq-q">{q}</summary>
						<p class="faq-a">{a}</p>
					</details>
				))}
			</div>
		</section>

		<p class="article-pubdate">公開日：{pubDateDisplay}</p>
	</article>

	<!-- ===== RELATED SERVICES ===== -->
	<nav class="article-services" aria-label="関連サービス">
		<h2 class="article-services__heading">関連サービス</h2>
		<div class="article-services__grid">
		<a href="TODO-/services/xxx/" class="article-services__card">
				<span class="article-services__cat">サービス</span>
				<span class="article-services__title">TODO サービス名</span>
				<span class="article-services__arrow">→</span>
			</a>
		<a href="TODO-/services/yyy/" class="article-services__card">
				<span class="article-services__cat">サービス</span>
				<span class="article-services__title">TODO サービス名</span>
				<span class="article-services__arrow">→</span>
			</a>
		</div>
	</nav>
	<NewsletterSidebar />

	<!-- ===== RELATED LINKS ===== -->
	<aside class="article-related container">
		<p class="article-related__label">関連コンテンツ</p>
		<div class="article-related__grid">
			<a href="/revenue-architecture/" class="article-related__card">
				<p class="article-related__card-cat">概念解説</p>
				<p class="article-related__card-title">Revenue Architecture（レベニューアーキテクチャ）とは</p>
				<span class="article-related__card-arrow">→</span>
			</a>
			<a href="/about-revops/" class="article-related__card">
				<p class="article-related__card-cat">概念解説</p>
				<p class="article-related__card-title">RevOps（レベニューオペレーション）とは</p>
				<span class="article-related__card-arrow">→</span>
			</a>
			<a href="TODO-/insights/xxx/" class="article-related__card">
				<p class="article-related__card-cat">関連記事</p>
				<p class="article-related__card-title">TODO 関連記事タイトル</p>
				<span class="article-related__card-arrow">→</span>
			</a>
		</div>
	</aside>

	<!-- ===== CTA ===== -->
	<section class="article-cta">
		<div class="container">
			<div class="article-cta__body">
				<h2>Consilegyでは現在、Revenue Architectureの観点から、<br class="br-pc" />TODO（記事テーマ）の課題を整理する30分無料相談を実施しています。</h2>
				<ul class="article-cta__list">
					<li>TODO 読者の悩み1</li>
					<li>TODO 読者の悩み2</li>
					<li>TODO 読者の悩み3</li>
				</ul>
				<p class="article-cta__note">ツールの前に、「設計図」から整理することが、最短の改善ルートです。</p>
				<div class="article-cta__actions">
					<a href="/free-consultation/" class="btn btn--cta-primary">30分無料相談を予約する →</a>
					<a href="TODO-/services/xxx/" class="btn btn--cta-ghost">TODO サービス名を見る</a>
				</div>
			</div>
		</div>
	</section>

</div>
</BaseLayout>

<style>
	/* ── 定義ブロック（LLMO） ─── */
	.article-def__text {
		background: var(--color-bg-soft, #f8fafc);
		border-left: 4px solid var(--color-primary, #1e40af);
		border-radius: 0 8px 8px 0;
		padding: 1.25rem 1.5rem;
		font-size: 1rem;
		line-height: 1.85;
		color: var(--color-navy, #0f172a);
	}

	/* ── 記事末FAQ（LLMO） ─── */
	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.faq-item {
		border: 1px solid var(--color-border, #e2e8f0);
		border-radius: 8px;
		background: #fff;
		overflow: hidden;
	}

	.faq-q {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--color-navy, #0f172a);
		padding: 1.1rem 1.25rem;
		cursor: pointer;
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		line-height: 1.5;
	}

	.faq-q::-webkit-details-marker { display: none; }

	.faq-q::after {
		content: '+';
		font-size: 1.25rem;
		font-weight: 300;
		color: var(--color-primary, #1e40af);
		flex-shrink: 0;
		transition: transform 0.2s;
	}

	details[open] .faq-q::after { transform: rotate(45deg); }

	.faq-a {
		font-size: 0.9rem;
		line-height: 1.8;
		color: var(--color-charcoal, #334155);
		padding: 0 1.25rem 1.25rem;
		margin: 0;
	}

	/* ── Eyecatch ─── */
	.article-eyecatch {
		margin-bottom: 2rem;
		border-radius: 8px;
		overflow: hidden;
		max-height: 360px;
	}
	.article-eyecatch__img {
		width: 100%; height: auto; display: block;
		max-height: 360px; object-fit: cover;
	}
	/* ── Layout ────────────────────────────────────────────── */
	.article-wrap { background: #fff; }

	.container {
		max-width: 800px;
		margin-inline: auto;
		padding-inline: var(--space-md, 1.5rem);
	}

	.br-pc { display: inline; }

	/* ── Breadcrumb ────────────────────────────────────────── */
	.breadcrumb {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.4em;
		font-size: 0.8rem;
		color: var(--color-muted, #64748b);
		margin-bottom: 2rem;
	}

	.breadcrumb a { color: inherit; text-decoration: none; }
	.breadcrumb a:hover { color: var(--color-primary, #1e40af); }

	/* ── Article header ────────────────────────────────────── */
	.article-head {
		padding-top: 3rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--color-border, #e2e8f0);
	}

	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
		flex-wrap: wrap;
	}

	.article-cat {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-primary, #1e40af);
		background: rgba(30, 64, 175, 0.07);
		padding: 0.2em 0.7em;
		border-radius: 4px;
	}

	.article-date,
	.article-read {
		font-size: 0.8rem;
		color: var(--color-muted, #64748b);
	}

	.article-date::before {
		content: '';
		display: inline-block;
		width: 1px;
		height: 0.9em;
		background: var(--color-border, #e2e8f0);
		margin-right: 0.75rem;
		vertical-align: middle;
	}

	.article-head h1 {
		font-size: clamp(1.5rem, 3vw, 2.1rem);
		font-weight: 600;
		color: var(--color-navy, #0f172a);
		line-height: 1.35;
		margin: 0 0 1rem;
	}

	.article-desc {
		font-size: 1rem;
		line-height: 1.75;
		color: var(--color-charcoal, #334155);
		margin: 0;
	}

	/* ── Article body ──────────────────────────────────────── */
	.article-body { padding-block: 3rem; }

	.article-section { margin-bottom: 0; }

	.article-section h2 {
		font-size: clamp(1.15rem, 2.2vw, 1.4rem);
		font-weight: 600;
		color: var(--color-navy, #0f172a);
		margin: 0 0 1.25rem;
		line-height: 1.45;
		padding-bottom: 0.6rem;
		border-bottom: 2px solid var(--color-border, #e2e8f0);
	}

	.article-section h3 {
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-navy, #0f172a);
		margin: 2rem 0 0.75rem;
	}

	.article-section p {
		font-size: 0.975rem;
		line-height: 1.9;
		color: var(--color-charcoal, #334155);
		margin: 0 0 1rem;
	}

	.article-section ul {
		margin: 0 0 1.25rem;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.article-section ul li {
		padding-left: 1.25rem;
		position: relative;
		font-size: 0.95rem;
		line-height: 1.7;
		color: var(--color-charcoal, #334155);
	}

	.article-section ul li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.65em;
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: var(--color-primary, #1e40af);
		opacity: 0.5;
	}

	.article-hr {
		border: none;
		border-top: 1px solid var(--color-border, #e2e8f0);
		margin: 3rem 0;
	}

	/* ── Callout ───────────────────────────────────────────── */
	.article-callout {
		background: var(--color-bg-soft, #f8fafc);
		border-left: 4px solid var(--color-primary, #1e40af);
		border-radius: 0 8px 8px 0;
		padding: 1.1rem 1.5rem;
		margin: 1.5rem 0;
	}

	.article-callout p {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.8;
		color: var(--color-navy, #0f172a);
	}

	/* ── Numbered blocks ───────────────────────────────────── */
	.article-numbered {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-top: 1.5rem;
	}

	.article-numbered__item {
		border: 1px solid var(--color-border, #e2e8f0);
		border-radius: 8px;
		padding: 1.5rem;
		background: #fff;
	}

	.article-numbered__num {
		font-size: 0.7rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		color: var(--color-primary, #1e40af);
		margin: 0 0 0.5rem;
	}

	.article-numbered__item h3 {
		margin: 0 0 0.75rem;
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-navy, #0f172a);
	}

	.article-numbered__item p {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.8;
		color: var(--color-charcoal, #334155);
	}

	/* ── Table ─────────────────────────────────────────────── */
	.article-table-wrap {
		overflow-x: auto;
		margin: 1.5rem 0;
		border: 1px solid var(--color-border, #e2e8f0);
		border-radius: 8px;
	}

	.article-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
	}

	.article-table thead th {
		padding: 0.75rem 1.25rem;
		background: var(--color-navy, #0f172a);
		color: #fff;
		font-weight: 700;
		text-align: left;
		white-space: nowrap;
	}

	.article-table tbody td {
		padding: 0.75rem 1.25rem;
		border-bottom: 1px solid var(--color-border, #e2e8f0);
		color: var(--color-charcoal, #334155);
		line-height: 1.6;
	}

	.article-table tbody tr:last-child td { border-bottom: none; }

	.article-table tbody td:first-child {
		font-weight: 700;
		color: var(--color-navy, #0f172a);
		white-space: nowrap;
		border-right: 1px solid var(--color-border, #e2e8f0);
	}

	/* ── Related ───────────────────────────────────────────── */
	.article-related {
		padding-block: 2.5rem 3rem;
		border-top: 1px solid var(--color-border, #e2e8f0);
	}

	.article-related__label {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted, #64748b);
		margin: 0 0 1rem;
	}

	.article-related__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
		gap: 0.75rem;
	}

	.article-related__card {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		padding: 1rem 1.25rem;
		border: 1px solid var(--color-border, #e2e8f0);
		border-radius: 8px;
		text-decoration: none;
		transition: border-color 0.15s, box-shadow 0.15s;
	}

	.article-related__card:hover {
		border-color: var(--color-primary, #1e40af);
		box-shadow: 0 2px 10px rgba(30, 64, 175, 0.07);
	}

	.article-related__card-cat {
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-primary, #1e40af);
		margin: 0;
	}

	.article-related__card-title {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--color-navy, #0f172a);
		margin: 0;
		line-height: 1.45;
	}

	.article-related__card-arrow {
		font-size: 0.85rem;
		color: var(--color-primary, #1e40af);
		margin-top: 0.25rem;
	}

	/* ── CTA ───────────────────────────────────────────────── */
	.article-cta {
		padding-block: 4rem;
		background:
			radial-gradient(800px 360px at 85% -5%, rgba(124,92,191,0.35), transparent 55%),
			linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%);
	}

	.article-cta__body {
		max-width: 700px;
		margin-inline: auto;
		text-align: center;
	}

	.article-cta__body h2 {
		font-size: clamp(1.2rem, 2.5vw, 1.65rem);
		font-weight: 600;
		color: #fff;
		line-height: 1.5;
		margin: 0 0 1.5rem;
	}

	.article-cta__list {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		margin: 0 auto 1.5rem;
		padding: 0;
		list-style: none;
		text-align: left;
		max-width: 420px;
	}

	.article-cta__list li {
		font-size: 0.875rem;
		color: rgba(255,255,255,0.85);
		padding-left: 1.1rem;
		position: relative;
		line-height: 1.6;
	}

	.article-cta__list li::before {
		content: '·';
		position: absolute;
