---
interface Props {
	title: string;
	description: string;
	href?: string;
	meta?: string;
	imageSrc?: string;
	imageAlt?: string;
	moreLabel?: string;
}

const { title, description, href, meta, imageSrc, imageAlt = '', moreLabel = '詳しく見る' } = Astro.props;
---

{
	href ? (
		<a class:list={['card', 'card--link']} href={href}>
			{imageSrc && (
				<div class="card__image">
					<img src={imageSrc} alt={imageAlt} width="480" height="280" loading="lazy" />
				</div>
			)}
			<div class="card__body">
				{meta && <p class="card__meta">{meta}</p>}
				<h3 class="card__title">{title}</h3>
				<p class="card__desc">{description}</p>
				<span class="card__more">{moreLabel} →</span>
			</div>
		</a>
	) : (
		<div class="card">
			{imageSrc && (
				<div class="card__image">
					<img src={imageSrc} alt={imageAlt} width="480" height="280" loading="lazy" />
				</div>
			)}
			<div class="card__body">
				{meta && <p class="card__meta">{meta}</p>}
				<h3 class="card__title">{title}</h3>
				<p class="card__desc">{description}</p>
			</div>
		</div>
	)
}

<style>
	.card {
		display: flex;
		flex-direction: column;
		height: 100%;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: calc(var(--radius) * 2);
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		color: inherit;
		transition: border-color 0.15s ease, box-shadow 0.2s ease, transform 0.2s ease;
	}

	.card--link:hover {
		border-color: rgba(30, 64, 175, 0.3);
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}

	.card__image img {
		width: 100%;
		height: 200px;
		object-fit: cover;
	}

	.card__body {
		padding: var(--space-md);
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		flex: 1;
	}

	.card__meta {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 700;
		color: var(--color-text-muted);
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.card__title {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.4;
	}

	.card__desc {
		margin: 0;
		color: #475569;
		line-height: 1.65;
		font-size: 0.95rem;
		flex: 1;
	}

	.card__more {
		margin-top: var(--space-sm);
		font-weight: 600;
		color: var(--color-primary);
		font-size: 0.9rem;
	}
</style>
