---
/**
 * EN Privacy Policy: /en/privacy-policy/
 *
 * This is the canonical English Privacy Policy page.
 * Legacy URL /en/27775-2/ redirects here via public/.htaccess.
 *
 * Content sourced from WordPress page ID 27775 (slug: 27775-2).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Privacy Policy';
const description =
  'Consilegy LLC Privacy Policy — how we handle personal information for our website and related services in Japan.';
const canonical = '/en/privacy-policy/';
---

<BaseLayout title={title} description={description} canonical={canonical} lang="en">
  <main class="content-page">
    <section class="section">
      <div class="container article-container">
        <p class="eyebrow">EN / Legal</p>
        <h1>{title}</h1>
        <div class="wp-content privacy-content">

          <p class="updated">Last Updated: 2025-08-17</p>

          <p>This Policy explains how Consilegy LLC ("we") handles personal information for our website
          and related services in Japan. It includes disclosures related to Google Tag Manager (GTM)
          and HubSpot. Overseas regimes are not covered here.</p>

          <h2>1. Scope</h2>
          <p>Applies to users of our Services in Japan and covers cookies, tags, pixels, and similar technologies.</p>

          <h2>2. Information We Collect</h2>

          <h3>2.1 Provided by you</h3>
          <ul>
            <li>Contact forms, downloads, event registrations: name, company, title, email, phone, inquiry details.</li>
            <li>Newsletter subscriptions and chat: email address and chat content.</li>
          </ul>

          <h3>2.2 Collected automatically</h3>
          <ul>
            <li>Device/browser information, IP address, referrer, pages viewed, time on page, click history.</li>
            <li>Identifiers via cookies and similar technologies (see Section 4).</li>
          </ul>

          <h2>3. Purposes of Use</h2>
          <ul>
            <li>Responding to inquiries and providing requested materials.</li>
            <li>Operating, maintaining, and improving the Services.</li>
            <li>Event invitations and newsletters where you agree.</li>
            <li>Marketing automation for nurturing, measurement, and personalization where you agree.</li>
            <li>Security, fraud prevention, and legal compliance.</li>
          </ul>

          <h2>4. Cookies and Similar Technologies</h2>
          <p>We use strictly necessary cookies and, with your consent, analytics/advertising/functional
          cookies. Manage or withdraw consent any time via the on-site "Cookie Settings" link.</p>

          <h3>4.1 Google Tag Manager (GTM)</h3>
          <ul>
            <li>GTM is a tag manager and does not itself collect personal data.</li>
            <li>Tags deployed through GTM may set/read cookies. We integrate GTM with consent management
            so non-consented categories do not fire.</li>
          </ul>

          <h3>4.2 HubSpot</h3>
          <ul>
            <li>We use HubSpot for forms, CRM, email, chat, and baseline analytics.</li>
            <li>Depending on interactions (e.g., form submissions, email link clicks), your browsing history
            may be associated with your contact record where consent applies.</li>
            <li>Example HubSpot cookies (names/expiry may change): hubspotutk, __hstc, __hssc, __hssrc,
            messagesUtk, __cfruid.</li>
          </ul>

          <h3>4.3 Opt-out</h3>
          <ul>
            <li>Use "Cookie Settings" to change or withdraw consent.</li>
            <li>Unsubscribe using the link in each email.</li>
          </ul>

          <h2>5. Sharing with Service Providers</h2>
          <p>We engage trusted vendors (e.g., hosting, analytics, support) under appropriate contracts.
          We do not disclose data to third parties for their own marketing without your consent.</p>

          <h2>6. Retention</h2>
          <p>We keep data only as long as necessary for the purposes described or as required by law,
          then delete or anonymize it.</p>

          <h2>7. Security</h2>
          <p>We implement appropriate technical and organizational measures, including access controls,
          encryption, logging, vendor oversight, and staff training.</p>

          <h2>8. Your Rights (Japan)</h2>
          <p>Under Japan's Act on the Protection of Personal Information, you may request notice of purposes,
          access, correction/addition/deletion, suspension/erasure, and cessation of third-party provision.
          See "10. Contact" for how to reach us.</p>

          <h2>9. Changes</h2>
          <p>We may update this Policy from time to time. Material changes will be posted on the site.</p>

          <h2>10. Contact</h2>
          <ul>
            <li>Entity: Consilegy LLC</li>
            <li>Representative: Seiko Yamaguchi</li>
            <li>Email: info@consilegy.com</li>
          </ul>

        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .privacy-content {
    max-width: 720px;
  }

  .privacy-content .updated {
    font-size: 0.875rem;
    color: #6b7280;
    margin-bottom: 1.5rem;
  }

  .privacy-content h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .privacy-content h3 {
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 1.05rem;
  }

  .privacy-content ul {
    margin: 0.5rem 0 1rem 1.25rem;
    line-height: 1.8;
  }

  .privacy-content p {
    line-height: 1.8;
    margin-bottom: 1rem;
  }
</style>
