---
interface Props {
	portalId: string;
	formId: string;
	region?: string;
}

const { portalId, formId, region = 'na1' } = Astro.props;
const targetId = `hubspot-form-${formId}`;
---

<div class="hubspot-form" id={targetId} data-hubspot-form></div>

<script
	define:vars={{ portalId, formId, region, targetId }}
	is:inline
>
	(function () {
		var target = '#' + targetId;
		var s = document.createElement('script');
		s.src = 'https://js.hsforms.net/forms/embed/v2.js';
		s.defer = true;
		s.onload = function () {
			if (window.hbspt && window.hbspt.forms) {
				window.hbspt.forms.create({
					region: region,
					portalId: portalId,
					formId: formId,
					target: target,
				});
			}
		};
		document.head.appendChild(s);
	})();
</script>

<style>
	.hubspot-form {
		min-height: 320px;
		padding: var(--space-md);
		background: var(--color-bg-subtle);
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
	}
</style>
