---
const pathname = Astro.url.pathname;
const isEN = pathname.startsWith('/en');

const services = isEN
	? [
		{ label: 'Japan Market GTM & Messaging',          href: '/en/services/japan-market-gtm-messaging/' },
		{ label: 'Revenue Architecture Design',           href: '/en/services/revenue-architecture-design/' },
		{ label: 'CRM / RevOps Implementation',           href: '/en/services/crm-revops-implementation/' },
		{ label: 'HubSpot Implementation & Ops',          href: '/en/services/hubspot-implementation-operations-support/' },
		{ label: 'Adoption & Growth Support',             href: '/en/services/adoption-growth-support/' },
	]
	: [
		{ label: 'レベニューアーキテクチャ設計',    href: '/services/revenue-architecture-design/' },
		{ label: 'マーケティング戦略設計',          href: '/services/b2b-marketing-gtm-design/' },
		{ label: 'MA / CRM / SFA設計・実装支援',   href: '/services/crm-revops-redesign/' },
		{ label: 'HubSpot導入・運用支援',          href: '/services/hubspot-implementation-operations/' },
		{ label: '運用定着・改善支援',             href: '/services/adoption-growth-support/' },
	];

const resources = isEN
	? [
		{ label: 'Case Studies', href: '/en/case-studies/' },
		{ label: 'Insights',     href: '/en/insights/' },
		{ label: 'Newsletter',   href: '/en/newsletter/' },
		{ label: 'About',        href: '/en/company/' },
		{ label: 'Contact',      href: '/en/contact/' },
	]
	: [
		{ label: '収益構造 成熟度診断（無料）',        href: '/diagnostic/' },
		{ label: '導入事例',                   href: '/case-studies/' },
		{ label: 'インサイト',                  href: '/insights/' },
		{ label: 'レベニューアーキテクチャとは', href: '/revenue-architecture/' },
		{ label: 'RevOpsとは',                 href: '/about-revops/' },
		{ label: 'ニュースレター',              href: '/newsletter/' },
	];

const company = isEN
	? []
	: [
		{ label: '会社概要',       href: '/company/' },
		{ label: '料金',           href: '/pricing/' },
		{ label: '資料ダウンロード', href: '/download/' },
		{ label: 'お問い合わせ',   href: '/contact/' },
		{ label: '無料相談',       href: '/free-consultation/' },
	];

const privacyHref = isEN ? '/en/privacy-policy/' : '/privacy-policy/';
---

<footer class={`site-footer${isEN ? ' site-footer--en' : ''}`}>
	<div class="container site-footer__grid">

		<!-- Brand -->
		<div class="site-footer__brand">
			<a class="site-footer__logo-link" href={isEN ? '/en/' : '/'}>
				<img
					src="/images/common/consilegy-logo-white.svg"
					alt="Consilegy"
					height="28"
					width="155"
					class="site-footer__logo"
				/>
			</a>
			<p class="site-footer__tagline">Translate strategy into operations.</p>
			<p class="site-footer__desc">
				{isEN
					? 'We help global B2B teams design revenue operations that actually work in Japan.'
					: 'マーケ・営業・CSをつなぐ収益構造の設計と実装を支援します。'}
			</p>
		</div>

		<!-- Services -->
		<div>
			<p class="site-footer__heading">Services</p>
			<ul class="site-footer__links">
				{services.map(({ label, href }) => (
					<li><a href={href}>{label}</a></li>
				))}
			</ul>
		</div>

		<!-- Resources -->
		<div>
			<p class="site-footer__heading">{isEN ? 'Resources' : 'リソース'}</p>
			<ul class="site-footer__links">
				{resources.map(({ label, href }) => (
					<li><a href={href}>{label}</a></li>
				))}
			</ul>
		</div>

		<!-- Company & Contact (JA only) / Follow Us (EN) -->
		{!isEN && (
			<div>
				<p class="site-footer__heading">会社・連絡先</p>
				<ul class="site-footer__links">
					{company.map(({ label, href }) => (
						<li><a href={href}>{label}</a></li>
					))}
				</ul>
			</div>
		)}

		<!-- Follow Us -->
		<div>
			<p class="site-footer__heading">{isEN ? 'Follow Us' : 'フォロー'}</p>
			<ul class="site-footer__links">
				<li>
					<a
						href="https://www.linkedin.com/company/consilegy"
						target="_blank"
						rel="noopener noreferrer"
						class="site-footer__social"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
						</svg>
						LinkedIn
					</a>
				</li>
				<li>
					<a
						href="https://note.com/consilegy"
						target="_blank"
						rel="noopener noreferrer"
						class="site-footer__social"
					>
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M0 .279c4.623 0 10.953-.235 15.498-.117 6.099.156 8.39 2.813 8.468 9.374.077 3.71 0 14.335 0 14.335h-6.598c0-9.296.04-10.83 0-13.759-.078-2.578-.814-3.807-2.795-4.041-2.097-.235-7.975-.04-7.975-.04v17.84H0Z"/>
						</svg>
						note
					</a>
				</li>
			</ul>
		</div>

	</div>

	<!-- Bottom bar -->
	<div class="site-footer__bottom">
		<div class="container site-footer__bottom-inner">
			<p>(c) 2025 Consilegy LLC.</p>
			<a href={privacyHref} class="site-footer__privacy">Privacy Policy</a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		background: #111827;
		color: #94a3b8;
		margin-top: 0;
	}

	.site-footer__grid {
		/* Reset --container: html[lang="en"] sets 72ch which would narrow the footer */
		--container: 1120px;
		display: grid;
		grid-template-columns: 1.4fr 1fr 1fr 1fr 0.7fr;
		gap: var(--space-xl);
		padding-block: var(--space-2xl) var(--space-xl);
		align-items: start;
	}

	/* EN: 4 columns (no company column) */
	.site-footer--en .site-footer__grid {
		grid-template-columns: 1.4fr 1fr 1fr 0.7fr;
	}

	/* Brand */
	.site-footer__logo-link {
		display: inline-block;
		margin-bottom: 0.85rem;
		text-decoration: none;
	}

	.site-footer__logo {
		height: 28px;
		width: auto;
		display: block;
	}

	.site-footer__tagline {
		margin: 0 0 0.65rem;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		color: #475569;
		text-transform: uppercase;
	}

	.site-footer__desc {
		margin: 0;
		font-size: 0.85rem;
		line-height: 1.7;
		color: #64748b;
		max-width: 30ch;
	}

	/* Column headings */
	.site-footer__heading {
		margin: 0 0 0.75rem;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #475569;
	}

	/* Link lists */
	.site-footer__links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.55rem;
	}

	.site-footer__links a {
		font-size: 0.85rem;
		font-weight: 500;
		color: #94a3b8;
		text-decoration: none;
		line-height: 1.4;
		transition: color 0.15s;
	}

	.site-footer__links a:hover { color: #fff; }

	.site-footer__social {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
	}

	/* Bottom bar */
	.site-footer__bottom {
		border-top: 1px solid #1e293b;
	}

	.site-footer__bottom-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-block: 1rem;
		font-size: 0.78rem;
		color: #475569;
	}

	.site-footer__bottom-inner p { margin: 0; }

	.site-footer__privacy {
		font-size: 0.78rem;
		color: #64748b;
		text-decoration: none;
		transition: color 0.15s;
	}

	.site-footer__privacy:hover { color: #94a3b8; }

	/* Tablet */
	@media (max-width: 1080px) {
		.site-footer__grid {
			grid-template-columns: 1fr 1fr 1fr;
			gap: var(--space-lg);
		}

		.site-footer__brand {
			grid-column: 1 / -1;
		}

		.site-footer__desc { max-width: 100%; }
	}

	@media (max-width: 720px) {
		.site-footer__grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	/* SP */
	@media (max-width: 560px) {
		.site-footer__grid {
			grid-template-columns: 1fr;
			gap: var(--space-md);
			padding-block: var(--space-xl) var(--space-lg);
		}
	}
</style>
