---
import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
	description: string;
	canonical?: string;
	ogImage?: string;
	noindex?: boolean;
	ogType?: 'website' | 'article';
	lang?: 'ja' | 'en';
	eyebrow?: string;
	featuredImage?: string;
	imageAlt?: string;
	backHref?: string;
	backLabel?: string;
	hideLede?: boolean;
}

const { eyebrow, featuredImage, imageAlt, backHref, backLabel, hideLede, ...base } = Astro.props;
const effectiveOgImage = base.ogImage ?? (featuredImage || undefined);
const showLede = !hideLede && !!base.description;
---

<BaseLayout {...base} ogImage={effectiveOgImage} ogType={base.ogType ?? 'article'}>
	<article class="article">
		{featuredImage && (
			<div class="article__visual">
				<div class="container">
					<img
						class="article__cover"
						src={featuredImage}
						alt={imageAlt ?? ''}
						width="1120"
						height="440"
						loading="eager"
					/>
				</div>
			</div>
		)}

		<header class="article__header">
			<div class="container article__header-inner">
				{backHref && (
					<a class="article__back" href={backHref}>
						← {backLabel ?? '一覧へ戻る'}
					</a>
				)}
				{eyebrow && <p class="article__eyebrow">{eyebrow}</p>}
				<h1 class="article__title">{base.title}</h1>
				{showLede && <p class="article__lede">{base.description}</p>}
			</div>
		</header>

		<div class="container article__body">
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	/* Cover image */
	.article__visual {
		background: var(--color-bg-subtle);
		border-bottom: 1px solid var(--color-border);
		padding-top: var(--space-lg);
	}

	.article__cover {
		width: 100%;
		max-height: 460px;
		object-fit: cover;
		border-radius: calc(var(--radius) * 2) calc(var(--radius) * 2) 0 0;
		box-shadow: var(--shadow-md);
		display: block;
	}

	/* Header area */
	.article__header {
		background: var(--color-bg-subtle);
		border-bottom: 1px solid var(--color-border);
		padding-block: var(--space-xl) var(--space-lg);
	}

	.article__header-inner {
		max-width: 760px;
	}

	.article__back {
		display: inline-block;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--color-text-muted);
		text-decoration: none;
		margin-bottom: var(--space-md);
		transition: color 0.15s;
	}

	.article__back:hover {
		color: var(--color-primary);
	}

	.article__eyebrow {
		margin: 0 0 var(--space-sm);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-primary);
	}

	.article__title {
		margin: 0 0 var(--space-md);
		font-size: clamp(1.55rem, 3vw, 2.1rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.25;
		color: var(--color-text);
	}

	.article__lede {
		margin: 0;
		font-size: var(--text-lead);
		color: var(--color-text-muted);
		line-height: 1.75;
		max-width: 60ch;
	}

	/* Body */
	.article__body {
		padding-block: var(--space-xl) var(--space-2xl);
		/* Constrain reading width while allowing full-width WP tables to scroll */
		max-width: 820px;
	}

	/* Constrain inner .wp-content to reading width, but let scrollable table wrappers break out */
	.article__body :global(.wp-content) {
		max-width: 65ch;
	}

	.article__body :global(.wp-content .wp-block-table),
	.article__body :global(.wp-content > table) {
		max-width: 100%;
		width: 100%;
	}

	/* post-meta date line */
	.article__body :global(.post-meta) {
		font-size: 0.875rem;
		color: var(--color-text-muted);
		margin-bottom: var(--space-lg);
		padding-bottom: var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}

	@media (max-width: 720px) {
		.article__header {
			padding-block: var(--space-lg) var(--space-md);
		}

		.article__body {
			padding-block: var(--space-lg) var(--space-xl);
		}
	}
</style>
