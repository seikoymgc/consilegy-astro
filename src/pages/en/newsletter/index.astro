---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import HubSpotForm from '../../../components/HubSpotForm.astro';

const portalId = '46498743';
const newsletterFormId = 'e3b68ea5-7c0f-4754-b0ec-30794227d1d6';

const backnumbers: { date: string; title: string; url: string }[] = [];

const pageSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: 'Consilegy B2B Revenue Playbook | Newsletter',
	description: 'Actionable playbooks for global B2B leaders on Revenue Architecture and Japan GTM. Practical frameworks, not theory.',
	url: 'https://consilegy.com/en/newsletter/',
	inLanguage: 'en',
};

const themes = [
	{
		title: 'Revenue Architecture Design',
		desc: 'How to build repeatable revenue structures — funnel logic, lifecycle definitions, and the handoff rules that actually prevent leakage.',
	},
	{
		title: 'Japan GTM Strategy',
		desc: 'ICP definition, messaging adaptation, and conversion paths built for how Japanese buyers evaluate trust, risk, and value.',
	},
	{
		title: 'CRM & RevOps in Japan',
		desc: 'What works (and what doesn\'t) when implementing HubSpot, Salesforce, or Kintone in Japanese-facing B2B organizations.',
	},
	{
		title: 'Pipeline & Forecast Visibility',
		desc: 'How to design forecast processes and KPI frameworks that give real revenue visibility — not just status updates.',
	},
	{
		title: 'Adoption & Change Management',
		desc: 'Making revenue systems stick. The operating habits, documentation cycles, and coaching routines that prevent regression.',
	},
	{
		title: 'Global B2B Trends for Japan',
		desc: 'How RevOps and GTM trends from North America and Europe translate — and where they break — in the Japan market context.',
	},
];

const recentPosts = [
	{
		href: '/en/case-studies/hubspot-sales-handoff-lead-to-revenue-2/',
		title: 'Closing the Gap Between Lead Volume and Revenue',
		category: 'HubSpot · Lead Ops',
	},
	{
		href: '/en/case-studies/japan-market-entry-gtm-architecture/',
		title: 'Japan Market Entry GTM Architecture',
		category: 'Japan GTM',
	},
	{
		href: '/en/case-studies/https-consilegy-com-case-studies-ai-gtm-automation-product-integration/',
		title: 'Building a Revenue Foundation for a New AI Business',
		category: 'GTM · CRM Build',
	},
	{
		href: '/en/case-studies/marketing-data-integration-hubspot-migration-2/',
		title: 'Redesigning a Complex Marketing Stack',
		category: 'HubSpot · Marketing Ops',
	},
];
---

<BaseLayout
	title="Consilegy B2B Revenue Playbook | Newsletter"
	description="Actionable playbooks for global B2B leaders on Revenue Architecture and Japan GTM. Practical frameworks on pipeline design, CRM adoption, and Japan market entry — delivered by Seiko Yamaguchi, Founder of Consilegy."
	lang="en"
	alternateUrl="/newsletter/"
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(pageSchema)} />
	</Fragment>

<div class="nl-wrap">

	<!-- ===== HERO ===== -->
	<section class="nl-hero">
		<div class="nl-hero-bg" aria-hidden="true"></div>
		<div class="container nl-hero-inner">
			<div class="nl-hero-copy">
				<div class="nl-badge">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#0a66c2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
					LinkedIn Newsletter
				</div>
				<h1>Consilegy B2B<br class="br-pc" /> Revenue Playbook</h1>
				<p class="nl-hero-sub">Actionable playbooks for global B2B leaders on Revenue Architecture and Japan GTM</p>
				<p class="nl-hero-desc">Practical frameworks on pipeline design, CRM adoption, and Japan market entry — not theory. Delivered by Seiko Yamaguchi, Founder of Consilegy, based on real implementation work.</p>

				<div class="nl-stats">
					<div class="nl-stat">
						<div class="nl-stat-num">~2,000<span class="nl-stat-unit"></span></div>
						<div class="nl-stat-label">LinkedIn subscribers</div>
					</div>
					<div class="nl-stat-divider"></div>
					<div class="nl-stat">
						<div class="nl-stat-num">47<span class="nl-stat-unit">%</span></div>
						<div class="nl-stat-label">English edition</div>
					</div>
					<div class="nl-stat-divider"></div>
					<div class="nl-stat">
						<div class="nl-stat-num">53<span class="nl-stat-unit">%</span></div>
						<div class="nl-stat-label">Japanese edition</div>
					</div>
				</div>

				<div class="nl-hero-actions">
					<a href="#signup" class="nl-btn nl-btn--primary">
						Subscribe free →
					</a>
					<a
						href="https://www.linkedin.com/build-relation/newsletter-follow?entityUrn=7413868864930947072"
						target="_blank"
						rel="noopener noreferrer"
						class="nl-btn nl-btn--outline"
					>
						Follow on LinkedIn
					</a>
				</div>
				<p class="nl-hero-note">* Subscriber count as of May 2026. Free to subscribe via LinkedIn or email.</p>
			</div>

			<div class="nl-hero-author">
				<div class="nl-author-card">
					<div class="nl-author-avatar">
						<img src="/images/common/seiko-yamaguchi.jpg" alt="Seiko Yamaguchi, Founder of Consilegy" width="96" height="96" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
						<div class="nl-author-avatar-fallback" style="display:none">SY</div>
					</div>
					<div class="nl-author-info">
						<div class="nl-author-name">Seiko Yamaguchi</div>
						<div class="nl-author-title">Founder, Consilegy</div>
						<p class="nl-author-bio">Revenue Architecture and RevOps specialist. Focused on Japan-facing B2B revenue systems — CRM implementation, GTM design, and operational adoption across HubSpot, Salesforce, and Kintone environments.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== THEMES ===== -->
	<section class="nl-themes">
		<div class="container">
			<header class="nl-section-head">
				<p class="nl-eyebrow">Topics</p>
				<h2>What this newsletter covers</h2>
				<p class="nl-section-desc">Each issue focuses on one practical topic — something you can apply to your revenue system, GTM motion, or Japan market strategy.</p>
			</header>
			<div class="nl-themes-grid">
				{themes.map(({ title, desc }) => (
					<div class="nl-theme-card">
						<h3 class="nl-theme-title">{title}</h3>
						<p class="nl-theme-desc">{desc}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ===== SIGN-UP FORM ===== -->
	<section class="nl-signup" id="signup">
		<div class="container">
			<header class="nl-section-head">
				<p class="nl-eyebrow">Sign Up</p>
				<h2>Get it by email</h2>
				<p class="nl-section-desc">Register below and each new issue will be delivered to your inbox.</p>
			</header>
			<div class="nl-signup-layout">
				<div class="nl-signup-form">
					<HubSpotForm portalId={portalId} formId={newsletterFormId} region="na2" />
				</div>
				<aside class="nl-signup-aside">
					<div class="nl-signup-or">
						<span>or</span>
					</div>
					<div class="nl-signup-li">
						<p class="nl-signup-li-head">Follow on LinkedIn</p>
						<p class="nl-signup-li-note">If you have a LinkedIn account, you can subscribe directly as a LinkedIn Newsletter and get notified when each issue goes live.</p>
						<a
							href="https://www.linkedin.com/build-relation/newsletter-follow?entityUrn=7413868864930947072"
							target="_blank"
							rel="noopener noreferrer"
							class="nl-btn nl-btn--li"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
							Follow on LinkedIn (free)
						</a>
					</div>
				</aside>
			</div>
		</div>
	</section>

	<!-- ===== BACKNUMBER ===== -->
	{backnumbers.length > 0 && (
	<section class="nl-backnumber">
		<div class="container">
			<header class="nl-section-head">
				<p class="nl-eyebrow">Back Numbers</p>
				<h2>Past issues</h2>
			</header>
			<div class="nl-bn-list">
				{backnumbers.map((issue) => (
					<a href={issue.url} class="nl-bn-item" target="_blank" rel="noopener noreferrer">
						<span class="nl-bn-date">{issue.date}</span>
						<span class="nl-bn-title">{issue.title}</span>
						<svg class="nl-bn-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
					</a>
				))}
			</div>
		</div>
	</section>
	)}

	<!-- ===== RECENT CASE STUDIES ===== -->
	<section class="nl-posts">
		<div class="container">
			<header class="nl-section-head">
				<p class="nl-eyebrow">Case Studies</p>
				<h2>Real work, real results</h2>
			</header>
			<div class="nl-posts-list">
				{recentPosts.map(({ href, title, category }) => (
					<a href={href} class="nl-post-item">
						<span class="nl-post-cat">{category}</span>
						<span class="nl-post-title">{title}</span>
						<svg class="nl-post-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
					</a>
				))}
			</div>
			<div class="nl-posts-more">
				<a href="/en/case-studies/" class="nl-btn nl-btn--outline">View all case studies →</a>
			</div>
		</div>
	</section>

	<!-- ===== CTA ===== -->
	<section class="nl-cta">
		<div class="container nl-cta-inner">
			<div class="nl-cta-copy">
				<p class="nl-cta-eyebrow">Free subscription</p>
				<h2>Practical revenue frameworks,<br />delivered regularly</h2>
				<p class="nl-cta-desc">Register once. Each new issue arrives in your inbox. Free to subscribe, unsubscribe any time.</p>
			</div>
			<div class="nl-cta-action">
				<a href="#signup" class="nl-btn nl-btn--cta">
					Subscribe free →
				</a>
				<p class="nl-cta-note">~2,000 B2B leaders and revenue practitioners subscribed</p>
			</div>
		</div>
	</section>

</div>

<style>
/* ===== WRAP ===== */
.nl-wrap { background: #fff; }
.container { max-width: 960px; margin: 0 auto; padding: 0 24px; }
.br-pc { display: none; }
@media (min-width: 640px) { .br-pc { display: block; } }

/* ===== HERO ===== */
.nl-hero {
	position: relative;
	background: var(--color-navy, #0f172a);
	padding: 72px 0 64px;
	overflow: hidden;
}
.nl-hero-bg {
	position: absolute; inset: 0;
	background:
		radial-gradient(ellipse 600px 400px at 90% 50%, rgba(30,64,175,0.35), transparent 60%),
		radial-gradient(ellipse 400px 300px at 10% 80%, rgba(124,92,191,0.2), transparent 60%);
	pointer-events: none;
}
.nl-hero-inner {
	position: relative;
	display: grid;
	grid-template-columns: 1fr auto;
	gap: 48px;
	align-items: start;
}
@media (max-width: 760px) {
	.nl-hero-inner { grid-template-columns: 1fr; }
}

.nl-badge {
	display: inline-flex;
	align-items: center;
	gap: 6px;
	background: rgba(255,255,255,0.1);
	border: 1px solid rgba(255,255,255,0.2);
	border-radius: 20px;
	padding: 5px 14px;
	font-size: 0.75rem;
	font-weight: 600;
	color: #fff;
	margin-bottom: 20px;
}

.nl-hero-copy h1 {
	font-size: clamp(1.8rem, 4vw, 2.6rem);
	font-weight: 800;
	color: #fff;
	line-height: 1.25;
	margin: 0 0 10px;
}
.nl-hero-sub {
	font-size: 0.9rem;
	font-weight: 600;
	color: #93c5fd;
	margin: 0 0 16px;
}
.nl-hero-desc {
	font-size: 0.975rem;
	color: rgba(255,255,255,0.8);
	line-height: 1.85;
	margin: 0 0 32px;
	max-width: 540px;
}

/* Stats */
.nl-stats {
	display: flex;
	align-items: center;
	gap: 20px;
	margin-bottom: 32px;
	flex-wrap: wrap;
}
.nl-stat { text-align: center; }
.nl-stat-num {
	font-size: 1.6rem;
	font-weight: 800;
	color: #fff;
	line-height: 1;
}
.nl-stat-unit { font-size: 0.85rem; font-weight: 600; margin-left: 2px; }
.nl-stat-label { font-size: 0.7rem; color: rgba(255,255,255,0.55); margin-top: 4px; }
.nl-stat-divider { width: 1px; height: 36px; background: rgba(255,255,255,0.2); flex-shrink: 0; }

/* Buttons */
.nl-hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
.nl-btn {
	display: inline-flex;
	align-items: center;
	gap: 8px;
	padding: 12px 24px;
	border-radius: 6px;
	font-size: 0.9rem;
	font-weight: 700;
	text-decoration: none;
	transition: opacity 0.15s, background 0.15s;
	white-space: nowrap;
}
.nl-btn--primary {
	background: #0a66c2;
	color: #fff;
	border: none;
}
.nl-btn--primary:hover { opacity: 0.88; }
.nl-btn--outline {
	background: transparent;
	color: rgba(255,255,255,0.85);
	border: 1.5px solid rgba(255,255,255,0.3);
}
.nl-btn--outline:hover { border-color: rgba(255,255,255,0.6); color: #fff; }
.nl-hero-note { font-size: 0.72rem; color: rgba(255,255,255,0.4); margin: 0; }

/* Author card */
.nl-author-card {
	background: rgba(255,255,255,0.06);
	border: 1px solid rgba(255,255,255,0.12);
	border-radius: 12px;
	padding: 24px;
	width: 260px;
	flex-shrink: 0;
}
@media (max-width: 760px) { .nl-author-card { width: 100%; } }
.nl-author-avatar {
	width: 64px; height: 64px;
	border-radius: 50%;
	overflow: hidden;
	margin-bottom: 14px;
	background: rgba(255,255,255,0.1);
}
.nl-author-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
.nl-author-avatar-fallback {
	width: 100%; height: 100%;
	align-items: center; justify-content: center;
	font-size: 1rem; font-weight: 700; color: rgba(255,255,255,0.7);
}
.nl-author-name { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 2px; }
.nl-author-title { font-size: 0.75rem; color: #93c5fd; margin-bottom: 12px; }
.nl-author-bio { font-size: 0.75rem; color: rgba(255,255,255,0.65); line-height: 1.7; margin: 0; }

/* ===== SECTION COMMON ===== */
.nl-section-head { text-align: center; margin-bottom: 48px; }
.nl-eyebrow {
	font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
	text-transform: uppercase; color: var(--color-primary, #1e40af);
	margin: 0 0 10px;
}
.nl-section-head h2 {
	font-size: clamp(1.4rem, 3vw, 1.9rem);
	font-weight: 800;
	color: var(--color-navy, #0f172a);
	margin: 0 0 14px;
}
.nl-section-desc {
	font-size: 0.95rem;
	color: var(--color-charcoal, #334155);
	line-height: 1.8;
	max-width: 560px;
	margin: 0 auto;
}

/* ===== THEMES ===== */
.nl-themes { padding: 72px 0; background: #f8fafc; }
.nl-themes-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 20px;
}
@media (max-width: 760px) { .nl-themes-grid { grid-template-columns: 1fr; } }
@media (min-width: 480px) and (max-width: 760px) { .nl-themes-grid { grid-template-columns: repeat(2, 1fr); } }

.nl-theme-card {
	background: #fff;
	border: 1px solid var(--color-border, #e2e8f0);
	border-radius: 10px;
	padding: 24px 20px;
}
.nl-theme-title {
	font-size: 0.88rem;
	font-weight: 700;
	color: var(--color-navy, #0f172a);
	margin: 0 0 8px;
	line-height: 1.4;
}
.nl-theme-desc {
	font-size: 0.8rem;
	color: var(--color-charcoal, #334155);
	line-height: 1.75;
	margin: 0;
}

/* ===== RECENT POSTS ===== */
.nl-posts { padding: 72px 0; }
.nl-posts-list { display: flex; flex-direction: column; gap: 0; margin-bottom: 32px; }
.nl-post-item {
	display: grid;
	grid-template-columns: auto 1fr auto;
	align-items: center;
	gap: 16px;
	padding: 18px 0;
	border-bottom: 1px solid var(--color-border, #e2e8f0);
	text-decoration: none;
	transition: background 0.12s;
}
.nl-post-item:first-child { border-top: 1px solid var(--color-border, #e2e8f0); }
.nl-post-item:hover .nl-post-title { color: var(--color-primary, #1e40af); }
.nl-post-item:hover .nl-post-arrow { color: var(--color-primary, #1e40af); transform: translateX(3px); }
.nl-post-cat {
	display: inline-block;
	background: #eff6ff;
	color: var(--color-primary, #1e40af);
	font-size: 0.68rem;
	font-weight: 600;
	padding: 3px 10px;
	border-radius: 10px;
	white-space: nowrap;
	flex-shrink: 0;
}
.nl-post-title {
	font-size: 0.9rem;
	font-weight: 600;
	color: var(--color-navy, #0f172a);
	transition: color 0.15s;
	line-height: 1.5;
}
.nl-post-arrow {
	color: var(--color-muted, #64748b);
	flex-shrink: 0;
	transition: color 0.15s, transform 0.15s;
}
.nl-posts-more { text-align: center; }
.nl-posts-more .nl-btn--outline {
	color: var(--color-primary, #1e40af);
	border-color: var(--color-primary, #1e40af);
}
.nl-posts-more .nl-btn--outline:hover { background: rgba(30,64,175,0.05); }

/* ===== CTA ===== */
.nl-cta {
	padding: 80px 24px;
	background: radial-gradient(800px 360px at 85% -5%, rgba(124,92,191,0.35), transparent 55%), linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%);
}
.nl-cta-inner {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 40px;
	flex-wrap: wrap;
}
.nl-cta-eyebrow {
	font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
	text-transform: uppercase; color: rgba(255,255,255,0.6);
	margin: 0 0 10px;
}
.nl-cta-copy h2 {
	font-size: clamp(1.3rem, 3vw, 1.8rem);
	font-weight: 800;
	color: #fff;
	margin: 0 0 12px;
	line-height: 1.4;
}
.nl-cta-desc { font-size: 0.9rem; color: rgba(255,255,255,0.8); line-height: 1.75; margin: 0; max-width: 420px; }
.nl-cta-action { text-align: center; flex-shrink: 0; }
.nl-btn--cta {
	background: #fff;
	color: #0a66c2;
	border: none;
	font-size: 1rem;
	padding: 14px 28px;
	margin-bottom: 10px;
	display: inline-flex;
}
.nl-btn--cta:hover { opacity: 0.9; }
.nl-cta-note { font-size: 0.72rem; color: rgba(255,255,255,0.55); margin: 0; }

/* ===== SIGN-UP ===== */
.nl-signup { padding: 72px 0; background: #fff; border-top: 1px solid var(--color-border, #e2e8f0); }
.nl-signup-layout { display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: start; max-width: 760px; margin: 0 auto; }
@media (max-width: 660px) { .nl-signup-layout { grid-template-columns: 1fr; } }
.nl-signup-form { min-width: 0; }
.nl-signup-aside { display: flex; flex-direction: column; gap: 20px; width: 220px; flex-shrink: 0; padding-top: 4px; }
@media (max-width: 660px) { .nl-signup-aside { width: 100%; } }
.nl-signup-or {
	display: flex; align-items: center; gap: 10px;
	font-size: 0.75rem; color: var(--color-muted, #64748b); font-weight: 600;
}
.nl-signup-or::before, .nl-signup-or::after {
	content: ''; flex: 1; height: 1px; background: var(--color-border, #e2e8f0);
}
.nl-signup-li-head { font-size: 0.8rem; font-weight: 700; color: var(--color-navy, #0f172a); margin: 0 0 6px; }
.nl-signup-li-note { font-size: 0.72rem; color: var(--color-muted, #64748b); line-height: 1.7; margin: 0 0 12px; }
.nl-btn--li {
	background: #0a66c2; color: #fff; border: none;
	font-size: 0.8rem; padding: 9px 16px;
}
.nl-btn--li:hover { opacity: 0.88; }

/* ===== BACKNUMBER ===== */
