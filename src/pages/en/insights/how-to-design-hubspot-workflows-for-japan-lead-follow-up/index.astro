  display: block;
  font-size: 0.9375rem;
  font-weight: 700;
  color: var(--color-navy, #0f172a);
  margin-bottom: 6px;
}
.article-breakdown__body p {
  font-size: 0.9375rem;
  line-height: 1.75;
  color: var(--color-text-muted, #64748b);
  margin: 0;
}

/* ── Related ─────────────────────────────── */
.article-related {
  padding: 48px 0;
  border-top: 1px solid var(--color-border, #e2e8f0);
}
.article-related__label {
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--color-primary, #1e40af);
  margin: 0 0 20px;
}
.article-related__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
.article-related__card {
  background: #f8fafc;
  border: 1px solid var(--color-border, #e2e8f0);
  border-radius: 8px;
  padding: 16px 18px;
  text-decoration: none;
  display: flex; flex-direction: column; gap: 6px;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.article-related__card:hover {
  border-color: var(--color-primary, #1e40af);
  box-shadow: 0 2px 12px rgba(30,64,175,0.07);
}
.article-related__card-cat {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em;
  text-transform: uppercase; color: var(--color-primary, #1e40af); margin: 0;
}
.article-related__card-title {
  font-size: 0.875rem; font-weight: 600;
  color: var(--color-navy, #0f172a); line-height: 1.45; margin: 0; flex: 1;
}
.article-related__card-arrow {
  font-size: 0.875rem; color: var(--color-primary, #1e40af); font-weight: 600;
}

/* ── CTA ─────────────────────────────────── */
.article-cta {
  background: #f8fafc;
  border-top: 1px solid var(--color-border, #e2e8f0);
  padding: 64px 0;
}
.article-cta__body {
  text-align: center;
  max-width: 560px;
  margin: 0 auto;
}
.article-cta__body h2 {
  font-size: clamp(1.25rem, 3vw, 1.625rem);
  font-weight: 600;
  color: var(--color-navy, #0f172a);
  margin: 0 0 12px;
}
.article-cta__body p {
  font-size: 0.9375rem;
  line-height: 1.8;
  color: var(--color-text-muted, #64748b);
  margin: 0 0 28px;
}
.article-cta__actions {
  display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
}
.article-cta__btn {
  display: inline-flex; align-items: center;
  padding: 0.75em 1.75em;
  border-radius: 8px; font-size: 0.9375rem; font-weight: 700;
  text-decoration: none; transition: background 0.15s, color 0.15s;
}
.article-cta__btn--primary {
  background: var(--color-primary, #1e40af); color: #fff;
  border: 2px solid var(--color-primary, #1e40af);
}
.article-cta__btn--primary:hover { background: #1e3a8a; border-color: #1e3a8a; }
.article-cta__btn--ghost {
  background: transparent; color: var(--color-primary, #1e40af);
  border: 2px solid var(--color-primary, #1e40af);
}
.article-cta__btn--ghost:hover { background: rgba(30,64,175,0.06); }

/* ── Responsive ──────────────────────────── */
@media (max-width: 600px) {
  .article-head { padding-top: 32px; }
  .article-related__grid { grid-template-columns: 1fr; }
  .article-breakdown__num { font-size: 1rem; min-width: 2rem; }
}
</style>

</BaseLayout>
