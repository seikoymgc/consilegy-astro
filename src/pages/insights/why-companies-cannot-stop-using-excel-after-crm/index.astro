	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://consilegy.com/' },
		{ '@type': 'ListItem', position: 2, name: 'コラム', item: 'https://consilegy.com/insights/' },
		{ '@type': 'ListItem', position: 3, name: 'CRMを導入してもExcelが止まらない理由', item: 'https://consilegy.com/insights/why-companies-cannot-stop-using-excel-after-crm/' },
	],
