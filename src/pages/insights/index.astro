---
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  {
    slug: 'why-good-marketing-does-not-create-repeatable-growth',
    title: 'なぜ「良い施策」を打っているのに、組織が再現性を持てないのか',
    desc: '優秀な施策や営業人材がいるのに成長が再現しない原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
    cat: 'Revenue Architecture',
    date: '2026-05-07',
  },
  {
    slug: 'why-dashboards-do-not-improve-executive-decisions',
    title: 'ダッシュボードを作っても意思決定が速くならない理由',
    desc: 'BIやダッシュボードを整備しても経営判断が速くならない原因を、KPI設計・Revenue Architecture・RevOpsの観点から解説します。',
    cat: 'BI / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-marketing-automation-does-not-improve-pipeline',
    title: 'MAを導入しても商談化率が改善しない理由',
    desc: 'HubSpotやMarketoなどのMAを導入しても商談化率が改善しない原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
    cat: 'Marketing / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-more-kpis-create-less-revenue-visibility',
    title: 'KPIが増えるほど売上が見えなくなる理由',
    desc: 'KPIを増やしているのに意思決定が遅くなる原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
    cat: 'RevOps / KPI',
    date: '2026-05-07',
  },
  {
    slug: 'why-sales-and-customer-success-do-not-align',
    title: '営業とカスタマーサクセスが連携できない理由',
    desc: '営業とカスタマーサクセスが分断される原因を、KPI設計・CRM・Revenue Architectureの観点から解説します。',
    cat: 'RevOps / Customer Success',
    date: '2026-05-07',
  },
  {
    slug: 'why-more-leads-do-not-increase-revenue',
    title: 'リードは増えているのに受注が増えない理由',
    desc: 'リード獲得数が増えているのに売上につながらない原因を、営業・マーケ連携、KPI設計、Revenue Architectureの観点から解説します。',
    cat: 'Marketing / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-sales-teams-stop-using-crm',
    title: 'CRMを導入すると営業が入力しなくなる理由',
    desc: 'SalesforceやHubSpotを導入しても営業入力が定着しない原因を、現場UX・KPI・Revenue Architectureの観点から解説します。',
    cat: 'CRM / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-salesforce-and-hubspot-data-do-not-match',
    title: 'SalesforceとHubSpotで数字が合わない理由',
    desc: 'SalesforceとHubSpotで数字がズレる原因を、データ構造・KPI定義・Revenue Architectureの観点から解説します。',
    cat: 'CRM / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-sales-meetings-become-number-reporting',
    title: '営業会議が数字確認会になる理由',
    desc: '営業会議が改善につながらない理由を、KPI設計・CRM運用・Revenue Architectureの観点から解説します。',
    cat: 'CRM / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-sales-forecasting-fails-even-with-sfa',
    title: 'SFAを導入しても売上予測が当たらない理由',
    desc: 'SalesforceなどのSFAを導入しても売上予測が外れる原因を、商談定義・KPI・Revenue Architectureの観点から解説します。',
    cat: 'CRM / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-companies-cannot-stop-using-excel-after-crm',
    title: 'CRMを導入してもExcel集計が残る理由',
    desc: 'CRMを導入してもExcel集計が残る原因を、KPI設計・データ構造・Revenue Architectureの観点から解説します。',
    cat: 'CRM / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-crm-adoption-fails',
    title: 'CRMが定着しない本当の理由',
    desc: 'CRMが定着しない原因を、営業現場の意識ではなく、KPI設計・商談ステージ定義・データ構造・Revenue Architectureの観点から解説します。',
    cat: 'CRM / RevOps',
    date: '2026-05-06',
  },
  {
    slug: 'why-crm-does-not-align-sales-and-marketing',
    title: 'CRMを導入しても営業とマーケティングが連携できない本当の理由',
    desc: 'CRM・MAを導入しても営業とマーケティングが連携できない根本原因を、Revenue Architectureの観点から解説します。',
    cat: 'Revenue Architecture',
    date: '2026-05-06',
  },
  {
    slug: 'why-crm-integration-projects-fail',
    title: 'CRM統合プロジェクトが失敗する理由',
    desc: 'Salesforce・HubSpot・KintoneなどのCRM統合プロジェクトが失敗する原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
    cat: 'CRM / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-hubspot-operations-become-dependent-on-individuals',
    title: 'なぜHubSpot運用は属人化するのか',
    desc: 'HubSpot運用が一部担当者に依存し、ブラックボックス化する原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
    cat: 'HubSpot / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-revops-is-hard-in-japanese-companies',
    title: 'なぜ日本企業ではRevOpsが定着しにくいのか',
    desc: '欧米では一般化しつつあるRevOpsが、日本企業では定着しにくい理由を、組織構造・KPI・Revenue Architectureの観点から解説します。',
    cat: 'RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-sales-forecasting-fails',
    title: '営業予測（Forecast）が当たらない理由',
    desc: 'SalesforceやHubSpotを導入しても営業予測が当たらない原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
    cat: 'Sales / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-salesforce-implementations-fail',
    title: 'なぜSalesforce導入は失敗しやすいのか',
    desc: 'Salesforce導入が失敗する本当の原因を、Revenue Architecture・RevOps・運用定着の観点から解説します。',
    cat: 'Salesforce / RevOps',
    date: '2026-05-07',
  },
  {
    slug: 'why-sfa-becomes-just-a-pipeline-sheet',
    title: 'なぜSFAは案件管理表になるのか',
    desc: 'SalesforceなどのSFAが単なる案件管理表になってしまう原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
    cat: 'Sales / CRM',
    date: '2026-05-07',
  },
  {
    slug: 'why-sql-definitions-break-between-marketing-and-sales',
    title: 'なぜSQL定義がズレるのか',
    desc: 'MQLやSQLの定義が営業とマーケティングでズレる原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
    cat: 'Marketing / Sales',
    date: '2026-05-07',
  },
  {
    slug: 'what-is-revenue-visibility',
    title: 'Revenue Visibilityとは何か｜売上が見える状態の正体',
    desc: 'Revenue Visibility（収益可視性）とは何かを、RevOps・CRM・KPI・Revenue Architectureの観点から解説します。',
    cat: 'Revenue Architecture',
    date: '2026-05-07',
  },
  {
    slug: 'what-is-revenue-data-flow',
    title: 'Revenue Data Flowとは何か｜なぜ数字がつながらないのか',
    desc: 'Salesforce、HubSpot、Kintone、BIなどで数字が一致しない原因を、Revenue Data FlowとRevenue Architectureの観点から解説します。',
    cat: 'Revenue Architecture',
    date: '2026-05-07',
  },
];

// カテゴリの色マッピング
const catColor: Record<string, string> = {
  'Revenue Architecture': 'cat--ra',
  'CRM / RevOps':         'cat--crm',
  'RevOps / KPI':         'cat--kpi',
  'RevOps / Customer Success': 'cat--cs',
  'Marketing / RevOps':   'cat--mkt',
  'Marketing / Sales':    'cat--mkt',
  'BI / RevOps':          'cat--bi',
  'HubSpot / RevOps':     'cat--hs',
  'Salesforce / RevOps':  'cat--sf',
  'Sales / RevOps':       'cat--sales',
  'Sales / CRM':          'cat--sales',
  'RevOps':               'cat--revops',
};

function catClass(cat: string) {
  return catColor[cat] ?? 'cat--default';
}

function fmtDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y}年${parseInt(m)}月${parseInt(d)}日`;
}
---

<BaseLayout
  title="コラム | Consilegy"
  description="RevOps・Revenue Architecture・CRM・KPIに関する実践コラム。日本のBtoB企業の課題を構造から解説します。"
>
<div class="ins-page">

  <!-- ===== HEADER ===== -->
  <header class="ins-head">
    <div class="container"><div class="ins-head__inner">
      <p class="ins-head__eyebrow">Insights</p>
      <h1 class="ins-head__title">コラム</h1>
      <p class="ins-head__lede">RevOps・Revenue Architecture・CRM・KPI設計に関する実践コラム。<br class="br-pc" />日本のBtoB企業が直面する課題の構造を、実務の観点から解説します。</p>
      <p class="ins-head__count">{articles.length}本の記事</p>
    </div></div>
  </header>

  <!-- ===== GRID ===== -->
  <section class="ins-grid-wrap container">
    <ul class="ins-grid" role="list">
      {articles.map((a, i) => (
        <li class="ins-card">
          <a href={`/insights/${a.slug}/`} class="ins-card__link">
            <div class="ins-card__top">
              <span class={`ins-card__cat ${catClass(a.cat)}`}>{a.cat}</span>
              {i < 3 && <span class="ins-card__new">NEW</span>}
            </div>
            <h2 class="ins-card__title">{a.title}</h2>
            <p class="ins-card__desc">{a.desc}</p>
            <div class="ins-card__foot">
              <span class="ins-card__date">{fmtDate(a.date)}</span>
              <span class="ins-card__read">約10分</span>
              <span class="ins-card__arrow" aria-hidden="true">→</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ===== CTA ===== -->
  <div class="ins-cta container">
    <div class="ins-cta__inner">
      <p class="ins-cta__eyebrow">Revenue Architecture</p>
      <h2 class="ins-cta__title">記事の内容についてご相談ください</h2>
      <p class="ins-cta__body">RevOps・CRM・KPI設計の課題を30分でヒアリングし、構造的な論点を整理します。</p>
      <a href="/free-consultation/" class="ins-cta__btn">30分無料相談を予約</a>
    </div>
  </div>

</div>
</BaseLayout>

<style>
.ins-page { background: #fff; }
.container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

/* ===== HEADER ===== */
.ins-head {
  background: linear-gradient(160deg, #f8fafc 0%, #eff6ff 100%);
  border-bottom: 1px solid #e2e8f0;
  padding: 64px 0 48px;
}
.ins-head__inner { max-width: 780px; }
.ins-head__eyebrow {
  font-size: .72rem; font-weight: 800; letter-spacing: .18em;
  text-transform: uppercase; color: #1e40af; margin: 0 0 14px;
}
.ins-head__title {
  font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 800;
  color: #0f172a; letter-spacing: -.03em; margin: 0 0 16px; line-height: 1.2;
}
.ins-head__lede {
  font-size: 1rem; color: #334155; line-height: 1.8; margin: 0 0 20px;
}
.ins-head__count {
  display: inline-block; font-size: .78rem; font-weight: 600;
  color: #64748b; background: #fff; border: 1px solid #e2e8f0;
  border-radius: 4px; padding: 4px 14px; margin: 0;
}
.br-pc { display: block; }

/* ===== GRID ===== */
.ins-grid-wrap { padding: 56px 24px 48px; }
.ins-grid {
  list-style: none; padding: 0; margin: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

/* ===== CARD ===== */
.ins-card {
  border: 1px solid #e2e8f0; border-radius: 8px; background: #fff;
  transition: box-shadow .2s ease, transform .2s ease, border-color .2s ease;
}
.ins-card:hover {
  box-shadow: 0 8px 32px rgba(15,23,42,.10);
  transform: translateY(-3px);
  border-color: #bfdbfe;
}
.ins-card__link {
  display: flex; flex-direction: column; gap: 0;
  padding: 24px 22px 20px; height: 100%; text-decoration: none; color: inherit;
}

.ins-card__top {
  display: flex; align-items: center; gap: 8px; margin-bottom: 12px;
}
.ins-card__cat {
  font-size: .68rem; font-weight: 700; letter-spacing: .04em;
  border-radius: 4px; padding: 3px 10px; border: 1px solid;
}
/* category colors — 2-tone system: accent (navy) or muted (slate) */
.cat--ra,
.cat--crm,
.cat--kpi,
.cat--sf,
.cat--revops  { background: #eff6ff; color: #1e40af; border-color: #bfdbfe; }
.cat--cs,
.cat--mkt,
.cat--bi,
.cat--hs,
.cat--sales,
.cat--default { background: #f8fafc; color: #475569; border-color: #e2e8f0; }

.ins-card__new {
  font-size: .6rem; font-weight: 800; letter-spacing: .08em;
  background: #1e40af; color: #fff; border-radius: 3px; padding: 2px 6px;
}

.ins-card__title {
  font-size: .97rem; font-weight: 700; color: #0f172a;
  line-height: 1.55; margin: 0 0 10px; flex-grow: 1;
}
.ins-card:hover .ins-card__title { color: #1e40af; }

.ins-card__desc {
  font-size: .82rem; color: #64748b; line-height: 1.7;
  margin: 0 0 16px;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
  overflow: hidden;
}

.ins-card__foot {
  display: flex; align-items: center; gap: 10px;
  padding-top: 14px; border-top: 1px solid #f1f5f9;
  margin-top: auto;
}
.ins-card__date { font-size: .72rem; color: #94a3b8; }
.ins-card__read { font-size: .72rem; color: #94a3b8; }
.ins-card__arrow {
  margin-left: auto; font-size: .9rem; color: #bfdbfe;
  transition: transform .18s ease, color .18s ease;
}
.ins-card:hover .ins-card__arrow { transform: translateX(4px); color: #1e40af; }

/* ===== CTA ===== */
.ins-cta { padding: 0 24px 80px; }
.ins-cta__inner {
  background:
    radial-gradient(800px 360px at 85% -5%, rgba(124,92,191,0.35), transparent 55%),
    linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%);
  border-radius: 8px; padding: 52px 48px; color: #fff; text-align: center;
}
.ins-cta__eyebrow {
  font-size: .72rem; font-weight: 800; letter-spacing: .12em;
  text-transform: uppercase; opacity: .7; margin: 0 0 12px;
}
.ins-cta__title  { font-size: clamp(1.3rem, 2.5vw, 1.7rem); font-weight: 700; line-height: 1.45; margin: 0 0 14px; }
.ins-cta__body   { font-size: .95rem; opacity: .85; line-height: 1.7; margin: 0 0 28px; }
.ins-cta__btn {
  display: inline-block; background: #fff; color: #1e40af;
  font-weight: 700; font-size: .95rem; border-radius: 8px;
  padding: 13px 32px; text-decoration: none;
  transition: background .18s ease;
}
.ins-cta__btn:hover { background: #f0f9ff; }

/* ===== RESPONSIVE ===== */
@media (max-width: 960px) {
  .ins-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .br-pc { display: none; }
  .ins-head { padding: 40px 0 32px; }
  .ins-grid-wrap { padding: 36px 16px 32px; }
  .ins-grid { grid-template-columns: 1fr; gap: 14px; }
  .ins-card__link { padding: 20px 18px 16px; }
  .ins-cta__inner { padding: 36px 24px; }
  .ins-cta { padding: 0 16px 60px; }
}
</style>
