---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
---

<BaseLayout
  title="About | Consilegy"
  description="Consilegy helps global B2B teams design and operate revenue systems for Japan. Learn about the founder and what we believe."
  lang="en"
  alternateUrl="/company/"
>
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://consilegy.com/en/"},
    {"@type": "ListItem", "position": 2, "name": "About", "item": "https://consilegy.com/en/company/"}
  ]
})} />
<script type="application/ld+json" slot="head" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://consilegy.com/company/#founder",
  "name": "Seiko Yamaguchi",
  "alternateName": "山口 聖子",
  "jobTitle": "Founder / Revenue Architect",
  "worksFor": { "@id": "https://consilegy.com/#organization" },
  "url": "https://consilegy.com/en/company/",
  "image": "https://consilegy.com/images/common/seiko-yamaguchi.jpg",
  "knowsLanguage": ["ja", "en"],
  "knowsAbout": ["Revenue Architecture", "RevOps", "Japan GTM", "CRM Implementation", "HubSpot", "Salesforce", "B2B Marketing"],
  "hasCredential": [
    { "@type": "EducationalOccupationalCredential", "name": "HubSpot Marketing Software Certification" },
    { "@type": "EducationalOccupationalCredential", "name": "Google Analytics Certification" },
    { "@type": "EducationalOccupationalCredential", "name": "Shopify Partner Certification" }
  ],
  "sameAs": ["https://www.linkedin.com/company/consilegy"]
})} />

  <!-- Hero -->
  <section class="ab-hero">
    <div class="container ab-hero__inner">
      <p class="ab-hero__eyebrow">About</p>
      <h1 class="ab-hero__title">We design strategy, turn it into systems, and stay until it works.</h1>
      <p class="ab-hero__sub">Consilegy supports global and Japan-based teams across Japan GTM strategy, revenue architecture, CRM implementation, and operational adoption.</p>
      <a class="ab-hero__cta" href="/en/contact/">Contact Us</a>
    </div>
  </section>

  <!-- Founder -->
  <section class="ab-founder">
    <div class="container ab-founder__inner">
      <h2 class="ab-section-label">Founder</h2>
      <div class="ab-founder__layout">
        <div class="ab-founder__photo-col">
          <img
            class="ab-founder__photo"
            src="/images/media/2025/12/seiko_biz_.jpg"
            alt="Seiko Yamaguchi"
            width="220"
            height="220"
            loading="lazy"
          />
        </div>
        <div class="ab-founder__bio-col">
          <h3 class="ab-founder__name">Seiko Yamaguchi</h3>
          <p class="ab-founder__role">Founder, Consilegy LLC</p>
          <div class="ab-founder__bio">
            <p>Seiko began her career in IT consulting, then built an independent practice in 2015 advising companies across Tokyo on marketing strategy, CRM implementation, and project management. Her client work spanned SaaS, consulting, healthcare, retail, and entertainment, with a consistent focus on Japan-facing and cross-border B2B contexts. She founded Consilegy LLC in 2025 to bring that work together under a dedicated firm for Japan-facing revenue architecture.</p>
            <p>Her work sits at the intersection of strategy and execution: designing the GTM structure, revenue architecture, and operating systems that allow global teams to move effectively in Japan. She holds a PMBOK-based project management background and brings hands-on delivery experience across both market-facing design and CRM/RevOps implementation.</p>
            <p>Bilingual in Japanese and English, she works directly with both sides of global-Japan teams, reducing the friction that typically accumulates when strategy is designed in one language and executed in another.</p>
          </div>
          <div class="ab-founder__creds">
            <p class="ab-founder__creds-label">Certifications</p>
            <ul class="ab-founder__creds-list">
              <li>HubSpot: Marketing Software Certification</li>
              <li>Google: Analytics Individual Qualification (GAIQ) · Ads Search, Display, Video, Shopping, Measurement</li>
              <li>Shopify: Theme Development · Product Fundamentals</li>
            </ul>
          </div>
          <a class="ab-founder__linkedin" href="https://www.linkedin.com/in/seiko-yamaguchi/" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Consilegy -->
  <section class="ab-why">
    <div class="container ab-why__inner">
      <h2 class="ab-section-label">Why Consilegy</h2>
      <ul class="ab-why__list">
        <li class="ab-why__item">
          <strong>Japan market depth</strong>
          <p>We understand the structural gap between global go-to-market logic and how business moves in Japan, from trust-building cycles to stakeholder dynamics to decision criteria.</p>
        </li>
        <li class="ab-why__item">
          <strong>Bilingual execution</strong>
          <p>We work fluently in both English and Japanese, reducing the friction that accumulates when strategy is designed in one language and executed in another.</p>
        </li>
        <li class="ab-why__item">
          <strong>Strategy through implementation</strong>
          <p>We don't stop at recommendations. We connect planning to CRM configuration, workflow design, and operational launch, and stay until the system works.</p>
        </li>
        <li class="ab-why__item">
          <strong>Disciplined delivery</strong>
          <p>We manage scope, dependencies, and cross-functional execution with PMBOK-grounded project discipline, not just consulting-style advisory.</p>
        </li>
        <li class="ab-why__item">
          <strong>HubSpot and RevOps experience</strong>
          <p>We support CRM implementation, workflow design, reporting, and adoption with practical delivery experience across real engagements.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Track Record -->
  <section class="ab-track">
    <div class="container ab-track__inner">
      <h2 class="ab-section-label">Track Record</h2>
      <p class="ab-track__lead">10+ years, 30+ engagements across SaaS, consulting, healthcare, retail, entertainment, and cross-border B2B.</p>
      <div class="ab-track__grid">
        <div class="ab-track__card">
          <p class="ab-track__cat">Revenue Architecture / CRM / Data Infrastructure</p>
          <div class="ab-track__tags">
            <span class="ab-track__tag">Nishikawa Co., Ltd.</span>
            <span class="ab-track__tag">elife Inc.</span>
            <span class="ab-track__tag">Alibaba Japan</span>
            <span class="ab-track__tag">Kaizen Platform</span>
          </div>
        </div>
        <div class="ab-track__card">
          <p class="ab-track__cat">Marketing Strategy / Project Management</p>
          <div class="ab-track__tags">
            <span class="ab-track__tag">Moloco Japan</span>
            <span class="ab-track__tag">MSL Japan</span>
            <span class="ab-track__tag">UCC Ueshima Coffee</span>
            <span class="ab-track__tag">Innova Inc.</span>
            <span class="ab-track__tag">THE MOLTS</span>
            <span class="ab-track__tag">Sazae Pty Ltd</span>
          </div>
        </div>
      </div>
      <p class="ab-track__note">Includes representative engagements by founder Seiko Yamaguchi.</p>
    </div>
  </section>

  <!-- What we believe -->
  <section class="ab-beliefs">
    <div class="container ab-beliefs__inner">
      <h2 class="ab-section-label">What we believe</h2>
      <div class="ab-beliefs__grid">
        <div class="ab-belief">
          <strong>Decide with hypotheses and data</strong>
          <p>Measurable assumptions over vague opinions. We build the infrastructure that makes data usable for decisions.</p>
        </div>
        <div class="ab-belief">
          <strong>Tie work to outcomes</strong>
          <p>Delivery that doesn't connect to business results isn't finished. We define what success looks like before we start.</p>
        </div>
        <div class="ab-belief">
          <strong>Test small and learn fast</strong>
          <p>Progress through validation is more reliable than overbuilt planning. We prefer reversible steps and clear signals.</p>
        </div>
        <div class="ab-belief">
          <strong>Take responsibility for delivery</strong>
          <p>We care about whether the thing actually works, not just whether the work was done. That distinction shapes how we engage.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Company Info -->
  <section class="ab-info">
    <div class="container ab-info__inner">
      <h2 class="ab-section-label">Company</h2>
      <dl class="ab-info__dl">
        <dt>Company name</dt><dd>Consilegy LLC</dd>
        <dt>Founded</dt><dd>May 2025</dd>
        <dt>Location</dt><dd>〒107-0061 R-Cube Aoyama 3F, 1-3-1 Kita-Aoyama, Minato-ku, Tokyo, Japan</dd>
        <dt>Corporate number</dt><dd>2010403035111</dd>
      </dl>
    </div>
  </section>

  <CTA
    title="Working with a Japan-facing revenue challenge?"
    href="/en/contact/"
    label="Get in touch"
  />

</BaseLayout>

<style>
  /* ── Shared ────────────────────────────────────── */
  .ab-section-label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-xl);
  }

  /* ── Hero ──────────────────────────────────────── */
  .ab-hero {
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-2xl);
  }

  .ab-hero__eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0 0 var(--space-md);
  }

  .ab-hero__title {
    font-size: clamp(1.55rem, 3vw, 2.2rem);
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.25;
    color: var(--color-text);
    margin: 0 0 var(--space-lg);
    max-width: 760px;
  }

  .ab-hero__sub {
    font-size: var(--text-lead);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin: 0 0 var(--space-xl);
    max-width: 60ch;
  }

  .ab-hero__cta {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 700;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .ab-hero__cta:hover {
    background: var(--color-primary-dark, #1e3a8a);
  }

  /* ── Founder ───────────────────────────────────── */
  .ab-founder {
    padding-block: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .ab-founder__inner {
    max-width: 900px;
  }

  .ab-founder__layout {
    display: flex;
    gap: var(--space-2xl);
    align-items: flex-start;
  }

  .ab-founder__photo-col {
    flex-shrink: 0;
  }

  .ab-founder__photo {
    width: 180px;
    height: 180px;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  .ab-founder__bio-col {
    flex: 1;
    min-width: 0;
  }

  .ab-founder__name {
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    margin: 0 0 0.25rem;
    color: var(--color-text);
  }

  .ab-founder__role {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-lg);
  }

  .ab-founder__bio p {
    margin: 0 0 var(--space-md);
    line-height: 1.75;
    color: var(--color-text);
  }

  .ab-founder__creds {
    margin-top: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .ab-founder__creds-label {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-sm);
  }

  .ab-founder__creds-list {
    margin: 0;
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .ab-founder__creds-list li {
    margin-bottom: 0.25rem;
  }

  .ab-founder__linkedin {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: var(--space-md);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .ab-founder__linkedin:hover {
    text-decoration: underline;
  }

  /* ── Why Consilegy ─────────────────────────────── */
  .ab-why {
    padding-block: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .ab-why__inner {
    max-width: 760px;
  }

  .ab-why__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .ab-why__item {
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .ab-why__item strong {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .ab-why__item p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.9375rem;
  }

  /* ── Beliefs ───────────────────────────────────── */
  .ab-track {
    padding-block: var(--space-xl);
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }
  .ab-track__inner { max-width: 900px; }
  .ab-track__lead {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin: 0.5rem 0 1.75rem;
    line-height: 1.7;
  }
  .ab-track__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1rem;
  }
  .ab-track__card {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-subtle);
  }
  .ab-track__cat {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.875rem;
  }
  .ab-track__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .ab-track__tag {
    font-size: 0.8125rem;
    color: var(--color-text);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.25rem 0.625rem;
  }
  .ab-track__note {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .ab-beliefs {
    padding-block: var(--space-2xl);
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }

  .ab-beliefs__inner {
    max-width: 900px;
  }

  .ab-beliefs__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .ab-belief {
    padding: var(--space-lg);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .ab-belief strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .ab-belief p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* ── Company Info ──────────────────────────────── */
  .ab-info {
    padding-block: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }

  .ab-info__inner {
    max-width: 540px;
  }

  .ab-info__dl {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1.5rem;
    font-size: 0.9375rem;
  }

  .ab-info__dl dt {
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
  }

  .ab-info__dl dd {
    margin: 0;
    color: var(--color-text-muted);
  }

  /* ── Responsive ────────────────────────────────── */
  @media (max-width: 640px) {
    .ab-founder__layout {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .ab-founder__photo {
      width: 140px;
      height: 140px;
    }

    .ab-beliefs__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
