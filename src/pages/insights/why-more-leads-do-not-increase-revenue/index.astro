/* =============================================
   DIAGRAM 1 — .diag--lead-gap
   ============================================= */
.diag--lead-gap {}

.diag-lg-header { text-align: center; margin-bottom: 24px; }
.diag-lg-header__label { display: inline-block; font-size: .72rem; font-weight: 700; color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; border-radius: 4px; padding: 4px 14px; letter-spacing: .04em; }

.diag-lg-grid { display: grid; grid-template-columns: 1fr auto auto auto 1fr; gap: 12px; align-items: center; }

.diag-lg-dept { background: #f8fafc; border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; padding: 16px 14px; text-align: center; }
.diag-lg-dept__badge { display: inline-block; font-size: .7rem; font-weight: 700; border-radius: 4px; padding: 3px 10px; margin-bottom: 8px; }
.diag-lg-dept__badge--mkt   { background: #fff7ed; color: #c2410c; border: 1px solid #fed7aa; }
.diag-lg-dept__badge--sales { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; }
.diag-lg-dept__kpi   { font-size: .75rem; font-weight: 600; color: var(--color-navy, #0f172a); margin-bottom: 8px; }
.diag-lg-dept__tools { display: flex; flex-wrap: wrap; justify-content: center; gap: 4px; }
.diag-lg-dept__tools span { font-size: .65rem; color: var(--color-muted, #64748b); background: #f1f5f9; border-radius: 3px; padding: 2px 6px; }

