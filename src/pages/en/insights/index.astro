---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const featured = {
  slug: 'why-japan-gtm-is-not-just-localization',
  title: 'Why Japan GTM Is Not Just Localization',
  desc: 'Japan GTM is not simply translating global assets into Japanese. It requires adapting messaging, trust signals, conversion paths, sales follow-up, and revenue operations to Japan\'s buying context.',
  cat: 'Japan GTM',
  readTime: 'About 6 min',
};

const japanGTM = [
  {
    slug: 'where-japan-gtm-breaks-after-lead-generation',
    title: 'Where Japan GTM Breaks After Lead Generation',
    desc: 'Japan GTM often does not break at lead generation. It breaks after: when qualification, ownership, follow-up, CRM stages, and reporting are unclear or undesigned.',
    readTime: 'About 5 min',
  },
  {
    slug: 'why-global-b2b-messaging-often-fails-in-japan',
    title: 'Why Global B2B Messaging Often Fails in Japan',
    desc: 'Global B2B messaging often fails in Japan not because the product is weak, but because the message does not match how Japanese buyers evaluate trust, risk, and operational fit.',
    readTime: 'About 6 min',
  },
  {
    slug: 'how-to-design-a-japan-ready-revenue-funnel-before-hiring-sales',
    title: 'How to Design a Japan-Ready Revenue Funnel Before Hiring Sales',
    desc: 'Before hiring sales in Japan, global B2B teams should clarify positioning, qualification criteria, handoff rules, CRM stages, follow-up logic, and reporting structure.',
    readTime: 'About 7 min',
  },
  {
    slug: 'what-global-b2b-companies-should-prepare-before-entering-japan',
    title: 'What Global B2B Companies Should Prepare Before Entering Japan',
    desc: 'Global B2B companies entering Japan often underestimate what needs to be designed before launch, from ICP assumptions and buyer expectations to proof points, partner strategy, and CRM readiness.',
    readTime: 'About 6 min',
  },
  {
    slug: 'japan-market-entry-for-b2b-saas-common-gtm-mistakes',
    title: 'Japan Market Entry for B2B SaaS: Common GTM Mistakes',
    desc: 'The most common Japan GTM mistakes for B2B SaaS are not product problems. They are design problems in messaging, sales motion, proof strategy, and revenue operations structure.',
    readTime: 'About 5 min',
  },
  {
    slug: 'how-japanese-b2b-buyers-evaluate-trust-and-risk',
    title: 'How Japanese B2B Buyers Evaluate Trust and Risk',
    desc: 'Japanese B2B buyers evaluate vendors across six dimensions: trust formation, risk reduction, vendor credibility, proof and reassurance, internal consensus, and long-term support expectations.',
    readTime: 'About 6 min',
  },
  {
    slug: 'how-to-adapt-a-global-b2b-landing-page-for-japan',
    title: 'How to Adapt a Global B2B Landing Page for Japan',
    desc: 'Adapting a global B2B landing page for Japan means redesigning the argument structure, not just translating words. Japanese buyers need different headline logic, proof types, CTAs, and FAQs.',
    readTime: 'About 5 min',
  },
  {
    slug: 'what-makes-a-japan-gtm-plan-execution-ready',
    title: 'What Makes a Japan GTM Plan Execution-Ready',
    desc: 'An execution-ready Japan GTM plan defines eight elements: target segment, messaging, funnel assumptions, lead flow, CRM stages, owner definitions, reporting, and a 90-day execution plan.',
    readTime: 'About 6 min',
  },
];

const revenueArch = [
  {
    slug: 'what-revenue-architecture-means-for-japan-gtm',
    title: 'What Revenue Architecture Means for Japan GTM',
    desc: 'Revenue architecture means designing the operating structure that connects market messaging, lead flow, CRM stages, handoff rules, and reporting so Japan-facing revenue execution can work in practice.',
    readTime: 'About 5 min',
  },
  {
    slug: 'why-crm-implementation-fails-without-revenue-architecture',
    title: 'Why CRM Implementation Fails Without Revenue Architecture',
    desc: 'Most CRM implementations fail not because of the tool but because the revenue structure it needs, including lifecycle stages, handoff rules, qualification criteria, and reporting logic, was never designed first.',
    readTime: 'About 5 min',
  },
  {
    slug: 'how-to-define-lifecycle-stages-for-japan-facing-revenue-operations',
    title: 'How to Define Lifecycle Stages for Japan-Facing Revenue Operations',
    desc: 'Defining lifecycle stages for Japan-facing revenue operations requires adapting global stage definitions to Japan\'s longer evaluation cycles, multi-stakeholder approval patterns, and relationship-first buying context.',
    readTime: 'About 6 min',
  },
  {
    slug: 'lead-handoff-rules-for-japan-gtm-teams',
    title: 'Lead Handoff Rules for Japan GTM Teams',
    desc: 'Lead handoff rules define when a lead moves from marketing to sales, who owns follow-up at each stage, and what criteria must be met. Without them, Japan pipeline breaks between capture and close.',
    readTime: 'About 5 min',
  },
  {
    slug: 'how-to-build-revenue-visibility-for-japan-market-expansion',
    title: 'How to Build Revenue Visibility for Japan Market Expansion',
    desc: 'Revenue visibility for Japan requires tracking Japan-specific pipeline metrics such as MQL volume, MQL-to-SQL rate, sales cycle length, and win rate, separately from global reporting.',
    readTime: 'About 6 min',
  },
  {
    slug: 'revops-for-japan-gtm-what-global-teams-need-to-localize',
    title: 'RevOps for Japan GTM: What Global Teams Need to Localize',
    desc: 'Revenue operations designed for US or European markets often fails in Japan. Five areas require localization: CRM stage definitions, lead qualification criteria, handoff rules, follow-up logic, and reporting.',
    readTime: 'About 5 min',
  },
];

const hubspot = [
  {
    slug: 'hubspot-implementation-for-japan-gtm-what-to-configure-first',
    title: 'HubSpot Implementation for Japan GTM: What to Configure First',
    desc: 'HubSpot out of the box is not Japan-ready. Configuration order matters: lifecycle stages first, then Japan-specific properties, pipeline stages, handoff workflows, and Japan-focused reporting dashboards.',
    readTime: 'About 6 min',
  },
  {
    slug: 'hubspot-lifecycle-stages-vs-lead-status-for-japan-gtm',
    title: 'HubSpot Lifecycle Stages vs Lead Status for Japan GTM',
    desc: 'HubSpot uses two systems to track leads: lifecycle stages and lead status. Understanding how both work, and configuring each for Japan\'s buying cycle, is essential for accurate Japan GTM reporting.',
    readTime: 'About 5 min',
  },
  {
    slug: 'how-to-design-hubspot-workflows-for-japan-lead-follow-up',
    title: 'How to Design HubSpot Workflows for Japan Lead Follow-Up',
    desc: 'Japan lead follow-up requires a different workflow design than global defaults. Timing, messaging tone, task assignment logic, and handoff triggers all need to be adapted to Japan\'s evaluation pace.',
    readTime: 'About 6 min',
  },
  {
    slug: 'hubspot-dashboards-for-japan-revenue-visibility',
    title: 'HubSpot Dashboards for Japan Revenue Visibility',
    desc: 'Default HubSpot dashboards show global aggregate data. Japan-facing teams need separate dashboard views tracking Japan MQL volume, pipeline value, sales cycle length, win rate, and quarterly revenue.',
    readTime: 'About 5 min',
  },
  {
    slug: 'when-global-teams-should-use-hubspot-for-japan-market-entry',
    title: 'When Global Teams Should Use HubSpot for Japan Market Entry',
    desc: 'HubSpot is a strong fit for global teams entering Japan when already in use and properly configured. The key question is not whether to use it, but what to configure before relying on it.',
    readTime: 'About 5 min',
  },
];
---

<BaseLayout
  title="Insights | Consilegy"
  description="Practical articles on Revenue Architecture, Japan GTM, CRM adoption, and RevOps for global B2B teams operating in Japan."
  lang="en"
  alternateUrl="/insights/"
>

<div class="ins-wrap">

  <!-- Hero -->
  <section class="ins-hero">
    <div class="ins-container">
      <p class="ins-eyebrow">Insights</p>
      <h1>Japan RevOps, GTM & Revenue Architecture Insights</h1>
      <p class="ins-hero-desc">Practical articles on Revenue Architecture, Japan GTM, CRM adoption, and RevOps for global B2B teams operating in Japan.</p>
    </div>
  </section>

  <!-- Featured -->
  <section class="ins-featured">
    <div class="ins-container">
      <a href={`/en/insights/${featured.slug}/`} class="ins-featured-card">
        <div class="ins-featured-card__meta">
          <span class="ins-featured-badge">Featured</span>
          <span class="ins-badge">{featured.cat}</span>
          <span class="ins-read">{featured.readTime}</span>
        </div>
        <h2 class="ins-featured-card__title">{featured.title}</h2>
        <p class="ins-featured-card__desc">{featured.desc}</p>
        <span class="ins-featured-card__link">Read article →</span>
      </a>
    </div>
  </section>

  <!-- Japan GTM -->
  <section class="ins-category">
    <div class="ins-container">
      <div class="ins-category__head">
        <h2 class="ins-category__title">Japan GTM</h2>
        <p class="ins-category__desc">Adapting go-to-market strategy for Japan's B2B buying context.</p>
      </div>
      <div class="ins-grid">
        {japanGTM.map(({ slug, title, desc, readTime }) => (
          <a href={`/en/insights/${slug}/`} class="ins-card">
            <div class="ins-card__meta">
              <span class="ins-badge">Japan GTM</span>
              {readTime && <span class="ins-read">{readTime}</span>}
            </div>
            <h3 class="ins-card__title">{title}</h3>
            <p class="ins-card__desc">{desc}</p>
            <span class="ins-card__link">Read article →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Revenue Architecture -->
  <section class="ins-category ins-category--alt">
    <div class="ins-container">
      <div class="ins-category__head">
        <h2 class="ins-category__title">Revenue Architecture</h2>
        <p class="ins-category__desc">Designing the revenue operating system that makes Japan GTM work in practice.</p>
      </div>
      <div class="ins-grid">
        {revenueArch.map(({ slug, title, desc, readTime }) => (
          <a href={`/en/insights/${slug}/`} class="ins-card">
            <div class="ins-card__meta">
              <span class="ins-badge ins-badge--rev">Revenue Architecture</span>
              {readTime && <span class="ins-read">{readTime}</span>}
            </div>
            <h3 class="ins-card__title">{title}</h3>
            <p class="ins-card__desc">{desc}</p>
            <span class="ins-card__link">Read article →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HubSpot & CRM -->
  <section class="ins-category">
    <div class="ins-container">
      <div class="ins-category__head">
        <h2 class="ins-category__title">HubSpot &amp; CRM</h2>
        <p class="ins-category__desc">Configuring HubSpot and CRM tools for Japan-facing revenue operations.</p>
      </div>
      <div class="ins-grid">
        {hubspot.map(({ slug, title, desc, readTime }) => (
          <a href={`/en/insights/${slug}/`} class="ins-card">
            <div class="ins-card__meta">
              <span class="ins-badge ins-badge--hs">HubSpot &amp; CRM</span>
              {readTime && <span class="ins-read">{readTime}</span>}
            </div>
            <h3 class="ins-card__title">{title}</h3>
            <p class="ins-card__desc">{desc}</p>
            <span class="ins-card__link">Read article →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="ins-nl">
    <div class="ins-container">
      <div class="ins-nl__inner">
        <div class="ins-nl__copy">
          <p class="ins-nl__eyebrow">Newsletter</p>
          <h2 class="ins-nl__title">Go deeper with the B2B Revenue Playbook</h2>
          <p class="ins-nl__desc">A newsletter for global B2B teams working on Revenue Architecture, Japan GTM, CRM adoption, pipeline design, and forecast visibility. Each issue is a practical operating framework, not an article roundup.</p>
        </div>
        <a href="/en/newsletter/" class="ins-nl__btn">Explore the newsletter →</a>
      </div>
    </div>
  </section>

</div>

<style>
/* ── Base ─────────────────────────────────────────── */
.ins-wrap { background: #fff; }
.ins-container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

/* ── Hero ─────────────────────────────────────────── */
.ins-hero {
  background: var(--color-bg-subtle, #f8fafc);
  border-bottom: 1px solid var(--color-border, #e2e8f0);
  padding: 64px 0 56px;
}
.ins-eyebrow {
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--color-primary, #1e40af);
  margin: 0 0 12px;
}
.ins-hero h1 {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 600; color: var(--color-navy, #0f172a);
  margin: 0 0 16px; letter-spacing: 0.01em;
}
.ins-hero-desc {
  font-size: 1rem; color: var(--color-text-muted, #64748b);
  line-height: 1.8; margin: 0; max-width: 560px;
}

/* ── Shared badges / meta ─────────────────────────── */
.ins-badge {
  display: inline-block;
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.06em;
  text-transform: uppercase;
  background: #eff6ff; color: #1e40af;
  padding: 2px 9px; border-radius: 8px;
}
.ins-badge--rev { background: #f0fdf4; color: #166534; }
.ins-badge--hs  { background: #fff7ed; color: #9a3412; }
.ins-read {
  font-size: 0.78rem; color: #94a3b8;
}

/* ── Featured card ────────────────────────────────── */
.ins-featured { padding: 48px 0 0; }
.ins-featured-card {
  display: block; text-decoration: none;
  background: #eff6ff;
  border: 1.5px solid #93c5fd;
  border-left: 4px solid #1e40af;
  border-radius: 10px;
  padding: 32px 36px;
  transition: box-shadow 0.15s, border-color 0.15s;
}
.ins-featured-card:hover {
  box-shadow: 0 6px 24px rgba(30,64,175,0.12);
  border-color: #1e40af;
}
.ins-featured-card__meta {
  display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
}
.ins-featured-badge {
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.07em;
  text-transform: uppercase;
  background: #1e40af; color: #fff;
  padding: 2px 9px; border-radius: 8px;
}
.ins-featured-card__title {
  font-size: clamp(1.125rem, 2.5vw, 1.375rem);
  font-weight: 600; color: #0f172a;
  margin: 0 0 10px; letter-spacing: 0.01em; line-height: 1.3;
}
.ins-featured-card__desc {
  font-size: 0.9375rem; color: #475569;
  line-height: 1.75; margin: 0 0 18px;
  max-width: 700px;
}
.ins-featured-card__link {
  font-size: 0.875rem; font-weight: 700; color: #1e40af;
}

/* ── Category section ─────────────────────────────── */
.ins-category { padding: 48px 0 56px; border-top: 1px solid #e2e8f0; }
.ins-category--alt { background: #f8fafc; }
.ins-category--alt .ins-card { background: #fff; }

.ins-category__head { margin-bottom: 28px; }
.ins-category__title {
  font-size: 1.125rem; font-weight: 600; color: #0f172a;
  margin: 0 0 6px; letter-spacing: 0.01em;
}
.ins-category__desc {
  font-size: 0.875rem; color: #64748b; margin: 0;
}

/* ── Card grid ────────────────────────────────────── */
.ins-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

/* ── Individual card ──────────────────────────────── */
.ins-card {
  display: flex; flex-direction: column; gap: 8px;
  padding: 20px 22px;
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
  text-decoration: none;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.ins-card:hover {
  border-color: #93c5fd;
  box-shadow: 0 4px 16px rgba(30,64,175,0.08);
}
.ins-card__meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.ins-card__title {
  font-size: 0.9375rem; font-weight: 600; color: #0f172a;
  margin: 0; line-height: 1.4;
  transition: color 0.15s;
}
.ins-card:hover .ins-card__title { color: #1e40af; }
.ins-card__desc {
  font-size: 0.8125rem; color: #64748b;
  line-height: 1.7; margin: 0; flex: 1;
}
.ins-card__link {
  font-size: 0.8125rem; font-weight: 600; color: #1e40af;
  margin-top: 4px;
}

/* ── Newsletter CTA ───────────────────────────────── */
.ins-nl {
  background: linear-gradient(135deg, #1e40af 0%, #3b82f6 55%, #987ad6 100%);
  padding: 64px 0;
}
.ins-nl__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  flex-wrap: wrap;
}
.ins-nl__eyebrow {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: #93c5fd;
  margin: 0 0 10px;
}
.ins-nl__title {
  font-size: clamp(1.3rem, 2.5vw, 1.75rem);
  font-weight: 700; color: #fff;
  margin: 0 0 12px; line-height: 1.3;
}
.ins-nl__desc {
  font-size: 0.9375rem; color: rgba(255,255,255,0.7);
  line-height: 1.75; margin: 0; max-width: 520px;
}
.ins-nl__btn {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  flex-shrink: 0;
  background: #fff;
  color: #1e40af;
  font-size: 0.9375rem;
  font-weight: 700;
  padding: 0.75rem 1.5rem;
  border-radius: 8px;
  text-decoration: none;
  transition: opacity 0.15s;
}
.ins-nl__btn:hover { opacity: 0.88; }

/* ── Responsive ───────────────────────────────────── */
@media (max-width: 900px) {
  .ins-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 600px) {
  .ins-grid { grid-template-columns: 1fr; }
  .ins-featured-card { padding: 24px 20px; }
  .ins-featured-card__meta { flex-wrap: wrap; }
  .ins-nl__inner { flex-direction: column; align-items: flex-start; gap: 24px; }
}
</style>

</BaseLayout>
