const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: 'なぜSQL定義がズレるのか｜RevOpsとRevenue Architecture',
	description: 'MQLやSQLの定義が営業とマーケティングでズレる原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
	datePublished: pubDate,
	dateModified: pubDate,
	author: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	publisher: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	url: 'https://consilegy.com/insights/why-sql-definitions-break-between-marketing-and-sales/',
	inLanguage: 'ja',
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://consilegy.com/' },
		{ '@type': 'ListItem', position: 2, name: 'コラム', item: 'https://consilegy.com/insights/' },
		{ '@type': 'ListItem', position: 3, name: 'なぜマーケと営業で「SQL定義」がズレるのか', item: 'https://consilegy.com/insights/why-sql-definitions-break-between-marketing-and-sales/' },
	],
