/* ===== DIAGRAMS ===== */
.diag-wrap { margin: 0 0 56px; padding: 0; border: none; }
.diag { background: #f8fafc; border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; padding: 28px 24px; }
.diag-caption { font-size: 0.78rem; color: var(--color-muted, #64748b); text-align: center; margin-top: 10px; line-height: 1.5; }

/* --- DIAGRAM 1: SFA Chaos --- */
.diag--sfa-chaos { display: flex; flex-direction: column; gap: 16px; }
.sfa-header { text-align: center; font-size: 0.82rem; font-weight: 700; color: var(--color-muted, #64748b); letter-spacing: 0.05em; text-transform: uppercase; }
.sfa-row { display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; }
.sfa-tool { display: flex; flex-direction: column; align-items: center; gap: 6px; background: #fff; border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; padding: 14px 18px; min-width: 100px; }
.sfa-icon { width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 700; color: #fff; }
.icon-sf  { background: #00a1e0; }
.icon-mtg { background: #94a3b8; }
.icon-xl  { background: #217346; }
.sfa-tool-label { font-size: 0.78rem; font-weight: 600; color: var(--color-charcoal, #334155); }
.sfa-tool-sub { font-size: 0.7rem; color: var(--color-muted, #64748b); }
.sfa-divider { font-size: 1.2rem; color: var(--color-muted, #64748b); flex-shrink: 0; }
.sfa-bubbles { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; }
.sfa-bubble { background: #fff; border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; padding: 7px 14px; font-size: 0.78rem; color: var(--color-charcoal, #334155); }
.sfa-bubble--warn { background: #fff3cd; border-color: #fbbf24; color: #92400e; font-weight: 600; }
.sfa-result { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; padding-top: 4px; }
.sfa-tag { font-size: 0.75rem; font-weight: 600; }
.bad { color: #dc2626; }

/* --- DIAGRAM 2: Revenue Pipeline Design --- */
.diag--rpd { display: flex; flex-direction: column; gap: 14px; }
.rpd-header { text-align: center; font-size: 0.9rem; font-weight: 700; color: var(--color-navy, #0f172a); letter-spacing: 0.03em; }
.rpd-flow { display: flex; align-items: flex-start; justify-content: center; gap: 4px; flex-wrap: wrap; }
.rpd-stage { display: flex; flex-direction: column; align-items: center; gap: 5px; }
.rpd-box { padding: 8px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 700; color: #fff; text-align: center; white-space: nowrap; }
.box-lead   { background: #60a5fa; }
.box-sql    { background: #3b82f6; }
.box-opp    { background: #2563eb; }
.box-prop   { background: #1d4ed8; }
.box-commit { background: #1e40af; }
.box-won    { background: #0f172a; }
.rpd-exit { font-size: 0.67rem; color: var(--color-muted, #64748b); background: #fff; border: 1px solid var(--color-border, #e2e8f0); border-radius: 4px; padding: 2px 6px; white-space: nowrap; }
.rpd-arrow { font-size: 1rem; color: var(--color-muted, #64748b); flex-shrink: 0; padding-top: 8px; }
.rpd-bar { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 10px 16px; text-align: center; }
.rpd-bar-label { font-size: 0.78rem; font-weight: 600; color: var(--color-primary, #1e40af); }
.rpd-metrics { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
.rpd-metric { font-size: 0.72rem; background: #fff; border: 1px solid var(--color-border, #e2e8f0); color: var(--color-charcoal, #334155); border-radius: 8px; padding: 3px 10px; }

/* --- DIAGRAM 3: RA SFA Hub --- */
.diag--ra-sfa { display: flex; flex-direction: column; align-items: stretch; gap: 0; }
.ra-pills-row { display: flex; justify-content: center; gap: 8px; flex-wrap: wrap; padding-bottom: 4px; }
.ra-pill { background: #fff; border: 1px solid var(--color-border, #e2e8f0); border-radius: 4px; padding: 5px 14px; font-size: 0.75rem; font-weight: 600; color: var(--color-charcoal, #334155); white-space: nowrap; }
.ra-svg { width: 100%; height: 60px; display: block; }
.ra-core { background: var(--color-navy, #0f172a); color: #fff; border-radius: 8px; padding: 18px 20px; text-align: center; }
.ra-core-title { font-size: 1rem; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.02em; }
.ra-core-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; }
.ra-core-tags span { font-size: 0.7rem; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); border-radius: 4px; padding: 3px 9px; color: #e2e8f0; }
.ra-connector-bar { height: 24px; background: linear-gradient(180deg, var(--color-navy, #0f172a) 0%, #334155 100%); width: 2px; margin: 0 auto; }
.ra-outcomes { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
.ra-outcome { background: #fff; border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; padding: 14px 12px; text-align: center; }
.ra-outcome--mid { border-color: var(--color-primary, #1e40af); box-shadow: 0 0 0 1px var(--color-primary, #1e40af); }
.ra-outcome-title { font-size: 0.82rem; font-weight: 700; color: var(--color-navy, #0f172a); margin-bottom: 6px; }
.ra-outcome-sub { font-size: 0.72rem; color: var(--color-muted, #64748b); line-height: 1.5; }

/* ===== CTA ===== */
.article-cta { background: radial-gradient(800px 360px at 85% -5%, rgba(124,92,191,0.35), transparent 55%), linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%); border-radius: 8px; padding: 40px 36px; text-align: center; margin-bottom: 48px; }
.article-cta__catch { font-size: 1.15rem; font-weight: 700; color: #fff; margin-bottom: 12px; }
.article-cta__body { font-size: 0.92rem; color: rgba(255,255,255,0.88); line-height: 1.75; margin-bottom: 24px; }
.article-cta__btn { display: inline-block; background: #fff; color: var(--color-primary, #1e40af); font-weight: 700; font-size: 0.9rem; padding: 12px 28px; border-radius: 6px; text-decoration: none; transition: opacity 0.2s; }
.article-cta__btn:hover { opacity: 0.9; }

/* ===== RELATED ===== */
.article-related { border-top: 1px solid var(--color-border, #e2e8f0); padding-top: 32px; }
.article-related__heading { font-size: 0.9rem; font-weight: 700; color: var(--color-navy, #0f172a); margin-bottom: 16px; }
.article-related ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.article-related li a { font-size: 0.9rem; color: var(--color-primary, #1e40af); text-decoration: none; }
.article-related li a:hover { text-decoration: underline; }

/* ===== RESPONSIVE ===== */
@media (max-width: 700px) {
	.article-head h1 { font-size: 1.4rem; }
	.br-pc { display: none; }
	.rpd-flow { gap: 4px; }
	.rpd-box { font-size: 0.68rem; padding: 7px 7px; }
	.rpd-arrow { font-size: 0.85rem; }
	.ra-outcomes { grid-template-columns: 1fr; gap: 8px; }
	.article-cta { padding: 28px 20px; }
	.sfa-row { gap: 8px; }
}
@media (max-width: 480px) {
	.container { padding: 0 16px; }
	.rpd-exit { display: none; }
	.ra-outcomes { grid-template-columns: 1fr 1fr; }
}
</style>

</BaseLayout>
