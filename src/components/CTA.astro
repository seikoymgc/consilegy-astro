---
interface Props {
	title: string;
	description?: string;
	href: string;
	label: string;
}

const { title, description, href, label } = Astro.props;
---

<section class="cta-band" aria-labelledby="cta-heading">
	<div class="container cta-band__inner">
		<div class="cta-band__text">
			<h2 id="cta-heading" class="cta-band__title">{title}</h2>
			{description && <p class="cta-band__desc">{description}</p>}
		</div>
		<div class="cta-band__action">
			<a class="btn btn--primary" href={href}>{label}</a>
		</div>
	</div>
</section>

<style>
	.cta-band {
		background: linear-gradient(135deg, #1e40af 0%, #3b82f6 55%, #987ad6 100%);
		color: #fff;
		padding-block: var(--space-xl);
		margin-top: var(--space-2xl);
	}

	.cta-band__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-lg);
		flex-wrap: wrap;
	}

	.cta-band__title {
		margin: 0;
		font-size: clamp(1.35rem, 2.5vw, 1.75rem);
		font-weight: 800;
		letter-spacing: -0.02em;
	}

	.cta-band__desc {
		margin: var(--space-sm) 0 0;
		max-width: 52ch;
		opacity: 0.95;
		line-height: 1.65;
	}

	.cta-band .btn--primary {
		background: #fff;
		color: var(--color-primary);
		box-shadow: var(--shadow-sm);
		min-width: 200px;
	}

	.cta-band .btn--primary:hover {
		background: #f8fafc;
		color: #1d4ed8;
	}
</style>
