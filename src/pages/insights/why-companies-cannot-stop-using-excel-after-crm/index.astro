	description: '医療テック企業（150名）が10箇所以上に分散した顧客データをHubSpotへ統合し、データ管理業務65%削減・月100時間創出。CRMがあっても「Excelの方が使いやすい」が続く組織の構造問題を解説します。',
	datePublished: pubDate,
	dateModified: pubDate,
	author: { '@type': 'Person', name: '山口聖子', alternateName: 'Seiko Yamaguchi', jobTitle: 'Revenue Architect', url: 'https://consilegy.com/company/', worksFor: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' } },
	publisher: { '@type': 'Organization', name: 'Consilegy', url: 'https://consilegy.com' },
	url: 'https://consilegy.com/insights/why-companies-cannot-stop-using-excel-after-crm/',
	inLanguage: 'ja',
};

