---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const faqItems = [
	{
		q: 'CRM導入済みでも依頼できますか？',
		a: 'はい。むしろ、CRM導入済みで「定着していない」「活用できていない」という状態からの相談が最も多いです。既存のCRM環境を前提に、KPI再設計・ダッシュボード改善・営業マーケ連携・ワークフロー整理など、現状を活かしながら段階的に改善します。ツールの入れ替えや大規模移行を前提とせず、今あるCRMを売上管理に使える状態へ育てることを起点にします。',
	},
	{
		q: '月額伴走だけ依頼できますか？',
		a: 'はい。Phase 2の月額伴走支援から開始することも可能ですが、まずPhase 1のRevOps運用診断（30万円〜）を経てから伴走支援の範囲・優先施策を設計することをお勧めします。診断なしで伴走を開始すると、改善の優先順位がずれやすく、費用対効果が下がるケースがあります。',
	},
	{
		q: 'KPIレビューも対応できますか？',
		a: 'はい。月次・隔週でのKPIレビュー運営支援は支援範囲の中心です。単に数字を確認するだけの会議ではなく、KPIから改善アクションを設計し、優先順位を付け、実行まで追跡する会議体の設計と運営支援を行います。',
	},
	{
		q: 'RevOpsとは何ですか？',
		a: 'RevOps（Revenue Operations）は、営業・マーケティング・カスタマーサクセスなど、収益に関わる部門を横断して、プロセス・データ・ツール・KPIを統合的に運用・改善する機能です。ツール導入だけでは実現せず、業務プロセス設計・KPI定義・会議体設計・継続的な改善サイクルが揃って初めて機能します。CRM・SFA・MAの「定着」と「改善」は、RevOpsの実践そのものです。',
	},
	{
		q: 'Revenue Architectureとの違いは何ですか？',
		a: 'Revenue Architectureは、営業・マーケ・CS・CRM・KPI・会議体を含む収益構造全体の設計を指します。運用定着・改善支援は、その設計を現場に定着させ、継続的に改善するフェーズの支援です。Revenue Architecture設計が「構造の設計図を作る」なら、Adoption & Growth Supportは「その設計図が現場で機能し続けるように改善し続ける」支援です。',
	},
	{
		q: '会議改善も含まれますか？',
		a: 'はい。「数字確認で終わる会議」を改善アクションにつながる会議体へ再設計することは、支援の中心のひとつです。会議アジェンダの設計・KPIレビューの構造・改善アクションの追跡・責任者の定義まで含めて設計します。',
	},
	{
		q: 'HubSpot以外にも対応していますか？',
		a: 'はい。HubSpot・Salesforce・Kintone・Marketo・Account Engagementなど、主要CRM / SFA / MAに対応します。複数ツールが混在する環境でも、横断的なRevOps運用改善が可能です。Consilegyはベンダーフリーの立場で支援します。',
	},
	{
		q: '定着率改善も支援できますか？',
		a: 'はい。CRM入力率・KPI活用率・ダッシュボード参照率などの定着指標の改善は支援範囲に含まれます。「なぜ入力されないのか」「なぜ使われないのか」の構造的な原因を分析し、入力負荷の軽減・フィードバックループの設計・ワークフロー自動化を通じて改善します。',
	},
	{
		q: '運用代行との違いは何ですか？',
		a: 'Consilegyは、単なる作業代行ではなく、Revenue Operationsを改善し続けるための運用設計・KPI改善・会議改善まで支援します。運用代行は「決まった作業を継続的に実行する」サービスですが、Consilegyは「何をどう変えれば売上につながるか」を設計・実行・改善するパートナーです。目標は、チームが自走できる状態を作ることです。',
	},
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map(({ q, a }) => ({
		'@type': 'Question',
		name: q,
		acceptedAnswer: { '@type': 'Answer', text: a },
	})),
};

const deliverables = [
	{ num: '01', title: 'RevOps改善レポート', freq: '月次', kpi: '15項目', savings: '−12h/月' },
	{ num: '02', title: 'KPI改善提案書', freq: '四半期', kpi: '8項目', savings: '−5h/月' },
	{ num: '03', title: 'CRM運用改善計画', freq: '隔月', kpi: '20項目', savings: '−8h/月' },
	{ num: '04', title: 'ダッシュボード改善案', freq: '月次', kpi: '12項目', savings: '−6h/月' },
	{ num: '05', title: '会議運用設計書', freq: '初回〜改善', kpi: '6項目', savings: '−10h/月' },
	{ num: '06', title: 'ワークフロー改善案', freq: '随時', kpi: '10項目', savings: '−15h/月' },
	{ num: '07', title: '入力定着ルール', freq: '初回〜改善', kpi: '8項目', savings: '−7h/月' },
	{ num: '08', title: 'Revenue Architecture改善提案', freq: '四半期', kpi: '全体', savings: '戦略的' },
	{ num: '09', title: '月次レビュー資料', freq: '月次', kpi: '12項目', savings: '−8h/月' },
	{ num: '10', title: '改善ロードマップ', freq: '四半期', kpi: '優先施策', savings: '可視化' },
];
---

<BaseLayout
	title="運用定着・改善支援（Adoption & Growth Support）| Consilegy"
	description="CRM導入後に定着しない、KPIが使われない、営業マーケ連携が崩れる。Revenue Operationsを継続的に改善するConsilegyの伴走支援。HubSpot / Salesforce / Kintone対応。月額30万〜100万円。"
	lang="ja"
>
	<Fragment slot="head">
		<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
	</Fragment>

<!-- ===================== HERO ===================== -->
<section class="hero">
	<div class="container">
		<div class="hero-nav">
			<a href="/services/" class="back-link">← サービス一覧</a>
			<span class="hero-tag">Adoption &amp; Growth Support</span>
		</div>
		<div class="hero-service-name">
			<span class="hero-service-ja">運用定着・改善支援</span>
			<span class="hero-service-en">Adoption &amp; Growth Support</span>
		</div>
		<h1>
			CRMを導入しただけでは、<br />
			<span class="accent">Revenue Operationsは定着しない</span>。
		</h1>
		<div class="hero-body">
			<p class="hero-poem">
				CRMを導入しても、<br />
				営業が入力しない。<br />
				KPIが使われない。<br />
				会議が数字確認だけで終わる。
			</p>
			<p class="hero-lead">
				多くの企業では、導入直後ではなく、<br />
				「運用フェーズ」でRevenue Operationsが崩れていきます。
			</p>
			<p class="hero-value">
				Consilegyは、CRM / KPI / 営業・マーケ・CS運用を継続的に改善し、<br />
				売上につながる運用基盤を定着させます。
			</p>
		</div>
		<div class="hero-cta">
			<a href="/free-consultation/" class="btn btn--primary btn--lg">RevOps運用相談を申し込む →</a>
			<a href="/download/" class="btn btn--outline btn--lg">サービス資料をダウンロード</a>
		</div>
		<div class="hero-keywords">
			<span class="kw-pill">CRM定着</span>
			<span class="kw-pill">KPI改善</span>
			<span class="kw-pill">営業マーケ連携</span>
			<span class="kw-pill">RevOps運用</span>
			<span class="kw-pill">Revenue Architecture</span>
		</div>
	</div>
</section>

<!-- ===================== CRM崩壊 ===================== -->
<section class="collapse">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow-label">What Happens</p>
			<h2>CRM導入後、多くの企業で運用が止まります。</h2>
		</div>
		<div class="collapse-grid">
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>営業がCRMを入力しなくなる</span>
			</div>
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>KPIが現場で使われない</span>
			</div>
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>ダッシュボードが放置される</span>
			</div>
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>MQL / SQL定義が崩れる</span>
			</div>
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>会議が数字確認だけになる</span>
			</div>
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>Excel管理へ戻る</span>
			</div>
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>営業とマーケが再び分断する</span>
			</div>
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>レポート作成が属人化する</span>
			</div>
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>データ更新ルールが曖昧になる</span>
			</div>
			<div class="collapse-card">
				<span class="collapse-icon">✕</span>
				<span>「誰も見ていないCRM」になる</span>
			</div>
		</div>
		<div class="collapse-footer">
			<p>
				Revenue Operationsは、導入しただけでは機能しません。<br />
				入力、レビュー、改善、会議運用まで含めて、<br />
				継続的に改善される必要があります。
			</p>
		</div>
	</div>
</section>

<!-- ===================== なぜ定着しないのか ===================== -->
<section class="root-cause">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow-label">Root Cause</p>
			<h2>問題はツールではなく、「運用構造」にあります。</h2>
		</div>
		<div class="cause-grid">
			<div class="cause-card">
				<div class="cause-num">01</div>
				<h3>KPIが現場業務につながっていない</h3>
				<p>入力しても、現場メリットがない。<br />「なぜ入力するのか」が現場に伝わっていない。</p>
			</div>
			<div class="cause-card">
				<div class="cause-num">02</div>
				<h3>会議が改善につながっていない</h3>
				<p>数字を見るだけで、改善アクションが存在しない。<br />確認で終わり、次のアクションが決まらない。</p>
			</div>
			<div class="cause-card">
				<div class="cause-num">03</div>
				<h3>RevOps改善責任が曖昧</h3>
				<p>営業、マーケ、CSが再び個別最適へ戻ってしまう。<br />横断的な改善を担う機能が存在しない。</p>
			</div>
		</div>
	</div>
</section>

<!-- ===================== 定義 ===================== -->
<section class="definition">
	<div class="container">
		<div class="def-box">
			<p class="eyebrow-label">Definition</p>
			<h2>運用定着・改善支援とは</h2>
			<p class="def-lead">
				運用定着・改善支援は、CRM / KPI / 営業・マーケ・CS運用を継続的に改善し、Revenue Operationsを現場へ定着させる伴走支援です。
			</p>
			<p class="def-oneliner">
				CRMを、「導入しただけ」で終わらせず、<br />
				売上改善に使われ続ける運用基盤へ育てるサービスです。
			</p>
		</div>
	</div>
</section>

<!-- ===================== 解決する課題 ===================== -->
<section class="problems">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow-label">Problems We Solve</p>
			<h2>解決する課題</h2>
		</div>
		<div class="problems-grid">
			<div class="problem-card">
				<div class="problem-num">01</div>
				<h3>CRM定着不足</h3>
				<p>入力率・活用率が低い。CRMに情報が蓄積されない。</p>
			</div>
			<div class="problem-card">
				<div class="problem-num">02</div>
				<h3>KPI形骸化</h3>
				<p>指標が改善アクションにつながらない。数字があっても意思決定されない。</p>
			</div>
			<div class="problem-card">
				<div class="problem-num">03</div>
				<h3>営業マーケ分断</h3>
				<p>MQL/SQL定義が崩れ、部門間の連携が機能しない。</p>
			</div>
			<div class="problem-card">
				<div class="problem-num">04</div>
				<h3>会議形骸化</h3>
				<p>数字確認で終わり、改善アクションが生まれない会議体になっている。</p>
			</div>
			<div class="problem-card">
				<div class="problem-num">05</div>
				<h3>RevOps改善停止</h3>
				<p>導入後に改善が止まり、Revenue Operationsのサイクルが回っていない。</p>
			</div>
		</div>
	</div>
</section>

<!-- ===================== 支援範囲 ===================== -->
<section class="scope">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow-label">Scope</p>
			<h2>支援領域</h2>
			<p class="section-desc">月額伴走の中で対応する12の支援領域です。Phase 1の診断後、必要な範囲を絞ってご提案します。</p>
		</div>
		<div class="scope-grid">
			<div class="scope-item"><span class="scope-num">01</span><span class="scope-label">CRM運用改善</span></div>
			<div class="scope-item"><span class="scope-num">02</span><span class="scope-label">KPI改善</span></div>
			<div class="scope-item"><span class="scope-num">03</span><span class="scope-label">ダッシュボード改善</span></div>
			<div class="scope-item"><span class="scope-num">04</span><span class="scope-label">RevOpsレビュー運用</span></div>
			<div class="scope-item"><span class="scope-num">05</span><span class="scope-label">営業マーケCS連携改善</span></div>
			<div class="scope-item"><span class="scope-num">06</span><span class="scope-label">会議運用改善</span></div>
			<div class="scope-item"><span class="scope-num">07</span><span class="scope-label">ワークフロー改善</span></div>
			<div class="scope-item"><span class="scope-num">08</span><span class="scope-label">データ品質改善</span></div>
			<div class="scope-item"><span class="scope-num">09</span><span class="scope-label">入力定着支援</span></div>
			<div class="scope-item"><span class="scope-num">10</span><span class="scope-label">Revenue Architecture改善提案</span></div>
			<div class="scope-item"><span class="scope-num">11</span><span class="scope-label">レポート作成自動化</span></div>
			<div class="scope-item"><span class="scope-num">12</span><span class="scope-label">Slack / 通知運用改善</span></div>
		</div>
	</div>
</section>

<!-- ===================== 支援プロセス ===================== -->
<section class="process">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow-label">Process</p>
			<h2>支援プロセス</h2>
			<p class="section-desc">単なる保守運用ではなく、Revenue Operationsを改善し続ける伴走支援。</p>
		</div>
		<div class="process-flow">
			<div class="process-step">
				<div class="step-num">01</div>
				<div class="step-body">
					<h3>RevOps現状分析</h3>
					<p>CRM活用率・KPI品質・プロセス断絶の構造を診断します。</p>
				</div>
			</div>
			<div class="process-step">
				<div class="step-num">02</div>
				<div class="step-body">
					<h3>KPI / CRM分析</h3>
					<p>KPI体系・CRMデータ品質・ダッシュボード設計を詳細に分析します。</p>
				</div>
			</div>
			<div class="process-step">
				<div class="step-num">03</div>
				<div class="step-body">
					<h3>運用課題整理</h3>
					<p>部門横断でのボトルネックを整理し、優先度の高い課題を可視化します。</p>
				</div>
			</div>
			<div class="process-step">
				<div class="step-num">04</div>
				<div class="step-body">
					<h3>改善優先順位設計</h3>
					<p>インパクトと実行コストで施策を評価し、四半期ロードマップを設計します。</p>
				</div>
			</div>
			<div class="process-step">
				<div class="step-num">05</div>
				<div class="step-body">
					<h3>CRM / KPI改善</h3>
					<p>入力定着施策・プロパティ整理・KPI再定義を実行します。</p>
				</div>
			</div>
			<div class="process-step">
				<div class="step-num">06</div>
				<div class="step-body">
					<h3>会議運用改善</h3>
					<p>数字確認から改善アクションにつながる会議体を設計・運営します。</p>
				</div>
			</div>
			<div class="process-step">
				<div class="step-num">07</div>
				<div class="step-body">
					<h3>ワークフロー自動化</h3>
					<p>手作業・属人的なレポートをワークフローとSlack通知で自動化します。</p>
				</div>
			</div>
			<div class="process-step">
				<div class="step-num">08</div>
				<div class="step-body">
					<h3>定着支援</h3>
					<p>現場チームへの運用定着・トレーニング・ナレッジ整備を行います。</p>
				</div>
			</div>
			<div class="process-step process-step--last">
				<div class="step-num step-num--cycle">↺</div>
				<div class="step-body">
					<h3>継続改善サイクル運用</h3>
					<p>月次レビューを基盤に、RevOps改善サイクルを継続的に回し続けます。</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ===================== BEFORE / AFTER ===================== -->
<section class="ba-section">
	<div class="container">
		<div class="section-header">
			<p class="eyebrow-label">Before / After</p>
			<h2>「導入しただけのCRM」を、<br />改善し続けるRevenue Operationsへ。</h2>
		</div>
		<div class="ba-layout">
			<div class="ba-col ba-col--before">
				<div class="ba-badge ba-badge--before">Before</div>
				<div class="ba-title">放置されたCRM</div>
				<ul class="ba-list">
					<li class="ba-item ba-item--bad"><span class="ba-x">✕</span>入力されないCRM</li>
					<li class="ba-item ba-item--bad"><span class="ba-x">✕</span>放置されたダッシュボード</li>
					<li class="ba-item ba-item--bad"><span class="ba-x">✕</span>KPI形骸化</li>
					<li class="ba-item ba-item--bad"><span class="ba-x">✕</span>Excel逆戻り</li>
					<li class="ba-item ba-item--bad"><span class="ba-x">✕</span>属人的レポート</li>
					<li class="ba-item ba-item--bad"><span class="ba-x">✕</span>部門分断</li>
					<li class="ba-item ba-item--bad"><span class="ba-x">✕</span>会議疲弊</li>
				</ul>
			</div>
			<div class="ba-arrow-col">
				<div class="ba-arrow-wrap">
					<div class="ba-arrow-line"></div>
					<div class="ba-arrow-label">Consilegy<br />伴走支援</div>
					<div class="ba-arrow-head">→</div>
				</div>
			</div>
			<div class="ba-col ba-col--after">
				<div class="ba-badge ba-badge--after">After</div>
				<div class="ba-title">改善サイクルが回るRevOps運用</div>
				<ul class="ba-list">
					<li class="ba-item ba-item--good"><span class="ba-check">✓</span>KPI改善サイクル</li>
					<li class="ba-item ba-item--good"><span class="ba-check">✓</span>RevOpsレビュー運用</li>
