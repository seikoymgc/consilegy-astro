---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const cases = (await getCollection('caseStudies'))
	.filter((c) => c.data.lang === 'ja' && !c.data.draft)
	.slice(0, 3);

const insightsPosts = [
	{
		href: '/insights/why-good-marketing-strategies-fail-to-scale/',
		title: 'なぜ「良い施策」を打っても再現性が生まれないのか',
		description: '一時的に成果が出ても再現性が続かない原因を、Revenue Architecture・RevOps・Revenue Visibilityの観点から解説します。',
		category: 'Revenue Architecture',
	},
	{
		href: '/insights/why-kpi-meetings-become-status-update-sessions/',
		title: 'なぜKPI会議は「数字確認会」で終わってしまうのか',
		description: 'KPI会議が改善につながらず、数字確認だけで終わってしまう原因を、Revenue ArchitectureとRevOpsの観点から解説します。',
		category: 'RevOps / KPI',
	},
	{
		href: '/insights/why-salesforce-implementations-fail/',
		title: 'なぜSalesforce導入は失敗しやすいのか',
		description: 'Salesforce導入が失敗する本当の原因を、Revenue Architecture・RevOps・運用定着の観点から解説します。',
		category: 'Salesforce / RevOps',
	},
];
---

<BaseLayout
	title="Consilegy | CRM・SFA・MAを売上が見える経営基盤へ"
	description="Salesforce・HubSpot・Kintone・Marketoなど複数ツールが混在する収益オペレーションを、ベンダーフリーの立場から再設計します。RevOps・マルチCRM再設計・伴走支援。"
	lang="ja"
>
	<link
		rel="preload"
		as="image"
		href="/images/common/hero-visual.webp"
		type="image/webp"
		fetchpriority="high"
		slot="head"
	/>
	<script slot="head">
		if (window.location.pathname === '/' || window.location.pathname === '') {
			const pref = localStorage.getItem('languagePreference');
			if (!pref) {
				const lang = navigator.language || 'ja';
				if (!lang.toLowerCase().startsWith('ja')) {
					window.location.replace('/en/');
				}
			}
		}
	</script>

<!-- ===================== HERO ===================== -->
<section class="hero">
	<div class="hero-bg" aria-hidden="true">
		<div class="hero-orb hero-orb--1"></div>
		<div class="hero-orb hero-orb--2"></div>
		<div class="hero-grid"></div>
	</div>
	<div class="container hero-inner">
		<div class="hero-copy">
			<span class="hero-eyebrow"><span class="eyebrow-dot"></span>Revenue Operations</span>
			<h1>
				CRM・SFA・MAを、<br />
				<span class="hero-accent">売上が見える経営基盤へ。</span>
			</h1>
			<p class="hero-lead">
				Salesforce、HubSpot、Kintone、Marketoなど既存ツールを前提に、
				営業・マーケ・CSの分断を整理し、商談化・受注・継続までを
				管理できる収益プロセスへ再設計します。
			</p>
			<div class="hero-actions">
				<a href="/contact/" class="btn btn--hero-primary btn--lg">
					お問い合わせ →
				</a>
				<a href="/download/" class="btn btn--hero-outline btn--lg">
					資料ダウンロード
				</a>
			</div>
		</div>

	</div>
	<div class="hero-tools">
		<div class="container">
			<p class="tools-label">対応ツール（一部）</p>
			<div class="tools-row">
				<span>Salesforce</span><span class="tools-sep">|</span>
				<span>HubSpot</span><span class="tools-sep">|</span>
				<span>Kintone</span><span class="tools-sep">|</span>
				<span>Marketo</span><span class="tools-sep">|</span>
				<span>ServiceNow</span><span class="tools-sep">|</span>
				<span>Zoho CRM</span><span class="tools-sep">|</span>
				<span>Tableau / Looker</span>
			</div>
		</div>
	</div>
</section>

<!-- ===================== WHY ===================== -->
<section class="why">
	<div class="container">
		<div class="why-grid">
			<div class="why-head">
				<p class="section-eyebrow">Why It Fails</p>
				<h2>CRMが機能しない理由は<br />ツールではなく、<span class="text-primary">設計にあります</span></h2>
				<p class="section-lead">
					多くの企業がCRM / SFA / MAを導入しても成果に繋がらない原因は、
					ツールの問題ではありません。営業プロセス・データ構造・組織設計が
					ツール導入の前後で整理されていないことにあります。
				</p>
				<p class="section-lead" style="margin-top: 1rem;">
					Consilegyは部分最適ではなく、収益プロセス全体を設計し直すアプローチで支援します。
				</p>
			</div>
			<div class="why-problems">
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>リードはあるが、商談化しない</h4>
						<p>マーケと営業の定義・ハンドオフ・KPIが揃っていないため、リードが積み上がるだけで商談に繋がらない。</p>
					</div>
				</div>
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>営業とマーケティングの定義が揃っていない</h4>
						<p>「有望なリード」の基準が部門ごとに異なり、データの意味が統一されていない状態が続く。</p>
					</div>
				</div>
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>SFAに入力されない、データが信頼できない</h4>
						<p>設計が現場に合っておらず、正しく入力されないまま運用が続き、レポートが形骸化する。</p>
					</div>
				</div>
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>レポートが経営判断に使えない</h4>
						<p>ツールからデータは出るが、数字の定義・粒度・タイミングがバラバラで意思決定に活用できない。</p>
					</div>
				</div>
				<div class="problem-item">
					<span class="problem-icon" aria-hidden="true">→</span>
					<div>
						<h4>部門ごとに顧客データが分断されている</h4>
						<p>営業・マーケ・CS・基幹システムで顧客情報が別々に管理され、全体像が見えない。</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- ===================== HOW ===================== -->
<section class="how">
	<div class="container">
		<div class="how-grid">
			<div class="how-visual">
				<div class="flow-diagram">
					<div class="flow-step flow-step--top">
						<span class="flow-label">マーケティング</span>
						<div class="flow-tools">MA / CDP</div>
					</div>
					<div class="flow-arrow">↓</div>
					<div class="flow-center">
						<span class="flow-center-label">収益プロセス設計</span>
						<span class="flow-center-sub">Revenue Architecture</span>
					</div>
					<div class="flow-arrow">↓</div>
					<div class="flow-step flow-step--mid">
						<span class="flow-label">営業・インサイドセールス</span>
						<div class="flow-tools">CRM / SFA</div>
					</div>
					<div class="flow-arrow">↓</div>
					<div class="flow-step flow-step--bot">
						<span class="flow-label">カスタマーサクセス</span>
						<div class="flow-tools">CS / BI / データ基盤</div>
					</div>
					<div class="flow-kpi">
						<span>KPI・ダッシュボード</span>
						<span class="flow-kpi-arrow">←</span>
						<span>経営判断に使えるデータへ</span>
					</div>
				</div>
			</div>
			<div class="how-copy">
				<p class="section-eyebrow">Our Approach</p>
				<h2>RevOps再設計 ＆<br /><span class="text-primary">レベニューアーキテクチャ</span></h2>
				<p class="section-lead">
					Consilegyの支援の中心は「ツール導入」ではなく、
					収益プロセス全体の再設計です。
					CRM / SFA / MAを点として改善するのではなく、
					営業・マーケ・CSがひとつのプロセスとして機能するよう、
					データモデル・組織設計・KPIを一体で整えます。
				</p>
				<ul class="how-points">
					<li>
						<span class="how-num">01</span>
						<div>
							<strong>ベンダーフリー</strong>
							<p>特定ツールの代理店ではないため、事業構造に合った中立的な設計を提案します。</p>
						</div>
					</li>
					<li>
						<span class="how-num">02</span>
						<div>
							<strong>プロセス設計から実装・定着まで</strong>
							<p>To-Be設計だけでなく、現場に落とし込む運用ルールと伴走支援まで一貫して対応します。</p>
						</div>
					</li>
					<li>
						<span class="how-num">03</span>
						<div>
							<strong>複数ツール横断の統合設計</strong>
							<p>Salesforce・HubSpot・Kintone・Marketoなどが混在する環境でもマルチCRM統合を設計します。</p>
						</div>
					</li>
				</ul>
				<a href="/revenue-architecture/" class="btn btn--outline-primary">
					レベニューアーキテクチャとは →
				</a>
			</div>
		</div>
	</div>
</section>

<!-- ===================== SERVICES ===================== -->
<section class="services-overview">
	<div class="container">
		<header class="section-head">
			<p class="section-eyebrow">Service Packages</p>
			<h2>提供サービス</h2>
			<p class="section-lead">
				現状把握から再設計、定着まで。課題のフェーズに合わせて選べる3つのステップを用意しています。
			</p>
		</header>

		<div class="svc-grid">

			<!-- Step 01: 診断 -->
			<article class="svc-card">
				<div class="svc-card__head">
					<span class="svc-step">Step 01</span>
					<h3>CRM / RevOps 診断</h3>
					<p class="svc-price-range">¥100,000〜500,000</p>
				</div>
				<p class="svc-desc">
					現状のCRM / SFA / MA運用・データ構造を診断し、
					ボトルネックの根拠と改善ロードマップを提示します。
					まず状況を把握したい企業向けの入口商品です。
				</p>
				<ul class="svc-items">
					<li>現状ヒアリングと課題仮説の整理</li>
					<li>CRM / MA運用・データ構造のフルレビュー</li>
					<li>ボトルネック分析と改善ロードマップ</li>
				</ul>
				<div class="svc-plans">
					<div class="svc-plan">
						<span class="svc-plan__name">簡易診断</span>
						<span class="svc-plan__price">¥100,000〜150,000</span>
					</div>
					<div class="svc-plan">
						<span class="svc-plan__name">詳細診断</span>
						<span class="svc-plan__price">¥300,000〜500,000</span>
					</div>
				</div>
				<a href="/pricing/#diagnosis" class="btn btn--primary svc-cta">詳しく見る →</a>
			</article>

			<!-- Step 02: 再設計 -->
			<article class="svc-card">
				<div class="svc-card__head">
					<span class="svc-step">Step 02</span>
					<h3>マルチCRM再設計プロジェクト</h3>
					<p class="svc-price-range">¥3,000,000〜8,000,000</p>
				</div>
				<p class="svc-desc">
					Salesforce / HubSpot / Kintone / Marketoなど複数ツールが混在する
					収益オペレーションを、ベンダー中立の立場で設計し直す中核プロジェクト。
				</p>
				<ul class="svc-items">
					<li>営業プロセス / データモデル再設計</li>
					<li>CRM / SFA / MA統合・移行設計</li>
					<li>KPI / ダッシュボード基盤の再構築</li>
					<li>実装ベンダー選定支援（中立）</li>
				</ul>
				<a href="/pricing/#project" class="btn btn--primary svc-cta">プロジェクトを相談する →</a>
			</article>

			<!-- Step 03: 伴走 -->
			<article class="svc-card">
				<div class="svc-card__head">
					<span class="svc-step">Step 03</span>
					<h3>伴走・顧問支援</h3>
					<p class="svc-price-range">月額 ¥300,000〜1,000,000</p>
				</div>
				<p class="svc-desc">
					再設計後の定着から内製化まで、月次で並走します。
					関与度に応じてライト・スタンダード・フルの3プランから選択可能。
				</p>
				<ul class="svc-items">
					<li>月次定例会・KPIレビュー</li>
					<li>施策の優先順位付けと改善支援</li>
					<li>部門間調整・RevOps内製化支援</li>
				</ul>
				<div class="svc-plans">
					<div class="svc-plan">
						<span class="svc-plan__name">ライト</span>
						<span class="svc-plan__price">月 ¥300,000〜400,000</span>
					</div>
					<div class="svc-plan">
						<span class="svc-plan__name">スタンダード</span>
						<span class="svc-plan__price">月 ¥500,000〜800,000</span>
					</div>
					<div class="svc-plan">
						<span class="svc-plan__name">フル</span>
						<span class="svc-plan__price">月 ¥800,000〜1,000,000</span>
					</div>
				</div>
				<a href="/pricing/#support" class="btn btn--primary svc-cta">詳しく見る →</a>
			</article>

		</div>

		<div class="svc-footer">
			<a class="btn btn--secondary" href="/services/">サービス一覧を見る</a>
			<a class="btn btn--secondary" href="/pricing/">パッケージ料金を見る</a>
		</div>
	</div>
</section>

<!-- ===================== CASE STUDIES ===================== -->
{cases.length > 0 && (
<section class="cases">
	<div class="container">
		<header class="section-head">
			<p class="section-eyebrow">Case Studies</p>
			<h2>導入事例</h2>
			<p class="section-lead">
				製造・SaaS・サービス業など、複数のB2B事業会社にて
				収益プロセスの再設計と定着を支援してきました。
			</p>
		</header>
		<div class="cases-grid">
			{cases.map((c) => (
				<article class="case-card">
					{c.data.featuredImage && (
						<div class="case-img">
							<img src={c.data.featuredImage} alt={c.data.featuredImageAlt || c.data.title} loading="lazy" />
						</div>
					)}
					<div class="case-body">
						{c.data.industry && <p class="case-tag">{c.data.industry}</p>}
						<h3 class="case-title">{c.data.title}</h3>
						{c.data.description && <p class="case-desc">{c.data.description.slice(0, 90)}...</p>}
						<a href={`/case-studies/${c.data.slug}/`} class="case-link">詳しく見る →</a>
					</div>
				</article>
			))}
		</div>
		<p style="margin-top: var(--space-lg); text-align: center;">
			<a class="btn btn--secondary" href="/case-studies/">事例一覧へ</a>
		</p>
	</div>
</section>
)}

<!-- ===================== BLOG ===================== -->
<section class="blog-section">
	<div class="container">
		<header class="section-head">
			<p class="section-eyebrow">Insights</p>
			<h2>最新コラム</h2>
			<p class="section-lead">RevOps・CRM運用・データ活用に関するナレッジを公開しています。</p>
		</header>
		<div class="blog-grid">
			{insightsPosts.map((post) => (
				<article class="blog-card">
					<div class="blog-body">
						<span class="blog-cat">{post.category}</span>
						<h3 class="blog-title">
							<a href={post.href}>{post.title}</a>
						</h3>
						<p class="blog-desc">{post.description}</p>
					</div>
				</article>
			))}
		</div>
		<p style="margin-top: var(--space-lg); text-align: center;">
			<a class="btn btn--secondary" href="/insights/">コラム一覧へ</a>
		</p>
	</div>
</section>

<!-- ===================== NEWSLETTER CTA ===================== -->
<section class="nl-cta-strip">
	<div class="container nl-cta-strip__inner">
		<div class="nl-cta-strip__copy">
			<p class="nl-cta-strip__eyebrow">Newsletter</p>
			<h2>次世代B2Bレベニュー戦略バイブル</h2>
			<p>Revenue Architecture・RevOps・CRM実装の実践知を毎月配信。約2,000人が購読中。</p>
		</div>
		<a href="/newsletter/#signup" class="btn nl-cta-strip__btn">
			無料で登録する →
		</a>
	</div>
</section>

<!-- ===================== FINAL CTA ===================== -->
<section class="final-cta">
	<div class="container cta-inner">
		<div class="cta-copy">
			<p class="cta-eyebrow">Get Started</p>
			<h2>まずは30分無料相談から<br />はじめましょう</h2>
			<p class="cta-lead">
				初回ご相談は無料。現状のシステム構成・営業プロセス・組織体制を
				ヒアリングし、改善余地と優先順位を明確にします。
			</p>
			<div class="cta-actions">
				<a href="/free-consultation/" class="btn btn--cta-primary btn--lg">
					30分無料相談を申し込む →
				</a>
				<a href="/download/" class="btn btn--cta-outline btn--lg">
					サービス資料をダウンロード
				</a>
			</div>
		</div>
		<div class="cta-checklist">
			<h4>ご相談時にお伺いする内容</h4>
			<ul>
				<li>現在ご利用中のCRM / SFA / MAツール構成</li>
				<li>事業部・組織体制（規模・部門数）</li>
				<li>現状の課題・優先度の高いテーマ</li>
				<li>想定スケジュールと社内ステークホルダー</li>
				<li>過去の導入・移行プロジェクトの経緯</li>
			</ul>
		</div>
	</div>
</section>

</BaseLayout>

<style>
/* ── Shared ──────────────────────────────────────────── */
.container { max-width: 1160px; margin-inline: auto; padding-inline: 2rem; }
section { padding-block: var(--space-2xl); }
.section-head { max-width: 680px; margin-bottom: var(--space-xl); }
.section-eyebrow {
	font-size: 0.8125rem; font-weight: 600; color: var(--color-primary);
	letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 0.75rem;
}
.section-lead { font-size: 1.0625rem; color: var(--color-text-muted); line-height: 1.75; margin: 0; }
.text-primary { color: var(--color-primary); }
.btn--lg { padding: 1.0625rem 1.875rem; font-size: 1rem; }

/* ── Hero ──────────────────────────────────────────── */
.hero {
	position: relative; overflow: hidden;
	background-image: url('/images/common/hero-visual-720.webp');
	background-size: cover;
	background-position: center;
	background-repeat: no-repeat;
	border-bottom: 1px solid var(--color-border);
	padding-block: 0;
}
@media (min-width: 769px) {
	.hero {
		background-image: url('/images/common/hero-visual.webp');
	}
}
.hero-bg {
	position: absolute; inset: 0; pointer-events: none; z-index: 0;
}
.hero-orb {
	position: absolute; border-radius: 50%; filter: blur(80px);
}
.hero-orb--1 {
	width: 640px; height: 640px; top: -200px; right: -160px;
	background: radial-gradient(circle, rgba(30,64,175,0.07) 0%, transparent 70%);
}
.hero-orb--2 {
	width: 400px; height: 400px; bottom: -100px; left: -80px;
	background: radial-gradient(circle, rgba(124,92,191,0.06) 0%, transparent 70%);
}
.hero-grid {
	position: absolute; inset: 0;
	background-image:
		linear-gradient(rgba(30,64,175,0.04) 1px, transparent 1px),
		linear-gradient(90deg, rgba(30,64,175,0.04) 1px, transparent 1px);
	background-size: 48px 48px;
}

.hero-inner {
	position: relative; z-index: 1;
	padding-block: var(--space-2xl) var(--space-xl);
}
.hero-copy {
	max-width: 600px;
}

.hero-eyebrow {
	display: inline-flex; align-items: center; gap: 0.5rem;
	font-size: 0.8125rem; font-weight: 600; color: #fff;
	background: rgba(255,255,255,0.18); padding: 0.375rem 0.875rem; border-radius: 4px;
	letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 1.5rem;
}
.eyebrow-dot {
	width: 6px; height: 6px; border-radius: 50%;
	background: #fff; display: inline-block;
}

.hero-copy h1 {
