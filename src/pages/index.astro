---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CardGrid from '../components/CardGrid.astro';
import CTA from '../components/CTA.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services', ({ data }) => data.lang !== 'en'))
	.sort((a, b) => a.data.order - b.data.order);

const cases = (await getCollection('caseStudies'))
	.filter((c) => c.data.lang === 'ja')
	.slice(0, 3);

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.filter((p) => {
		const url = p.data.sourceUrl ?? '';
		return url && !url.includes('/en/');
	})
	.sort((a, b) => {
		const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
		const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
		return db - da;
	})
	.slice(0, 3);
---

<BaseLayout
	title="Consilegy | レベニューアーキテクチャで収益構造を設計"
	description="戦略と現場をつなぎ、マーケティングから継続収益までを構造として設計・実装。HubSpotをはじめとするMA/CRM/SFAの実装と運用定着まで伴走します。"
	lang="ja"
>
	<script slot="head">
		// トップページ (/) のみ実行: 初回アクセス時にブラウザ言語でEN誘導
		if (window.location.pathname === '/' || window.location.pathname === '') {
			const pref = localStorage.getItem('languagePreference');
			if (!pref) {
				const lang = navigator.language || 'ja';
				if (!lang.toLowerCase().startsWith('ja')) {
					window.location.replace('/en/');
				}
			}
		}
	</script>
	<Hero
		subtitle="Revenue Architecture"
		title="導入して終わりにしない。成果が出る運用まで伴走する。"
		lede="レベニューアーキテクチャ（収益構造）の観点から、戦略・構造設計・実装・運用を一気通貫で支援します。部分最適ではなく、つながる設計でリードから継続収益までを支えます。"
		primaryHref="/contact/"
		primaryLabel="相談してみる"
		secondaryHref="/services/"
		secondaryLabel="サービスを見る"
	/>

	<Section
		variant="subtle"
		title="こんな課題に対応しています"
		intro="施策単体の改善ではなく、プロセスとデータの流れから見直し、再現性のある成果へつなげます。"
	>
		<CardGrid columns={2}>
			<Card
				title="施策は動いているのに、成果に繋がらない"
				description="上流の設計と現場の運用が分断され、改善が感覚頼みになっている状態を整理します。"
			/>
			<Card
				title="リードは入るが、商談化・売上に接続しない"
				description="ハンドオフと計測が弱く、どこで停滞しているかが見えないケースに対し、構造として設計します。"
			/>
			<Card
				title="MA/SFAを導入したが、入力とデータが定着しない"
				description="項目設計・自動化・レビュー会議まで含め、現場で回る運用へ落とし込みます。"
			/>
			<Card
				title="情報が散らばり、意思決定が遅い"
				description="データの所在と責任分界を整理し、ダッシュボードと定例会の設計まで支援します。"
			/>
		</CardGrid>
	</Section>

	<Section
		title="支援領域"
		intro="戦略設計からツール実装、運用定着まで。プロジェクトの局面に合わせて伴走します。"
	>
		<CardGrid columns={3}>
			{
				services.map((s) => (
					<Card
						href={`/services/${s.data.slug}/`}
						title={s.data.title}
						description={s.data.description}
					/>
				))
			}
		</CardGrid>
		<p style="margin-top: var(--space-lg); text-align: center;">
			<a class="btn btn--secondary" href="/services/">サービス一覧へ</a>
		</p>
	</Section>

	<Section
		variant="subtle"
		title="導入事例"
		intro="業種やフェーズは異なっても、データとプロセスの設計を軸に支援しています。"
	>
		<CardGrid columns={3}>
			{
				cases.map((c) => (
					<Card
						href={`/case-studies/${c.data.slug}/`}
						title={c.data.title}
						description={c.data.description}
						meta={c.data.industry}
						imageSrc={c.data.featuredImage}
						imageAlt={c.data.alt}
					/>
				))
			}
		</CardGrid>
		<p style="margin-top: var(--space-lg); text-align: center;">
			<a class="btn btn--secondary" href="/case-studies/">事例一覧へ</a>
		</p>
	</Section>

	{blogPosts.length > 0 && (
		<Section
			title="最新コラム"
			intro="マーケティングオペレーションとデータ活用に関する記事。"
		>
			<CardGrid columns={3}>
				{blogPosts.map((post) => {
					const rawUrl = post.data.sourceUrl ?? '';
					let href = '#';
					try {
						const parts = new URL(rawUrl).pathname.replace(/^\/|\/$/g, '').split('/');
						if (parts.length === 2) href = `/${parts[0]}/${parts[1]}/`;
					} catch {}
					return (
						<Card
							href={href}
							title={post.data.title}
							description={post.data.description ?? ''}
							imageSrc={post.data.featuredImage || undefined}
							imageAlt={post.data.featuredImageAlt ?? ''}
						/>
					);
				})}
			</CardGrid>
			<p style="margin-top: var(--space-lg); text-align: center;">
				<a class="btn btn--secondary" href="/insights/">コラム一覧へ</a>
			</p>
		</Section>
	)}

	<CTA
		title="まずは現状整理から。伴走の進め方をご提案します。"
		description="課題が整理できていなくても問題ありません。現在の体制とツール、短期で効く打ち手から一緒に確認します。"
		href="/contact/"
		label="お問い合わせ"
	/>
</BaseLayout>
