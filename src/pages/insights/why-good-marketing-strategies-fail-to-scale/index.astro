				<span class="article-services__cat">サービス</span>
				<span class="article-services__title">B2Bマーケティング / GTM設計</span>
				<span class="article-services__arrow">→</span>
			</a>
		</div>
	</nav>
	<NewsletterSidebar />
</div><!-- /.article-wrap -->

<style>
	/* ── Eyecatch ─── */
	.article-eyecatch {
		margin-bottom: 2rem;
		border-radius: 8px;
		overflow: hidden;
		max-height: 360px;
	}
	.article-eyecatch__img {
		width: 100%; height: auto; display: block;
		max-height: 360px; object-fit: cover;
	}
/* ===== LAYOUT ===== */
.article-wrap { background: #fff; }
.container { max-width: 760px; margin: 0 auto; padding: 0 24px; }

/* ===== HEADER ===== */
.article-head { padding: 48px 24px 40px; }
.breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 0.8rem; color: var(--color-muted, #64748b); margin-bottom: 20px; flex-wrap: wrap; }
.breadcrumb a { color: var(--color-muted, #64748b); text-decoration: none; }
.breadcrumb a:hover { color: var(--color-primary, #1e40af); }
.article-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
.article-cat { display: inline-block; background: #eff6ff; color: var(--color-primary, #1e40af); font-size: 0.78rem; font-weight: 600; padding: 4px 12px; border-radius: 4px; }
.article-date, .article-read { font-size: 0.82rem; color: var(--color-muted, #64748b); }
h1 { font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 600; color: var(--color-navy, #0f172a); line-height: 1.3; margin: 0 0 16px; }
.article-desc { font-size: 1rem; color: var(--color-charcoal, #334155); line-height: 1.8; margin: 0; }
.br-pc { display: none; }
@media (min-width: 640px) { .br-pc { display: block; } }

/* ===== BODY ===== */
.article-body { padding: 40px 24px 64px; }
.article-section { margin-bottom: 48px; }
.article-section h2 { font-size: 1.25rem; font-weight: 700; color: var(--color-navy, #0f172a); margin: 0 0 16px; padding-bottom: 10px; border-bottom: 2px solid var(--color-border, #e2e8f0); }
.article-section p { font-size: 0.975rem; color: var(--color-charcoal, #334155); line-height: 1.9; margin: 0 0 16px; }
.article-section p:last-child { margin-bottom: 0; }
.article-callout { background: #f8fafc; border-left: 3px solid var(--color-primary, #1e40af); padding: 14px 18px; border-radius: 0 6px 6px 0; font-size: 0.92rem !important; color: var(--color-navy, #0f172a) !important; }

/* ===== NUMBERED LIST ===== */
.article-numbered { list-style: none; padding: 0; margin: 0; counter-reset: item; display: flex; flex-direction: column; gap: 24px; }
.article-numbered li { counter-increment: item; display: grid; grid-template-columns: 36px 1fr; gap: 0 16px; }
.article-numbered li::before { content: counter(item); display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; background: var(--color-primary, #1e40af); color: #fff; border-radius: 50%; font-weight: 700; font-size: 0.85rem; flex-shrink: 0; margin-top: 2px; }
.article-numbered li strong { grid-column: 2; display: block; font-size: 1rem; color: var(--color-navy, #0f172a); margin-bottom: 6px; line-height: 1.4; }
.article-numbered li p { grid-column: 2; font-size: 0.925rem; color: var(--color-charcoal, #334155); line-height: 1.8; margin: 0; }

/* ===== TABLE ===== */
.article-table-wrap { overflow-x: auto; margin-top: 24px; }
table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
th { background: var(--color-navy, #0f172a); color: #fff; padding: 10px 14px; text-align: left; font-weight: 600; }
td { padding: 10px 14px; border-bottom: 1px solid var(--color-border, #e2e8f0); color: var(--color-charcoal, #334155); }
tr:last-child td { border-bottom: none; }
tr:nth-child(even) td { background: #f8fafc; }

/* ===== DIAGRAM WRAPPER ===== */
.diag-wrap { margin: 0 0 48px; }
.diag { border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; overflow: hidden; background: #fff; }
.diag-caption { display: block; font-size: 0.78rem; color: var(--color-muted, #64748b); margin-top: 8px; line-height: 1.5; }

/* ===================================================
   DIAGRAM 1: diag--repro-chaos
   =================================================== */
.diag--repro-chaos { font-family: inherit; }
.rc-header { background: var(--color-navy, #0f172a); color: #fff; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.05em; padding: 8px 16px; }
.rc-timeline { display: flex; align-items: center; gap: 6px; padding: 20px 16px 12px; overflow-x: auto; flex-wrap: nowrap; }
.rc-event { flex: 0 0 auto; background: #f8fafc; border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; padding: 10px 12px; text-align: center; min-width: 80px; }
.rc-event--success { border-top: 3px solid #22c55e; }
.rc-event--reset { border-top: 3px solid #ef4444; }
.rc-event-icon { font-size: 1.1rem; margin-bottom: 3px; }
.rc-event-label { font-size: 0.68rem; font-weight: 600; color: var(--color-charcoal, #334155); margin-bottom: 4px; }
.rc-event-result { font-size: 0.65rem; font-weight: 700; padding: 2px 6px; border-radius: 3px; }
.rc-result--good { background: #dcfce7; color: #15803d; }
.rc-result--bad { background: #fee2e2; color: #991b1b; }
.rc-fade { color: #94a3b8; font-size: 1rem; font-weight: 700; flex-shrink: 0; }
.rc-tools { display: flex; align-items: center; gap: 10px; padding: 8px 16px 14px; flex-wrap: wrap; }
.rc-tool { display: flex; flex-direction: column; align-items: center; gap: 3px; }
.rc-tool-icon { width: 28px; height: 28px; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 0.65rem; font-weight: 700; color: #fff; }
.rc-tool-icon.sf { background: #00a1e0; }
.rc-tool-icon.xl { background: #16a34a; }
.rc-tool-icon.hs { background: #ff7a59; }
.rc-tool-label { font-size: 0.6rem; color: var(--color-muted, #64748b); }
.rc-tool-sep { font-size: 0.8rem; color: #cbd5e1; font-weight: 700; }
.rc-tool-note { font-size: 0.68rem; color: #ef4444; font-weight: 500; flex: 1; }
.rc-bubbles { display: flex; flex-wrap: wrap; gap: 8px; padding: 4px 16px 12px; }
.rc-bubble { background: #fef9c3; border: 1px solid #fde047; border-radius: 8px; padding: 6px 14px; font-size: 0.78rem; color: #713f12; font-weight: 500; }
.rc-bubble--warn { background: #fef2f2; border-color: #fca5a5; color: #991b1b; }
.rc-footer { display: flex; gap: 8px; padding: 12px 16px; background: #fef2f2; flex-wrap: wrap; }
.rc-tag { font-size: 0.72rem; font-weight: 600; padding: 3px 10px; border-radius: 4px; }
.rc-tag.bad { background: #fee2e2; color: #991b1b; }

/* ===================================================
   DIAGRAM 2: diag--rgd  (Revenue Growth Design)
   =================================================== */
.diag--rgd { font-family: inherit; }
.rgd-header { background: var(--color-navy, #0f172a); color: #fff; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.05em; padding: 8px 16px; }
.rgd-flow { display: flex; align-items: stretch; padding: 20px 14px 8px; gap: 0; flex-wrap: nowrap; overflow-x: auto; }
.rgd-stage { flex: 1; min-width: 70px; background: #f8fafc; border: 1px solid var(--color-border, #e2e8f0); border-radius: 6px; padding: 10px 8px; text-align: center; }
.rgd-stage-label { font-size: 0.75rem; font-weight: 700; color: var(--color-navy, #0f172a); margin-bottom: 4px; }
.rgd-stage-sub { font-size: 0.62rem; color: var(--color-muted, #64748b); line-height: 1.3; }
.rgd-stage--traffic { border-top: 3px solid #94a3b8; }
.rgd-stage--mql     { border-top: 3px solid #60a5fa; }
.rgd-stage--sql     { border-top: 3px solid #3b82f6; }
.rgd-stage--opp     { border-top: 3px solid var(--color-primary, #1e40af); }
.rgd-stage--arr     { border-top: 3px solid #1d4ed8; background: #eff6ff; }
.rgd-stage--arr .rgd-stage-label { color: var(--color-primary, #1e40af); }
.rgd-stage--exp     { border-top: 3px solid var(--color-navy, #0f172a); }
.rgd-arrow { display: flex; align-items: center; padding: 0 3px; color: #94a3b8; font-size: 0.9rem; font-weight: 700; flex-shrink: 0; }
.rgd-visibility { margin: 4px 14px 8px; }
.rgd-vis-bar { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 10px 14px; }
.rgd-vis-label { font-size: 0.7rem; font-weight: 700; color: var(--color-primary, #1e40af); margin-bottom: 6px; }
.rgd-vis-items { display: flex; flex-wrap: wrap; gap: 6px; }
.rgd-vis-items span { font-size: 0.65rem; background: #fff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 2px 10px; color: var(--color-charcoal, #334155); }
.rgd-footer { display: flex; gap: 8px; padding: 10px 14px; background: #f0fdf4; flex-wrap: wrap; }
.rgd-tag { font-size: 0.72rem; font-weight: 600; padding: 3px 10px; border-radius: 4px; }
.rgd-tag.good { background: #dcfce7; color: #15803d; }

/* ===================================================
   DIAGRAM 3: diag--ra-repro  (standard RA hub, 7 pills)
   =================================================== */
.diag--ra-repro { padding: 28px 20px 24px; display: flex; flex-direction: column; align-items: center; gap: 0; }
.ra-pills-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; width: 100%; margin-bottom: 0; }
.ra-pill { background: #f1f5f9; border: 1px solid var(--color-border, #e2e8f0); border-radius: 4px; padding: 6px 16px; font-size: 0.78rem; font-weight: 600; color: var(--color-charcoal, #334155); }
.ra-svg { width: 100%; height: 60px; display: block; }
.ra-core { background: var(--color-navy, #0f172a); border-radius: 8px; padding: 18px 24px; width: 100%; max-width: 480px; text-align: center; }
.ra-core-title { font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 10px; letter-spacing: 0.02em; }
.ra-core-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 6px; }
.ra-core-tags span { background: rgba(255,255,255,0.12); color: #cbd5e1; font-size: 0.68rem; padding: 3px 10px; border-radius: 8px; }
.ra-connector-bar { width: 2px; height: 24px; background: var(--color-border, #e2e8f0); }
.ra-outcomes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; width: 100%; max-width: 520px; }
.ra-outcome { background: #f8fafc; border: 1px solid var(--color-border, #e2e8f0); border-radius: 8px; padding: 14px 12px; text-align: center; }
.ra-outcome--mid { border-color: var(--color-primary, #1e40af); background: #eff6ff; }
.ra-outcome--mid .ra-outcome-title { color: var(--color-primary, #1e40af); }
.ra-outcome-title { font-size: 0.78rem; font-weight: 700; color: var(--color-navy, #0f172a); margin-bottom: 6px; }
.ra-outcome-sub { font-size: 0.68rem; color: var(--color-muted, #64748b); line-height: 1.5; }

/* ===== CTA ===== */
.article-cta { background: radial-gradient(800px 360px at 85% -5%, rgba(124,92,191,0.35), transparent 55%), linear-gradient(135deg, #1e40af 0%, #1d4ed8 100%); padding: 64px 24px; text-align: center; color: #fff; }
.cta-label { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.7; margin: 0 0 12px; }
.cta-title { font-size: clamp(1.3rem, 3vw, 1.8rem); font-weight: 800; margin: 0 0 16px; line-height: 1.4; }
.cta-body { font-size: 0.95rem; opacity: 0.85; max-width: 520px; margin: 0 auto 28px; line-height: 1.7; }
.cta-btn { display: inline-block; background: #fff; color: var(--color-primary, #1e40af); font-weight: 700; font-size: 0.95rem; padding: 14px 36px; border-radius: 6px; text-decoration: none; transition: opacity 0.2s; }
.cta-btn:hover { opacity: 0.9; }
</style>

</BaseLayout>
