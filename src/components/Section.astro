---
interface Props {
	title: string;
	intro?: string;
	id?: string;
	variant?: 'default' | 'subtle';
}

const { title, intro, id, variant = 'default' } = Astro.props;
---

<section class:list={['section', variant === 'subtle' && 'section--subtle']} id={id}>
	<div class="container section__inner">
		<header class="section__header">
			<h2 class="section__title">{title}</h2>
			{intro && <p class="section__intro">{intro}</p>}
		</header>
		<div class="section__body">
			<slot />
		</div>
	</div>
</section>

<style>
	.section {
		padding-block: var(--space-xl);
	}

	.section--subtle {
		background: var(--color-bg-subtle);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
		/* Prevent double borders between adjacent subtle sections */
		margin-top: -1px;
	}

	.section__inner {
		display: flex;
		flex-direction: column;
	}

	.section__header {
		max-width: 60ch;
		margin-bottom: var(--space-lg);
	}

	.section__title {
		margin: 0 0 var(--space-sm);
		font-size: clamp(1.4rem, 2.5vw, 1.75rem);
		font-weight: 800;
		letter-spacing: -0.025em;
		color: var(--color-text);
	}

	.section__intro {
		margin: 0;
		color: var(--color-text-muted);
		line-height: 1.75;
		font-size: var(--text-lead);
	}
</style>
